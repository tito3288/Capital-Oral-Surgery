---
import { serviceGroups } from "../data/services";

interface Props {
  groupLabel: string;
  currentHref: string;
}

const { groupLabel, currentHref } = Astro.props;
const serviceGroup = serviceGroups.find(
  (group) => group.label.toLowerCase() === groupLabel.toLowerCase(),
);
---

{
  serviceGroup && (
    <aside
      class="hidden self-start min-[1400px]:sticky min-[1400px]:top-8 min-[1400px]:block min-[1400px]:w-[220px] min-[1700px]:w-[280px] min-[1700px]:justify-self-end"
      aria-label={`${groupLabel} services`}
    >
      <div class="rounded-lg border border-line bg-surface p-4 shadow-sm min-[1400px]:max-h-[calc(100dvh-4rem)] min-[1400px]:overflow-y-auto min-[1700px]:p-5">
        <p class="text-xs font-bold tracking-[.28em] text-secondary">
          {serviceGroup.label}
        </p>
        <nav class="mt-5 grid gap-1">
          {serviceGroup.items.map(({ label, href, items }) => {
            const isCurrent =
              href === currentHref || items?.some((item) => item.href === currentHref);

            return (
              <div>
                <a
                  href={href}
                  aria-current={href === currentHref ? "page" : undefined}
                  class={`group flex items-center justify-between gap-2 rounded-md px-3 py-3 text-[13px] leading-5 transition-colors min-[1700px]:px-4 min-[1700px]:text-sm ${
                    isCurrent
                      ? "bg-midnight font-bold text-surface"
                      : "text-muted hover:bg-aqua-soft hover:text-foreground"
                  }`}
                >
                  <span class="min-w-0 break-words">{label}</span>
                  <span
                    class={`shrink-0 text-xs transition-transform group-hover:translate-x-1 ${
                      isCurrent ? "text-accent" : "text-secondary"
                    }`}
                    aria-hidden="true"
                  >
                    →
                  </span>
                </a>
                {items && (
                  <div class="mt-1 grid gap-1 pl-3">
                    {items.map(({ label, href: childHref }) => {
                      const childIsCurrent =
                        childHref === currentHref && childHref !== href;

                      return (
                        <a
                          href={childHref}
                          aria-current={childIsCurrent ? "page" : undefined}
                          class={`rounded-md px-3 py-2 text-[13px] leading-5 transition-colors min-[1700px]:px-4 min-[1700px]:text-sm ${
                            childIsCurrent
                              ? "bg-aqua-soft font-bold text-foreground"
                              : "text-muted hover:bg-aqua-soft hover:text-foreground"
                          }`}
                        >
                          {label}
                        </a>
                      );
                    })}
                  </div>
                )}
              </div>
            );
          })}
        </nav>
      </div>
    </aside>
  )
}
