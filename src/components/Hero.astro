---
---

<section class="relative min-h-[720px] overflow-hidden">
  <img
    src="/images/hero.jpg"
    alt=""
    aria-hidden="true"
    class="absolute inset-0 h-full w-full object-cover"
    width="5184"
    height="3456"
    loading="eager"
    fetchpriority="high"
  />

  <div class="absolute inset-0 bg-neutral-dark/65"></div>
  <div
    class="absolute inset-0"
    style="background-image:
      radial-gradient(circle at center, color-mix(in srgb, var(--color-secondary) 35%, transparent), transparent 34%),
      linear-gradient(to top, color-mix(in srgb, var(--color-neutral-dark) 95%, transparent), transparent 55%);"
  >
  </div>

  <div
    class="relative z-10 mx-auto flex min-h-[720px] max-w-5xl flex-col items-center justify-center px-5 py-24 text-center"
  >
    <p
      class="mb-5 rounded-full border border-accent/30 bg-white/10 px-4 py-2 text-xs font-bold uppercase tracking-[.28em] text-accent backdrop-blur"
    >
      Topeka Oral Surgery & Dental Implants
    </p>

    <h1
      class="max-w-4xl text-4xl font-black leading-[.95] tracking-tight text-white sm:text-5xl lg:text-7xl"
    >
      Creating Healthy and Beautiful Smiles.
    </h1>

    <p class="mt-6 max-w-2xl text-lg leading-8 text-white/90 sm:text-xl">
      Dr. Lucaci, Dr. Barber, Dr. Lonergan and our caring staff provide an
      exceptional experience, advanced treatment, and brilliant results for
      every patient.
    </p>

    <div class="mt-9 flex flex-col gap-3 sm:flex-row">
      <a
        href="#"
        class="rounded-full bg-secondary px-8 py-4 text-base font-extrabold text-neutral-dark shadow-xl shadow-secondary/25 transition-opacity hover:opacity-90"
      >
        Request an Appointment
      </a>
      <a
        href="tel:7855884244"
        class="rounded-full border border-white/30 bg-white/10 px-8 py-4 text-base font-extrabold text-white backdrop-blur transition-colors hover:bg-white/20"
      >
        Call (785) 588-4244
      </a>
    </div>
  </div>
</section>
