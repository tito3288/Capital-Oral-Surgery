---
import { doctors } from "../data/doctors";
---

<section
  id="team"
  class="overflow-hidden bg-surface text-foreground"
  aria-labelledby="team-heading"
>
  <div class="mx-auto max-w-7xl px-5 pb-28 pt-10 lg:px-0 lg:pt-12">
    <div class="text-center" data-reveal>
      <p class="text-xs font-bold tracking-[.34em] text-secondary">
        Meet the team
      </p>
      <h2
        id="team-heading"
        class="serif mx-auto mt-4 max-w-4xl text-4xl leading-tight text-foreground sm:text-5xl"
      >
        Three specialists. One trusted practice.
      </h2>
    </div>

    <div class="mt-16 grid gap-10 md:grid-cols-3">
      {
        doctors.map(
          (
            {
              name,
              slug,
              initials,
              image,
              imageAlt,
              imageWidth,
              imageHeight,
              imagePosition,
              role,
            },
            index,
          ) => (
          <article data-reveal style={`--reveal-delay: ${index * 90}ms`}>
            <a
              href={`/doctors/${slug}/`}
              class="group block focus:outline-none focus-visible:ring-2 focus-visible:ring-secondary focus-visible:ring-offset-8"
              aria-label={`Meet ${name}`}
            >
              <div class="relative">
              <div
                class="absolute -bottom-3 left-3 right-[-12px] top-3 rounded-lg border border-secondary transition-transform duration-300 group-hover:translate-x-1 group-hover:translate-y-1"
                aria-hidden="true"
              >
              </div>
              <div
                class="relative flex aspect-[20/19] items-center justify-center overflow-hidden rounded-lg bg-midnight text-surface"
                aria-label={image ? undefined : `${name} portrait image placeholder`}
                role={image ? undefined : "img"}
              >
                {
                  image ? (
                    <img
                      src={image}
                      alt={imageAlt}
                      class="h-full w-full object-cover"
                      style={`object-position: ${imagePosition};`}
                      width={imageWidth}
                      height={imageHeight}
                      loading="lazy"
                      decoding="async"
                    />
                  ) : (
                    <span class="serif text-5xl font-bold">{initials}</span>
                  )
                }
              </div>
            </div>

              <h3 class="serif mt-8 text-2xl font-bold text-foreground transition-colors group-hover:text-secondary">
                {name}
              </h3>
              <p class="mt-3 text-xs font-bold tracking-[.32em] text-secondary">
                {role}
              </p>
              <p class="mt-5 inline-flex items-center text-sm font-bold text-foreground transition-colors group-hover:text-secondary">
                View Bio
                <span class="ml-2 transition-transform group-hover:translate-x-1" aria-hidden="true">
                  →
                </span>
              </p>
            </a>
          </article>
          ),
        )
      }
    </div>
  </div>
</section>
