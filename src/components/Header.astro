---
const navLinks = [
  { label: "Dental Implants", href: "#" },
  { label: "Wisdom Teeth", href: "#" },
  { label: "Procedures", href: "#" },
  { label: "Meet Us", href: "#" },
];
---

<header class="relative z-40 bg-primary text-white">
  <div class="mx-auto flex max-w-7xl items-center justify-between px-5 py-4 lg:px-8">
    <a href="/" class="inline-flex" aria-label="Capital Oral Surgery — Home">
      <img
        src="/images/logo-header.png"
        alt="Capital Oral Surgery logo"
        class="h-14 w-auto md:h-16 lg:h-[70px]"
        width="2200"
        height="399"
      />
    </a>

    <nav class="hidden gap-7 text-sm font-semibold md:flex" aria-label="Primary">
      {
        navLinks.map(({ label, href }) => (
          <a class="transition-colors hover:text-secondary" href={href}>
            {label}
          </a>
        ))
      }
    </nav>

    <a
      href="#"
      class="hidden rounded-none border-2 border-secondary px-5 py-3 text-sm font-bold uppercase tracking-widest text-accent-alt md:inline-flex"
    >
      Request Visit
    </a>

    <details class="group md:hidden">
      <summary
        class="flex h-11 w-11 cursor-pointer list-none items-center justify-center border border-white/30 text-white select-none"
        aria-label="Toggle navigation menu"
      >
        <svg
          class="h-6 w-6 group-open:hidden"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="square"
          aria-hidden="true"
        >
          <line x1="4" y1="7" x2="20" y2="7" />
          <line x1="4" y1="12" x2="20" y2="12" />
          <line x1="4" y1="17" x2="20" y2="17" />
        </svg>
        <svg
          class="hidden h-6 w-6 group-open:block"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="square"
          aria-hidden="true"
        >
          <line x1="6" y1="6" x2="18" y2="18" />
          <line x1="18" y1="6" x2="6" y2="18" />
        </svg>
      </summary>
      <div class="absolute left-0 right-0 top-full bg-primary p-5 shadow-xl">
        {
          navLinks.map(({ label, href }) => (
            <a class="block py-2 hover:text-secondary" href={href}>
              {label}
            </a>
          ))
        }
        <a
          href="#"
          class="mt-3 inline-flex border-2 border-secondary px-5 py-3 text-sm font-bold uppercase tracking-widest text-accent-alt"
        >
          Request Visit
        </a>
      </div>
    </details>
  </div>
</header>
