---
import { doctors } from "../data/doctors";
import { serviceGroups } from "../data/services";

const navLinks = [
  { label: "About", href: "/#about" },
  { label: "Services", href: "/#procedures" },
  { label: "Doctors", href: "/#team" },
  { label: "Contact", href: "/contact-us/" },
];

const doctorLinks = doctors.map(({ name, slug }) => ({
  label: name,
  href: `/doctors/${slug}/`,
}));
---

<header class="relative z-40 border-b border-surface/5 bg-midnight text-surface">
  <div
    class="mx-auto flex min-h-[76px] max-w-[1232px] items-center justify-between px-5"
  >
    <a href="/" class="inline-flex" aria-label="Capital Oral Surgery — Home">
      <img
        src="/images/logo-header.png"
        alt="Capital Oral Surgery logo"
        class="h-auto max-h-10 w-[min(62vw,11rem)] object-contain md:h-8 md:w-auto md:max-w-none"
        width="2200"
        height="399"
      />
    </a>

    <nav
      class="hidden items-center gap-9 self-stretch text-[15px] font-medium xl:flex"
      aria-label="Primary"
    >
      {
        navLinks.map(({ label, href }) =>
          label === "Services" ? (
            <div class="group static flex min-h-[76px] items-center">
              <a
                class="inline-flex items-center gap-2 transition-colors hover:text-accent focus:outline-none focus-visible:text-accent"
                href={href}
                aria-haspopup="true"
              >
                {label}
                <span
                  class="text-[10px] leading-none transition-transform group-hover:rotate-180 group-focus-within:rotate-180"
                  aria-hidden="true"
                >
                  ▾
                </span>
              </a>
              <div
                class="invisible absolute left-[max(1.25rem,calc((100vw-1232px)/2))] top-full z-50 w-[min(calc(100vw-20rem),960px)] min-w-[860px] pt-4 opacity-0 transition duration-150 group-hover:visible group-hover:opacity-100 group-focus-within:visible group-focus-within:opacity-100"
              >
                <div class="grid gap-8 rounded-lg border border-line/70 bg-surface p-8 text-foreground shadow-2xl md:grid-cols-3">
                  {
                    serviceGroups.map(({ label, href, items }) => (
                      <div>
                        <a
                          href={href}
                          class="block border-b border-line pb-4 text-xs font-bold tracking-[.28em] text-secondary transition-colors hover:text-foreground focus:text-foreground focus:outline-none"
                        >
                          {label}
                        </a>
                        <div class="mt-4 grid gap-1">
                          {items.map(({ label, href, items: childItems }) => (
                            <div class="group/submenu relative">
                              <a
                                href={href}
                                class="flex items-center justify-between rounded-md px-2 py-2 text-[14px] leading-5 text-muted transition-colors hover:bg-aqua-soft hover:text-foreground focus:bg-aqua-soft focus:text-foreground focus:outline-none"
                                aria-haspopup={childItems ? "true" : undefined}
                              >
                                <span>{label}</span>
                                {childItems && (
                                  <span class="ml-2 text-xs text-secondary" aria-hidden="true">
                                    →
                                  </span>
                                )}
                              </a>
                              {childItems && (
                                <div
                                  class="invisible absolute left-full top-0 z-50 w-72 pl-3 opacity-0 transition duration-150 group-hover/submenu:visible group-hover/submenu:opacity-100 group-focus-within/submenu:visible group-focus-within/submenu:opacity-100"
                                >
                                  <div class="rounded-lg border border-line/70 bg-surface p-3 shadow-2xl">
                                    {childItems.map(({ label, href }) => (
                                      <a
                                        href={href}
                                        class="block rounded-md px-4 py-3 text-sm leading-5 text-muted transition-colors hover:bg-aqua-soft hover:text-foreground focus:bg-aqua-soft focus:text-foreground focus:outline-none"
                                      >
                                        {label}
                                      </a>
                                    ))}
                                  </div>
                                </div>
                              )}
                            </div>
                          ))}
                        </div>
                      </div>
                    ))
                  }
                </div>
              </div>
            </div>
          ) : label === "Doctors" ? (
            <div class="group relative flex min-h-[76px] items-center">
              <a
                class="inline-flex items-center gap-2 transition-colors hover:text-accent focus:outline-none focus-visible:text-accent"
                href={href}
              >
                {label}
                <span
                  class="text-[10px] leading-none transition-transform group-hover:rotate-180 group-focus-within:rotate-180"
                  aria-hidden="true"
                >
                  ▾
                </span>
              </a>
              <div
                class="invisible absolute left-1/2 top-full z-50 w-64 -translate-x-1/2 pt-4 opacity-0 transition duration-150 group-hover:visible group-hover:opacity-100 group-focus-within:visible group-focus-within:opacity-100"
              >
                <div class="rounded-lg border border-surface/10 bg-midnight p-3 shadow-2xl">
                  <a
                    href="/#team"
                    class="block rounded-md px-4 py-3 text-sm font-bold text-surface/70 transition-colors hover:bg-surface/10 hover:text-accent focus:bg-surface/10 focus:text-accent focus:outline-none"
                  >
                    Meet All Doctors
                  </a>
                  {
                    doctorLinks.map(({ label, href }) => (
                      <a
                        href={href}
                        class="block rounded-md px-4 py-3 text-sm text-surface transition-colors hover:bg-surface/10 hover:text-accent focus:bg-surface/10 focus:text-accent focus:outline-none"
                      >
                        {label}
                      </a>
                    ))
                  }
                </div>
              </div>
            </div>
          ) : (
            <a
              class="inline-flex min-h-[76px] items-center transition-colors hover:text-accent"
              href={href}
            >
              {label}
            </a>
          ),
        )
      }
    </nav>

    <div class="hidden items-center gap-3 xl:flex">
      <a
        href="/contact-us/"
        class="inline-flex h-11 items-center rounded-md bg-secondary px-5 text-sm font-bold text-surface transition-opacity hover:opacity-90"
      >
        Request Appointment
      </a>
      <a
        href="/referring-doctors"
        class="inline-flex h-11 items-center rounded-md border border-surface/30 px-5 text-sm font-bold text-surface transition-colors hover:border-secondary hover:text-accent"
      >
        Referring Doctors
      </a>
    </div>

    <details class="group/menu xl:hidden">
      <summary
        class="flex h-11 w-11 cursor-pointer list-none items-center justify-center rounded-md border border-surface/30 text-surface select-none"
        aria-label="Toggle navigation menu"
      >
        <svg
          class="h-6 w-6 group-open/menu:hidden"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="square"
          aria-hidden="true"
        >
          <line x1="4" y1="7" x2="20" y2="7" />
          <line x1="4" y1="12" x2="20" y2="12" />
          <line x1="4" y1="17" x2="20" y2="17" />
        </svg>
        <svg
          class="hidden h-6 w-6 group-open/menu:block"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="square"
          aria-hidden="true"
        >
          <line x1="6" y1="6" x2="18" y2="18" />
          <line x1="18" y1="6" x2="6" y2="18" />
        </svg>
      </summary>
      <div class="absolute left-0 right-0 top-full h-[calc(100dvh-76px)] overflow-y-auto rounded-b-lg bg-surface text-foreground shadow-xl">
        <div class="flex min-h-full flex-col px-5 py-8">
          <nav aria-label="Mobile primary">
            {
              navLinks.map(({ label, href }) =>
                label === "Services" ? (
                  <details class="group/services border-y border-foreground/10 py-1" open>
                    <summary class="flex cursor-pointer list-none items-center justify-between py-3 text-lg font-medium text-foreground hover:text-secondary">
                      <span>{label}</span>
                      <span
                        class="text-sm transition-transform group-open/services:rotate-180"
                        aria-hidden="true"
                      >
                        ▾
                      </span>
                    </summary>
                    <div class="pb-2">
                      {serviceGroups.map(({ label, items }) => (
                        <details class="group/category border-t border-foreground/10 py-1">
                          <summary class="flex cursor-pointer list-none items-center justify-between py-3 pl-3 text-xs font-bold tracking-[.28em] text-foreground hover:text-secondary">
                            <span>{label}</span>
                            <span
                              class="text-sm transition-transform group-open/category:rotate-180"
                              aria-hidden="true"
                            >
                              ▾
                            </span>
                          </summary>
                          <div class="grid gap-1 pb-3 pl-7">
                            {items.map(({ label, href, items: childItems }) =>
                              childItems ? (
                                <details class="group/mobile-sub">
                                  <summary class="flex cursor-pointer list-none items-center justify-between rounded-md px-3 py-2 text-sm text-muted hover:bg-aqua-soft hover:text-foreground">
                                    <span>{label}</span>
                                    <span
                                      class="text-xs transition-transform group-open/mobile-sub:rotate-180"
                                      aria-hidden="true"
                                    >
                                      ▾
                                    </span>
                                  </summary>
                                  <div class="grid gap-1 pb-2 pl-4">
                                    {childItems.map(({ label, href }) => (
                                      <a
                                        class="block rounded-md px-3 py-2 text-sm text-muted hover:bg-aqua-soft hover:text-foreground focus:bg-aqua-soft focus:text-foreground focus:outline-none"
                                        href={href}
                                      >
                                        {label}
                                      </a>
                                    ))}
                                  </div>
                                </details>
                              ) : (
                                <a
                                  class="block rounded-md px-3 py-2 text-sm text-muted hover:bg-aqua-soft hover:text-foreground focus:bg-aqua-soft focus:text-foreground focus:outline-none"
                                  href={href}
                                >
                                  {label}
                                </a>
                              ),
                            )}
                          </div>
                        </details>
                      ))}
                    </div>
                  </details>
                ) : label === "Doctors" ? (
                  <details class="group/doctors border-y border-foreground/10 py-1">
                    <summary class="flex cursor-pointer list-none items-center justify-between py-3 text-lg text-foreground hover:text-secondary">
                      <span>{label}</span>
                      <span
                        class="text-sm transition-transform group-open/doctors:rotate-180"
                        aria-hidden="true"
                      >
                        ▾
                      </span>
                    </summary>
                    <div class="pb-4 pl-4">
                      <a
                        class="block py-2 text-sm font-bold text-muted hover:text-secondary"
                        href={href}
                      >
                        Meet All Doctors
                      </a>
                      {
                        doctorLinks.map(({ label, href }) => (
                          <a
                            class="block py-2 text-base text-foreground hover:text-secondary"
                            href={href}
                          >
                            {label}
                          </a>
                        ))
                      }
                    </div>
                  </details>
                ) : (
                  <a class="block py-3 text-lg text-foreground hover:text-secondary" href={href}>
                    {label}
                  </a>
                ),
              )
            }
          </nav>
          <div class="mt-8 grid gap-3 sm:grid-cols-2">
            <a
              href="/contact-us/"
              class="inline-flex justify-center rounded-md bg-secondary px-5 py-3 text-sm font-bold text-surface"
            >
              Request Appointment
            </a>
            <a
              href="/referring-doctors"
              class="inline-flex justify-center rounded-md border border-foreground/20 px-5 py-3 text-sm font-bold text-foreground"
            >
              Referring Doctors
            </a>
          </div>
        </div>
      </div>
    </details>
  </div>
</header>
