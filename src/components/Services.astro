---
const services = [
  {
    title: "Dental Implants",
    body: "Advanced implant technologies, including immediate implants and Straumann guided implant planning.",
  },
  {
    title: "Bone Grafting",
    body: "Techniques designed to rebuild bone structure with minimal surgical intervention and optimal comfort.",
  },
  {
    title: "Wisdom Teeth Removal",
    body: "Evaluation and removal of third molars, commonly appearing between ages 14 and 21.",
  },
  {
    title: "Tooth Extractions",
    body: "Comfort-focused extractions for damaged or impacted teeth, with replacement planning when needed.",
  },
  {
    title: "Oral Pathology",
    body: "Oral biopsy and diagnosis support for persistent lesions or abnormal tissue in the mouth.",
  },
  {
    title: "Anesthesia",
    body: "Local anesthesia, IV sedation, and outpatient general anesthesia with continuous monitoring.",
  },
];
---

<section class="mx-auto max-w-7xl px-5 py-24 lg:px-8" aria-labelledby="services-heading">
  <div class="mx-auto max-w-3xl text-center">
    <p class="font-black uppercase tracking-[.25em] text-secondary">
      What We Offer
    </p>
    <h2 id="services-heading" class="serif mt-4 text-4xl leading-tight sm:text-5xl">
      A complete oral surgery experience in one trusted location.
    </h2>
  </div>
  <div class="mt-14 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
    {
      services.map(({ title, body }) => (
        <article class="bg-white p-8 shadow-sm">
          <h3 class="serif text-2xl">{title}</h3>
          <p class="mt-4 leading-7 text-muted">{body}</p>
        </article>
      ))
    }
  </div>
</section>
