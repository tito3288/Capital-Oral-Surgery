---
const pillars = [
  {
    title: "Comfort",
    body: "Clear communication and sedation options help ease dental anxiety.",
  },
  {
    title: "Technology",
    body: "State-of-the-art equipment supports accurate planning and efficient treatment.",
  },
  {
    title: "Access",
    body: "Appointment reminders and quick turnaround on requests respect your time.",
  },
  {
    title: "Affordability",
    body: "Payment options, insurance help, and up-front cost information.",
  },
];
---

<section class="bg-primary text-white" aria-labelledby="confidence-heading">
  <div
    class="mx-auto grid max-w-7xl gap-12 px-5 py-20 lg:grid-cols-[.9fr_1.1fr] lg:px-8"
  >
    <div>
      <p class="font-black uppercase tracking-[.25em] text-accent">
        Patient Confidence
      </p>
      <h2
        id="confidence-heading"
        class="serif mt-4 text-4xl leading-tight sm:text-5xl"
      >
        A positive interaction at every step.
      </h2>
    </div>
    <div class="grid gap-5 sm:grid-cols-2">
      {
        pillars.map(({ title, body }) => (
          <div class="border border-white/15 p-6">
            <h3 class="font-bold text-accent">{title}</h3>
            <p class="mt-3 text-white/80">{body}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>
