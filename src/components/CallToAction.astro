<section class="px-5 py-24" aria-labelledby="cta-heading">
  <div
    class="mx-auto max-w-6xl bg-white p-8 shadow-xl sm:p-12 lg:flex lg:items-center lg:justify-between"
  >
    <div>
      <p class="font-bold uppercase tracking-widest text-secondary">
        Ready for your first visit?
      </p>
      <h2 id="cta-heading" class="serif mt-3 text-4xl">
        Book an appointment today.
      </h2>
      <p class="mt-4 max-w-2xl text-muted">
        Bring your referral slip, x-rays if applicable, medication list, and
        insurance information to your consultation.
      </p>
    </div>
    <a
      href="#"
      class="mt-8 inline-flex bg-primary px-8 py-4 font-extrabold text-white transition-opacity hover:opacity-90 lg:mt-0"
    >
      Request an Appointment
    </a>
  </div>
</section>
