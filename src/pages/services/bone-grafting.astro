---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import ServiceSidebar from "../../components/ServiceSidebar.astro";

const title = "Bone Grafting | Topeka, KS | Capital Oral Surgery";
const description =
  "Learn how major and minor bone grafting can restore jawbone volume for dental implants, function, and facial support in Topeka, KS.";

const currentHref = "/services/bone-grafting/";

const graftingUses = [
  {
    number: "01",
    title: "Missing teeth",
    body: "When teeth are missing for a period of time, the jawbone can shrink or resorb. This can affect implant options, tooth position, and facial support.",
  },
  {
    number: "02",
    title: "Previous extractions",
    body: "Extraction sites may not always heal with enough height, width, or density for future implant placement. Grafting can rebuild the area before treatment.",
  },
  {
    number: "03",
    title: "Gum disease or injury",
    body: "Bone loss from periodontal disease, trauma, or other defects may need reconstruction before the jaw can support a stable restoration.",
  },
  {
    number: "04",
    title: "Upper back jawbone",
    body: "Sinus grafting can restore bone in the posterior upper jaw when the sinus is close to the area where an implant needs to be placed.",
  },
];

const graftingOptions = [
  "Tissue-bank grafting material",
  "Bone from another area of your own body",
  "Sinus bone grafting for the upper jaw",
  "Protective membranes for guided regeneration",
];
---

<Layout title={title} description={description} ogImage="/images/specialized-care.jpg">
  <Header />
  <main>
    <section class="bg-midnight text-surface" aria-labelledby="service-heading">
      <div
        class="mx-auto grid min-h-[calc(100dvh-76px)] max-w-7xl items-center gap-10 px-5 py-14 lg:gap-14 xl:grid-cols-[minmax(0,610px)_minmax(360px,500px)] xl:justify-between xl:px-0"
      >
        <div data-reveal>
          <a
            href="/#procedures"
            class="inline-flex text-sm font-bold text-accent transition-colors hover:text-surface"
          >
            ← Services
          </a>
          <p class="mt-10 text-xs font-bold tracking-[.34em] text-secondary">
            Procedures
          </p>
          <h1
            id="service-heading"
            class="serif mt-5 max-w-[760px] text-5xl leading-[0.96] text-surface sm:text-6xl xl:text-[72px]"
          >
            Bone grafting.
          </h1>
          <p class="mt-7 max-w-[590px] text-lg leading-8 text-surface/75 sm:text-xl">
            Bone grafting helps rebuild jawbone where it has thinned, softened, or
            resorbed. Restoring that foundation can make dental implants possible and
            help protect long-term function and facial support.
          </p>
          <div class="mt-9 flex flex-col gap-3 sm:flex-row">
            <a
              href="/#appointment"
              class="inline-flex h-14 items-center justify-center rounded-md bg-secondary px-7 font-bold text-surface transition-opacity hover:opacity-90 sm:min-w-[223px]"
            >
              Request Appointment
            </a>
            <a
              href="tel:7852720444"
              class="inline-flex h-14 items-center justify-center rounded-md border border-surface/40 px-7 font-bold text-surface transition-colors hover:bg-surface/10 sm:min-w-[216px]"
            >
              Call (785) 272-0444
            </a>
          </div>
        </div>

        <div
          class="relative mx-auto w-full max-w-[500px] lg:mx-0"
          data-reveal
          style="--reveal-delay: 120ms"
        >
          <div
            class="absolute -bottom-3 left-3 right-[-12px] top-3 rounded-lg border border-secondary"
            aria-hidden="true"
          >
          </div>
          <div class="relative aspect-[4/5] overflow-hidden rounded-lg bg-surface/5">
            <img
              src="/images/specialized-care.jpg"
              alt="Dental imaging equipment used for oral surgery and bone grafting planning"
              class="h-full w-full object-cover object-center"
              width="5184"
              height="3456"
              loading="eager"
              decoding="async"
              fetchpriority="high"
            />
          </div>
        </div>
      </div>
    </section>

    <section class="bg-background py-20 text-foreground lg:py-24">
      <div
        class="mx-auto grid max-w-[920px] gap-10 px-5 min-[1400px]:max-w-[1400px] min-[1400px]:grid-cols-[220px_minmax(0,840px)_220px] min-[1400px]:items-start min-[1400px]:gap-8 min-[1700px]:max-w-[1640px] min-[1700px]:grid-cols-[280px_minmax(0,920px)_280px] min-[1700px]:gap-12"
      >
        <ServiceSidebar groupLabel="Procedures" currentHref={currentHref} />

        <div class="grid gap-20 lg:gap-24 min-[1400px]:col-start-2">
          <section class="pb-2 lg:pb-0" aria-labelledby="foundation-heading">
            <div class="max-w-5xl" data-reveal>
              <p class="text-xs font-bold tracking-[.34em] text-secondary">
                Major & minor bone grafting
              </p>
              <h2
                id="foundation-heading"
                class="serif mt-4 text-4xl leading-tight sm:text-5xl"
              >
                Healthy jawbone creates the foundation for strong replacement teeth.
              </h2>
              <div class="mt-7 space-y-6 text-base leading-8 text-muted">
                <p>
                  Missing teeth can allow the jawbone to atrophy over time. As bone
                  volume changes, there may be less support for dental implants, and the
                  surrounding teeth and facial structure can also be affected.
                </p>
                <p>
                  Bone grafting gives the team a way to build bone where it is needed.
                  That added support can help make implants the right length and width
                  possible while improving function and appearance.
                </p>
                <p>
                  Some grafting needs are minor and focused on a future implant site.
                  Larger defects from injury, tumor surgery, or developmental concerns
                  may require more extensive reconstruction.
                </p>
              </div>

              <div class="mt-8 rounded-lg border border-line bg-surface p-7 shadow-sm sm:p-8">
                <p class="text-xs font-bold tracking-[.28em] text-secondary">
                  Why timing matters
                </p>
                <p class="mt-3 text-base leading-7 text-muted">
                  Rebuilding bone before implant placement can preserve more treatment
                  options and reduce the chance that tooth replacement becomes more
                  complicated later.
                </p>
              </div>
            </div>
          </section>

          <section class="pt-4 lg:pt-2" aria-labelledby="uses-heading">
            <div class="max-w-3xl" data-reveal>
              <p class="text-xs font-bold tracking-[.34em] text-secondary">
                When grafting helps
              </p>
              <h2
                id="uses-heading"
                class="serif mt-4 text-4xl leading-tight sm:text-5xl"
              >
                Bone can be restored in areas that need more support.
              </h2>
              <p class="mt-6 text-base leading-7 text-muted">
                Your treatment plan depends on the location of the missing tooth, the
                amount of remaining bone, the cause of bone loss, and the type of
                restoration being planned.
              </p>
            </div>

            <div class="mt-12 grid gap-6 lg:grid-cols-2 lg:gap-7">
              {
                graftingUses.map(({ number, title, body }, index) => (
                  <article
                    class="rounded-lg border border-line bg-surface p-8 shadow-sm sm:p-9 lg:p-10"
                    data-reveal
                    style={`--reveal-delay: ${(index % 2) * 80}ms`}
                  >
                    <div class="flex h-10 w-10 items-center justify-center rounded-full bg-aqua-pale text-sm font-bold text-secondary">
                      {number}
                    </div>
                    <h3 class="serif mt-6 text-2xl font-bold text-foreground">
                      {title}
                    </h3>
                    <p class="mt-4 text-base leading-7 text-muted">{body}</p>
                  </article>
                ))
              }
            </div>
          </section>

          <section
            class="grid gap-10 rounded-lg bg-aqua-soft p-8 sm:p-10 lg:grid-cols-[minmax(0,1fr)_280px] lg:items-center lg:p-12"
            aria-labelledby="options-heading"
            data-reveal
          >
            <div>
              <p class="text-xs font-bold tracking-[.34em] text-secondary">
                Grafting materials
              </p>
              <h2
                id="options-heading"
                class="serif mt-4 text-4xl leading-tight sm:text-5xl"
              >
                The graft source is matched to the size and location of the defect.
              </h2>
              <p class="mt-6 text-base leading-7 text-muted">
                Bone may come from a tissue bank or, for some larger repairs, from
                another area of your own body. Protective membranes may also be placed
                under the gum to help guide new bone growth as the area heals.
              </p>
            </div>
            <div class="grid gap-3 text-sm font-bold text-foreground">
              {graftingOptions.map((item) => (
                <p class="rounded-md bg-surface px-4 py-3">{item}</p>
              ))}
            </div>
          </section>

          <section class="grid gap-8 md:grid-cols-2">
            <article class="rounded-lg border border-line bg-surface p-8 shadow-sm sm:p-9 lg:p-10" data-reveal>
              <p class="text-xs font-bold tracking-[.28em] text-secondary">
                Guided regeneration
              </p>
              <h2 class="serif mt-5 text-3xl leading-tight text-foreground">
                Membranes can help protect the graft as bone forms.
              </h2>
              <p class="mt-6 text-base leading-7 text-muted">
                In some cases, a dissolvable membrane is placed beneath the gum tissue.
                This helps shield the grafted area and supports guided bone or tissue
                regeneration during healing.
              </p>
            </article>

            <article
              class="rounded-lg border border-line bg-surface p-8 shadow-sm sm:p-9 lg:p-10"
              data-reveal
              style="--reveal-delay: 120ms"
            >
              <p class="text-xs font-bold tracking-[.28em] text-secondary">
                Major bone grafting
              </p>
              <h2 class="serif mt-5 text-3xl leading-tight text-foreground">
                Larger jaw defects may need a more advanced repair.
              </h2>
              <p class="mt-6 text-base leading-7 text-muted">
                Major grafts can repair defects related to trauma, tumor surgery, or
                congenital concerns. These cases may use the patient's own bone and are
                often performed in an operating room setting.
              </p>
            </article>
          </section>

          <section class="rounded-lg bg-midnight px-8 py-12 text-surface sm:px-10 lg:px-12 lg:py-14">
            <div class="grid gap-8 lg:grid-cols-[minmax(0,1fr)_auto] lg:items-center">
              <div data-reveal>
                <p class="text-xs font-bold tracking-[.34em] text-secondary">
                  We are here to help
                </p>
                <h2 class="serif mt-4 text-4xl leading-tight sm:text-5xl">
                  Start with a grafting consultation.
                </h2>
                <p class="mt-5 max-w-[660px] text-base leading-7 text-surface/75">
                  We will review imaging, explain your bone volume, and walk through the
                  grafting options that make sense for your treatment goals.
                </p>
              </div>
              <div
                class="flex flex-col gap-3 sm:flex-row lg:flex-col"
                data-reveal
                style="--reveal-delay: 120ms"
              >
                <a
                  href="/#appointment"
                  class="inline-flex h-14 items-center justify-center rounded-md bg-secondary px-7 font-bold text-surface transition-opacity hover:opacity-90"
                >
                  Request Appointment
                </a>
                <a
                  href="tel:7852720444"
                  class="inline-flex h-14 items-center justify-center rounded-md border border-surface/40 px-7 font-bold text-surface transition-colors hover:bg-surface/10"
                >
                  Call (785) 272-0444
                </a>
              </div>
            </div>
          </section>
        </div>

        <div class="hidden min-[1400px]:block" aria-hidden="true"></div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
