---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import ServiceSidebar from "../../components/ServiceSidebar.astro";

const title = "Tooth Extractions | Topeka, KS | Capital Oral Surgery";
const description =
  "Learn why a tooth may need extraction, what to expect during removal, sectioning, replacement planning, and after-care guidance.";

const currentHref = "/services/tooth-extractions/";

const extractionReasons = [
  {
    number: "01",
    title: "Severe decay",
    body: "A tooth may need to be removed when decay has damaged it beyond predictable repair.",
  },
  {
    number: "02",
    title: "Advanced periodontal disease",
    body: "Gum disease can weaken the bone and tissues that hold a tooth in place, making extraction the healthiest option.",
  },
  {
    number: "03",
    title: "Broken or unrestorable teeth",
    body: "Teeth that fracture deeply or cannot be restored with a crown or filling may need removal.",
  },
  {
    number: "04",
    title: "Impacted or poorly positioned teeth",
    body: "Some teeth are removed because they are trapped, poorly aligned, or need to come out before orthodontic treatment.",
  },
];

const visitDetails = [
  "Local anesthetic numbs the tooth, jawbone, and gums",
  "Pressure is expected, but pain should not be",
  "Some teeth are sectioned into smaller pieces",
  "Replacement options are reviewed when needed",
];
---

<Layout title={title} description={description} ogImage="/images/specialized-care.jpg">
  <Header />
  <main>
    <section class="bg-midnight text-surface" aria-labelledby="service-heading">
      <div
        class="mx-auto grid min-h-[calc(100dvh-76px)] max-w-7xl items-center gap-14 px-5 py-14 lg:grid-cols-[minmax(0,610px)_minmax(380px,500px)] lg:px-0"
      >
        <div data-reveal>
          <a
            href="/#procedures"
            class="inline-flex text-sm font-bold text-accent transition-colors hover:text-surface"
          >
            ← Services
          </a>
          <p class="mt-10 text-xs font-bold uppercase tracking-[.34em] text-secondary">
            Procedures
          </p>
          <h1
            id="service-heading"
            class="serif mt-5 max-w-[760px] text-5xl leading-[0.96] text-surface sm:text-6xl lg:text-[72px]"
          >
            Tooth extractions.
          </h1>
          <p class="mt-7 max-w-[590px] text-lg leading-8 text-surface/75 sm:text-xl">
            When a tooth cannot be predictably restored, extraction may protect your
            overall oral health. We also review alternatives and replacement options so
            you understand the full plan, not just the procedure.
          </p>
          <div class="mt-9 flex flex-col gap-3 sm:flex-row">
            <a
              href="/#appointment"
              class="inline-flex h-14 items-center justify-center rounded-md bg-secondary px-7 font-bold text-surface transition-opacity hover:opacity-90 sm:min-w-[223px]"
            >
              Request Appointment
            </a>
            <a
              href="tel:7852720444"
              class="inline-flex h-14 items-center justify-center rounded-md border border-surface/40 px-7 font-bold text-surface transition-colors hover:bg-surface/10 sm:min-w-[216px]"
            >
              Call (785) 272-0444
            </a>
          </div>
        </div>

        <div
          class="relative mx-auto w-full max-w-[500px] lg:mx-0"
          data-reveal
          style="--reveal-delay: 120ms"
        >
          <div
            class="absolute -bottom-3 left-3 right-[-12px] top-3 rounded-lg border border-secondary"
            aria-hidden="true"
          >
          </div>
          <div class="relative aspect-[4/5] overflow-hidden rounded-lg bg-surface/5">
            <img
              src="/images/specialized-care.jpg"
              alt="Dental imaging equipment used to plan tooth extractions"
              class="h-full w-full object-cover object-center"
              width="5184"
              height="3456"
              loading="eager"
              decoding="async"
              fetchpriority="high"
            />
          </div>
        </div>
      </div>
    </section>

    <section class="bg-background py-20 text-foreground lg:py-24">
      <div
        class="mx-auto grid max-w-[1600px] gap-10 px-5 lg:grid-cols-[minmax(0,1fr)_minmax(0,920px)_minmax(0,1fr)] lg:items-start lg:gap-12"
      >
        <ServiceSidebar groupLabel="Procedures" currentHref={currentHref} />

        <div class="grid gap-20 lg:col-start-2 lg:gap-24">
          <section class="pb-2 lg:pb-0" aria-labelledby="overview-heading">
            <div class="max-w-5xl" data-reveal>
              <p class="text-xs font-bold uppercase tracking-[.34em] text-secondary">
                When Removal Is Needed
              </p>
              <h2
                id="overview-heading"
                class="serif mt-4 text-4xl leading-tight sm:text-5xl"
              >
                Extraction is sometimes the healthiest path forward.
              </h2>
              <div class="mt-7 space-y-6 text-base leading-8 text-muted">
                <p>
                  A tooth may need to be removed for many reasons, including severe
                  decay, advanced periodontal disease, fracture, poor positioning,
                  impaction, or orthodontic preparation.
                </p>
                <p>
                  Removing a tooth can affect chewing, jaw joint comfort, and the
                  position of nearby teeth. That is why the team discusses alternatives
                  to extraction and replacement options whenever they are appropriate.
                </p>
                <p>
                  The goal is to remove the problem tooth comfortably while protecting
                  your long-term bite, bone, and restorative plan.
                </p>
              </div>

              <div class="mt-8 rounded-lg border border-line bg-surface p-7 shadow-sm sm:p-8">
                <p class="text-xs font-bold uppercase tracking-[.28em] text-secondary">
                  Replacement planning matters
                </p>
                <p class="mt-3 text-base leading-7 text-muted">
                  In many cases, planning for replacement before extraction helps reduce
                  future shifting, chewing changes, and bone loss.
                </p>
              </div>
            </div>
          </section>

          <section class="pt-4 lg:pt-2" aria-labelledby="reasons-heading">
            <div class="max-w-3xl" data-reveal>
              <p class="text-xs font-bold uppercase tracking-[.34em] text-secondary">
                Common Reasons
              </p>
              <h2
                id="reasons-heading"
                class="serif mt-4 text-4xl leading-tight sm:text-5xl"
              >
                Teeth are removed when they cannot stay healthy or functional.
              </h2>
              <p class="mt-6 text-base leading-7 text-muted">
                Your surgeon will evaluate the tooth, surrounding bone, gum tissue, and
                overall treatment goals before recommending extraction.
              </p>
            </div>

            <div class="mt-12 grid gap-6 lg:grid-cols-2 lg:gap-7">
              {
                extractionReasons.map(({ number, title, body }, index) => (
                  <article
                    class="rounded-lg border border-line bg-surface p-8 shadow-sm sm:p-9 lg:p-10"
                    data-reveal
                    style={`--reveal-delay: ${(index % 2) * 80}ms`}
                  >
                    <div class="flex h-10 w-10 items-center justify-center rounded-full bg-aqua-pale text-sm font-bold text-secondary">
                      {number}
                    </div>
                    <h3 class="serif mt-6 text-2xl font-bold text-foreground">
                      {title}
                    </h3>
                    <p class="mt-4 text-base leading-7 text-muted">{body}</p>
                  </article>
                ))
              }
            </div>
          </section>

          <section
            class="grid gap-10 rounded-lg bg-aqua-soft p-8 sm:p-10 lg:grid-cols-[minmax(0,1fr)_280px] lg:items-center lg:p-12"
            aria-labelledby="process-heading"
            data-reveal
          >
            <div>
              <p class="text-xs font-bold uppercase tracking-[.34em] text-secondary">
                The Extraction Process
              </p>
              <h2
                id="process-heading"
                class="serif mt-4 text-4xl leading-tight sm:text-5xl"
              >
                You should feel pressure, not sharp pain.
              </h2>
              <p class="mt-6 text-base leading-7 text-muted">
                Local anesthetic is used to numb the tooth, jawbone, and gums around the
                area. During removal, pressure is common because the tooth is gently
                moved to widen the socket. If you feel pain at any point, tell the team
                right away.
              </p>
            </div>
            <div class="grid gap-3 text-sm font-bold text-foreground">
              {visitDetails.map((item) => (
                <p class="rounded-md bg-surface px-4 py-3">{item}</p>
              ))}
            </div>
          </section>

          <section class="grid gap-8 md:grid-cols-2">
            <article class="rounded-lg border border-line bg-surface p-8 shadow-sm sm:p-9 lg:p-10" data-reveal>
              <p class="text-xs font-bold uppercase tracking-[.28em] text-secondary">
                Sectioning a Tooth
              </p>
              <h2 class="serif mt-5 text-3xl leading-tight text-foreground">
                Some teeth are removed in smaller sections.
              </h2>
              <p class="mt-6 text-base leading-7 text-muted">
                Sectioning is common when a tooth is firmly anchored, has curved roots,
                or the socket cannot expand enough for straightforward removal. The
                tooth is divided and removed one section at a time.
              </p>
            </article>

            <article
              class="rounded-lg border border-line bg-surface p-8 shadow-sm sm:p-9 lg:p-10"
              data-reveal
              style="--reveal-delay: 120ms"
            >
              <p class="text-xs font-bold uppercase tracking-[.28em] text-secondary">
                After Extraction
              </p>
              <h2 class="serif mt-5 text-3xl leading-tight text-foreground">
                Home care protects the healing socket.
              </h2>
              <p class="mt-6 text-base leading-7 text-muted">
                Follow your post-operative instructions closely. Rest, protect the blood
                clot, avoid disturbing the socket, and call if pain, bleeding, swelling,
                or other symptoms feel unusual.
              </p>
            </article>
          </section>

          <section class="rounded-lg bg-midnight px-8 py-12 text-surface sm:px-10 lg:px-12 lg:py-14">
            <div class="grid gap-8 lg:grid-cols-[minmax(0,1fr)_auto] lg:items-center">
              <div data-reveal>
                <p class="text-xs font-bold uppercase tracking-[.34em] text-secondary">
                  Comfort and Clarity
                </p>
                <h2 class="serif mt-4 text-4xl leading-tight sm:text-5xl">
                  We will walk you through the plan.
                </h2>
                <p class="mt-5 max-w-[660px] text-base leading-7 text-surface/75">
                  If extraction is needed, we will explain what to expect, how to care
                  for the site, and what replacement options may make sense.
                </p>
              </div>
              <div
                class="flex flex-col gap-3 sm:flex-row lg:flex-col"
                data-reveal
                style="--reveal-delay: 120ms"
              >
                <a
                  href="/#appointment"
                  class="inline-flex h-14 items-center justify-center rounded-md bg-secondary px-7 font-bold text-surface transition-opacity hover:opacity-90"
                >
                  Request Appointment
                </a>
                <a
                  href="tel:7852720444"
                  class="inline-flex h-14 items-center justify-center rounded-md border border-surface/40 px-7 font-bold text-surface transition-colors hover:bg-surface/10"
                >
                  Call (785) 272-0444
                </a>
              </div>
            </div>
          </section>
        </div>

        <div class="hidden lg:block" aria-hidden="true"></div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
