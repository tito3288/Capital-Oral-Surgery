---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import ServiceSidebar from "../../components/ServiceSidebar.astro";

const title =
  "Impacted Wisdom Teeth | Topeka, KS | Capital Oral Surgery";
const description =
  "Learn what impacted wisdom teeth are, the types of impactions, and how consultation and x-rays help determine whether removal is recommended.";

const currentHref = "/services/impacted-wisdom-teeth/";

const impactionTypes = [
  {
    number: "01",
    title: "Soft tissue impaction",
    body: "There is not enough room for gum tissue to retract around the tooth, which makes adequate cleaning difficult and can increase irritation or infection risk.",
  },
  {
    number: "02",
    title: "Partial bony impaction",
    body: "The wisdom tooth has enough space to partially erupt, but it cannot function properly for chewing and often creates cleaning problems.",
  },
  {
    number: "03",
    title: "Complete bony impaction",
    body: "There is no space for the tooth to erupt, so it remains embedded in the jawbone or requires more complex surgical techniques for removal.",
  },
];

const evaluationItems = [
  "Review wisdom tooth position",
  "Check available space for eruption",
  "Evaluate cleaning access",
  "Estimate removal complexity",
  "Discuss whether removal is recommended",
];
---

<Layout title={title} description={description} ogImage="/images/specialized-care.jpg">
  <Header />
  <main>
    <section class="bg-midnight text-surface" aria-labelledby="service-heading">
      <div
        class="mx-auto grid min-h-[calc(100dvh-76px)] max-w-7xl items-center gap-10 px-5 py-14 lg:gap-14 xl:grid-cols-[minmax(0,610px)_minmax(360px,500px)] xl:justify-between xl:px-0"
      >
        <div data-reveal>
          <a
            href="/#procedures"
            class="inline-flex text-sm font-bold text-accent transition-colors hover:text-surface"
          >
            ← Services
          </a>
          <p class="mt-10 text-xs font-bold tracking-[.34em] text-secondary">
            Wisdom teeth
          </p>
          <h1
            id="service-heading"
            class="serif mt-5 max-w-[760px] text-5xl leading-[0.96] text-surface sm:text-6xl xl:text-[72px]"
          >
            Impacted wisdom teeth.
          </h1>
          <p class="mt-7 max-w-[590px] text-lg leading-8 text-surface/75 sm:text-xl">
            Wisdom teeth become impacted when there is not enough space for them to
            erupt into a healthy position for chewing and cleaning. Imaging and exam
            findings help determine whether removal is recommended.
          </p>
          <div class="mt-9 flex flex-col gap-3 sm:flex-row">
            <a
              href="/#appointment"
              class="inline-flex h-14 items-center justify-center rounded-md bg-secondary px-7 font-bold text-surface transition-opacity hover:opacity-90 sm:min-w-[223px]"
            >
              Request Appointment
            </a>
            <a
              href="tel:7852720444"
              class="inline-flex h-14 items-center justify-center rounded-md border border-surface/40 px-7 font-bold text-surface transition-colors hover:bg-surface/10 sm:min-w-[216px]"
            >
              Call (785) 272-0444
            </a>
          </div>
        </div>

        <div
          class="relative mx-auto w-full max-w-[500px] lg:mx-0"
          data-reveal
          style="--reveal-delay: 120ms"
        >
          <div
            class="absolute -bottom-3 left-3 right-[-12px] top-3 rounded-lg border border-secondary"
            aria-hidden="true"
          >
          </div>
          <div class="relative aspect-[4/5] overflow-hidden rounded-lg bg-surface/5">
            <img
              src="/images/specialized-care.jpg"
              alt="3D dental imaging equipment used for oral surgery planning"
              class="h-full w-full object-cover object-center"
              width="5184"
              height="3456"
              loading="eager"
              decoding="async"
              fetchpriority="high"
            />
          </div>
        </div>
      </div>
    </section>

    <section class="bg-background py-20 text-foreground lg:py-24">
      <div
        class="mx-auto grid max-w-[920px] gap-10 px-5 min-[1400px]:max-w-[1400px] min-[1400px]:grid-cols-[220px_minmax(0,840px)_220px] min-[1400px]:items-start min-[1400px]:gap-8 min-[1700px]:max-w-[1640px] min-[1700px]:grid-cols-[280px_minmax(0,920px)_280px] min-[1700px]:gap-12"
      >
        <ServiceSidebar groupLabel="Wisdom teeth" currentHref={currentHref} />

        <div class="grid gap-20 lg:gap-24 min-[1400px]:col-start-2">
          <section class="pb-2 lg:pb-0" aria-labelledby="impacted-heading">
            <div class="max-w-5xl" data-reveal>
              <p class="text-xs font-bold tracking-[.34em] text-secondary">
                What impaction means
              </p>
              <h2
                id="impacted-heading"
                class="serif mt-4 text-4xl leading-tight sm:text-5xl"
              >
                Impacted teeth cannot erupt into a clean, functional position.
              </h2>
              <div class="mt-7 space-y-6 text-base leading-8 text-muted">
                <p>
                  Most people develop 32 permanent adult teeth, but many jaws do not
                  have enough space for the four wisdom teeth. When inadequate space
                  prevents eruption, these third molars are called impacted wisdom teeth.
                </p>
                <p>
                  An impacted wisdom tooth may be trapped by gum tissue, partially
                  covered by bone, fully embedded in the jawbone, or positioned in a
                  way that makes cleaning and removal more complex.
                </p>
                <p>
                  The concern is not only whether the tooth can be seen. It is whether
                  it can erupt into the proper position for chewing, cleaning, and
                  long-term health.
                </p>
              </div>

              <div class="mt-8 rounded-lg border border-line bg-surface p-7 shadow-sm sm:p-8">
                <p class="text-xs font-bold tracking-[.28em] text-secondary">
                  Consultation and x-rays
                </p>
                <p class="mt-3 text-base leading-7 text-muted">
                  A special x-ray of the mouth and jaws helps determine whether wisdom
                  teeth are impacted, if there is room for eruption, and how difficult
                  removal may be.
                </p>
              </div>
            </div>
          </section>

          <section class="pt-4 lg:pt-2" aria-labelledby="types-heading">
            <div class="max-w-3xl" data-reveal>
              <p class="text-xs font-bold tracking-[.34em] text-secondary">
                Types of impactions
              </p>
              <h2
                id="types-heading"
                class="serif mt-4 text-4xl leading-tight sm:text-5xl"
              >
                The amount of gum and bone covering the tooth affects treatment.
              </h2>
              <p class="mt-6 text-base leading-7 text-muted">
                Knowing the type of impaction helps your surgeon estimate complexity,
                explain risks, and decide whether removal is likely to benefit you.
              </p>
            </div>

            <div class="mt-12 grid gap-6 lg:grid-cols-3 lg:gap-7">
              {
                impactionTypes.map(({ number, title, body }, index) => (
                  <article
                    class="rounded-lg border border-line bg-surface p-8 shadow-sm sm:p-9 lg:p-10"
                    data-reveal
                    style={`--reveal-delay: ${index * 80}ms`}
                  >
                    <div class="flex h-10 w-10 items-center justify-center rounded-full bg-aqua-pale text-sm font-bold text-secondary">
                      {number}
                    </div>
                    <h3 class="serif mt-6 text-2xl font-bold text-foreground">
                      {title}
                    </h3>
                    <p class="mt-4 text-base leading-7 text-muted">{body}</p>
                  </article>
                ))
              }
            </div>
          </section>

          <section
            class="grid gap-10 rounded-lg bg-aqua-soft p-8 sm:p-10 lg:grid-cols-[minmax(0,1fr)_280px] lg:items-center lg:p-12"
            aria-labelledby="evaluation-heading"
            data-reveal
          >
            <div>
              <p class="text-xs font-bold tracking-[.34em] text-secondary">
                Evaluation
              </p>
              <h2
                id="evaluation-heading"
                class="serif mt-4 text-4xl leading-tight sm:text-5xl"
              >
                Imaging helps turn uncertainty into a clear recommendation.
              </h2>
              <p class="mt-6 text-base leading-7 text-muted">
                During consultation, your surgeon reviews the position of the wisdom
                teeth and explains whether removal is recommended, how difficult it may
                be, and what anesthesia options make sense.
              </p>
            </div>
            <div class="grid gap-3 text-sm font-bold text-foreground">
              {evaluationItems.map((item) => (
                <p class="rounded-md bg-surface px-4 py-3">{item}</p>
              ))}
            </div>
          </section>

          <section class="grid gap-8 md:grid-cols-2">
            <article class="rounded-lg border border-line bg-surface p-8 shadow-sm sm:p-9 lg:p-10" data-reveal>
              <p class="text-xs font-bold tracking-[.28em] text-secondary">
                Function
              </p>
              <h2 class="serif mt-5 text-3xl leading-tight text-foreground">
                Partially erupted teeth may still not work properly.
              </h2>
              <p class="mt-6 text-base leading-7 text-muted">
                Even when a wisdom tooth is partly visible, it may not contribute to
                chewing in a useful way. Instead, it can create cleaning issues and
                increase risk around the neighboring tooth.
              </p>
            </article>

            <article
              class="rounded-lg border border-line bg-surface p-8 shadow-sm sm:p-9 lg:p-10"
              data-reveal
              style="--reveal-delay: 120ms"
            >
              <p class="text-xs font-bold tracking-[.28em] text-secondary">
                Complexity
              </p>
              <h2 class="serif mt-5 text-3xl leading-tight text-foreground">
                Position and jaw shape can affect removal.
              </h2>
              <p class="mt-6 text-base leading-7 text-muted">
                A wisdom tooth may sit at an unusual angle or be affected by the size
                and shape of the jawbone and nearby facial structures. These details
                guide the surgical plan.
              </p>
            </article>
          </section>

          <section class="rounded-lg bg-midnight px-8 py-12 text-surface sm:px-10 lg:px-12 lg:py-14">
            <div class="grid gap-8 lg:grid-cols-[minmax(0,1fr)_auto] lg:items-center">
              <div data-reveal>
                <p class="text-xs font-bold tracking-[.34em] text-secondary">
                  Schedule a consultation
                </p>
                <h2 class="serif mt-4 text-4xl leading-tight sm:text-5xl">
                  Find out whether removal makes sense.
                </h2>
                <p class="mt-5 max-w-[660px] text-base leading-7 text-surface/75">
                  We will review your x-rays, explain the type of impaction, and help
                  you understand the safest next step.
                </p>
              </div>
              <div
                class="flex flex-col gap-3 sm:flex-row lg:flex-col"
                data-reveal
                style="--reveal-delay: 120ms"
              >
                <a
                  href="/#appointment"
                  class="inline-flex h-14 items-center justify-center rounded-md bg-secondary px-7 font-bold text-surface transition-opacity hover:opacity-90"
                >
                  Request Appointment
                </a>
                <a
                  href="tel:7852720444"
                  class="inline-flex h-14 items-center justify-center rounded-md border border-surface/40 px-7 font-bold text-surface transition-colors hover:bg-surface/10"
                >
                  Call (785) 272-0444
                </a>
              </div>
            </div>
          </section>
        </div>

        <div class="hidden min-[1400px]:block" aria-hidden="true"></div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
