---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import ServiceSidebar from "../../components/ServiceSidebar.astro";

const title =
  "Jaw Bone Loss and Deterioration | Topeka, KS | Capital Oral Surgery";
const description =
  "Learn common causes of jaw bone loss and deterioration, including tooth extractions, periodontal disease, dentures, trauma, misalignment, infection, tumors, and sinus changes.";

const currentHref = "/services/jaw-bone-loss-and-deterioration/";

const primaryCauses = [
  {
    number: "01",
    title: "Tooth extractions",
    body: "When an adult tooth is removed and not replaced, the alveolar bone no longer receives the stimulation it needs from chewing and biting. That bone can begin to resorb over time.",
  },
  {
    number: "02",
    title: "Periodontal disease",
    body: "Ongoing gum infections can damage the tissues that support natural teeth, including the periodontal ligament and the bone that holds teeth in place.",
  },
  {
    number: "03",
    title: "Dentures or bridgework",
    body: "Traditional dentures sit on top of the gums and do not directly stimulate the jawbone. Bridges also leave the bone beneath the missing tooth span without direct stimulation.",
  },
  {
    number: "04",
    title: "Facial trauma",
    body: "A knocked-out tooth, jaw fracture, or tooth broken below the gum line can stop bone stimulation in that area and lead to deterioration if the site is not restored.",
  },
];

const additionalCauses = [
  "Misalignment or lack of opposing tooth contact",
  "Osteomyelitis or other jawbone infection",
  "Benign or malignant tumors",
  "Developmental deformities",
  "Sinus enlargement after upper molar loss",
];
---

<Layout title={title} description={description} ogImage="/images/specialized-care.jpg">
  <Header />
  <main>
    <section class="bg-midnight text-surface" aria-labelledby="service-heading">
      <div
        class="mx-auto grid min-h-[calc(100dvh-76px)] max-w-7xl items-center gap-14 px-5 py-14 lg:grid-cols-[minmax(0,610px)_minmax(380px,500px)] lg:px-0"
      >
        <div data-reveal>
          <a
            href="/#procedures"
            class="inline-flex text-sm font-bold text-accent transition-colors hover:text-surface"
          >
            ← Services
          </a>
          <p class="mt-10 text-xs font-bold uppercase tracking-[.34em] text-secondary">
            Procedures
          </p>
          <h1
            id="service-heading"
            class="serif mt-5 max-w-[760px] text-5xl leading-[0.96] text-surface sm:text-6xl lg:text-[72px]"
          >
            Jaw bone loss and deterioration.
          </h1>
          <p class="mt-7 max-w-[590px] text-lg leading-8 text-surface/75 sm:text-xl">
            Jawbone can shrink when it no longer receives healthy stimulation or when
            disease, trauma, or other conditions damage the supporting bone. Grafting
            can help restore support where bone has been lost.
          </p>
          <div class="mt-9 flex flex-col gap-3 sm:flex-row">
            <a
              href="/#appointment"
              class="inline-flex h-14 items-center justify-center rounded-md bg-secondary px-7 font-bold text-surface transition-opacity hover:opacity-90 sm:min-w-[223px]"
            >
              Request Appointment
            </a>
            <a
              href="tel:7852720444"
              class="inline-flex h-14 items-center justify-center rounded-md border border-surface/40 px-7 font-bold text-surface transition-colors hover:bg-surface/10 sm:min-w-[216px]"
            >
              Call (785) 272-0444
            </a>
          </div>
        </div>

        <div
          class="relative mx-auto w-full max-w-[500px] lg:mx-0"
          data-reveal
          style="--reveal-delay: 120ms"
        >
          <div
            class="absolute -bottom-3 left-3 right-[-12px] top-3 rounded-lg border border-secondary"
            aria-hidden="true"
          >
          </div>
          <div class="relative aspect-[4/5] overflow-hidden rounded-lg bg-surface/5">
            <img
              src="/images/specialized-care.jpg"
              alt="Dental imaging equipment used to evaluate jaw bone loss"
              class="h-full w-full object-cover object-center"
              width="5184"
              height="3456"
              loading="eager"
              decoding="async"
              fetchpriority="high"
            />
          </div>
        </div>
      </div>
    </section>

    <section class="bg-background py-20 text-foreground lg:py-24">
      <div
        class="mx-auto grid max-w-[1600px] gap-10 px-5 lg:grid-cols-[minmax(0,1fr)_minmax(0,920px)_minmax(0,1fr)] lg:items-start lg:gap-12"
      >
        <ServiceSidebar groupLabel="Procedures" currentHref={currentHref} />

        <div class="grid gap-20 lg:col-start-2 lg:gap-24">
          <section class="pb-2 lg:pb-0" aria-labelledby="overview-heading">
            <div class="max-w-5xl" data-reveal>
              <p class="text-xs font-bold uppercase tracking-[.34em] text-secondary">
                Reasons Bone Can Change
              </p>
              <h2
                id="overview-heading"
                class="serif mt-4 text-4xl leading-tight sm:text-5xl"
              >
                Jawbone needs stimulation, healthy gums, and stable teeth to stay strong.
              </h2>
              <div class="mt-7 space-y-6 text-base leading-8 text-muted">
                <p>
                  Natural teeth are embedded in the jawbone and help stimulate the bone
                  through normal chewing and biting. When that stimulation is removed,
                  the body may begin to resorb bone in the area.
                </p>
                <p>
                  The rate and amount of bone loss varies from person to person, but a
                  significant amount can occur during the first eighteen months after a
                  tooth is extracted and may continue gradually over time.
                </p>
                <p>
                  Bone grafting may be recommended when deterioration limits function,
                  denture stability, or the ability to place dental implants in a
                  healthy position.
                </p>
              </div>

              <div class="mt-8 rounded-lg border border-line bg-surface p-7 shadow-sm sm:p-8">
                <p class="text-xs font-bold uppercase tracking-[.28em] text-secondary">
                  Tooth replacement matters
                </p>
                <p class="mt-3 text-base leading-7 text-muted">
                  Replacing missing teeth can help restore function and, when implants
                  are appropriate, provide bone-stimulating support that removable
                  appliances cannot always provide.
                </p>
              </div>
            </div>
          </section>

          <section class="pt-4 lg:pt-2" aria-labelledby="causes-heading">
            <div class="max-w-3xl" data-reveal>
              <p class="text-xs font-bold uppercase tracking-[.34em] text-secondary">
                Common Causes
              </p>
              <h2
                id="causes-heading"
                class="serif mt-4 text-4xl leading-tight sm:text-5xl"
              >
                Bone loss can begin after tooth loss, infection, or changes in bite force.
              </h2>
              <p class="mt-6 text-base leading-7 text-muted">
                Understanding the cause helps the surgeon decide whether bone grafting,
                implant planning, infection treatment, or another procedure is the right
                next step.
              </p>
            </div>

            <div class="mt-12 grid gap-6 lg:grid-cols-2 lg:gap-7">
              {
                primaryCauses.map(({ number, title, body }, index) => (
                  <article
                    class="rounded-lg border border-line bg-surface p-8 shadow-sm sm:p-9 lg:p-10"
                    data-reveal
                    style={`--reveal-delay: ${(index % 2) * 80}ms`}
                  >
                    <div class="flex h-10 w-10 items-center justify-center rounded-full bg-aqua-pale text-sm font-bold text-secondary">
                      {number}
                    </div>
                    <h3 class="serif mt-6 text-2xl font-bold text-foreground">
                      {title}
                    </h3>
                    <p class="mt-4 text-base leading-7 text-muted">{body}</p>
                  </article>
                ))
              }
            </div>
          </section>

          <section
            class="grid gap-10 rounded-lg bg-aqua-soft p-8 sm:p-10 lg:grid-cols-[minmax(0,1fr)_280px] lg:items-center lg:p-12"
            aria-labelledby="additional-heading"
            data-reveal
          >
            <div>
              <p class="text-xs font-bold uppercase tracking-[.34em] text-secondary">
                Additional Causes
              </p>
              <h2
                id="additional-heading"
                class="serif mt-4 text-4xl leading-tight sm:text-5xl"
              >
                Some causes need more specialized evaluation.
              </h2>
              <p class="mt-6 text-base leading-7 text-muted">
                Trauma, infection, sinus changes, tumor treatment, and developmental
                differences can all affect jawbone volume. Imaging helps clarify the
                defect and the best reconstruction plan.
              </p>
            </div>
            <div class="grid gap-3 text-sm font-bold text-foreground">
              {additionalCauses.map((item) => (
                <p class="rounded-md bg-surface px-4 py-3">{item}</p>
              ))}
            </div>
          </section>

          <section class="grid gap-8 md:grid-cols-2">
            <article class="rounded-lg border border-line bg-surface p-8 shadow-sm sm:p-9 lg:p-10" data-reveal>
              <p class="text-xs font-bold uppercase tracking-[.28em] text-secondary">
                Denture Stability
              </p>
              <h2 class="serif mt-5 text-3xl leading-tight text-foreground">
                Bone loss can make removable dentures harder to wear.
              </h2>
              <p class="mt-6 text-base leading-7 text-muted">
                As the jawbone resorbs, dentures may loosen and make eating or speaking
                less comfortable. Implant-supported options may help stimulate and
                preserve more bone in selected cases.
              </p>
            </article>

            <article
              class="rounded-lg border border-line bg-surface p-8 shadow-sm sm:p-9 lg:p-10"
              data-reveal
              style="--reveal-delay: 120ms"
            >
              <p class="text-xs font-bold uppercase tracking-[.28em] text-secondary">
                Sinus Changes
              </p>
              <h2 class="serif mt-5 text-3xl leading-tight text-foreground">
                Upper molar loss can reduce implant-ready bone height.
              </h2>
              <p class="mt-6 text-base leading-7 text-muted">
                After upper molars are removed, the maxillary sinus can expand into the
                area where bone once supported teeth. A sinus lift may be recommended to
                rebuild height for implant placement.
              </p>
            </article>
          </section>

          <section class="rounded-lg bg-midnight px-8 py-12 text-surface sm:px-10 lg:px-12 lg:py-14">
            <div class="grid gap-8 lg:grid-cols-[minmax(0,1fr)_auto] lg:items-center">
              <div data-reveal>
                <p class="text-xs font-bold uppercase tracking-[.34em] text-secondary">
                  Restore Support
                </p>
                <h2 class="serif mt-4 text-4xl leading-tight sm:text-5xl">
                  Talk with us about bone grafting options.
                </h2>
                <p class="mt-5 max-w-[660px] text-base leading-7 text-surface/75">
                  We will evaluate the cause and amount of bone loss, then explain
                  whether grafting, implants, or another approach fits your goals.
                </p>
              </div>
              <div
                class="flex flex-col gap-3 sm:flex-row lg:flex-col"
                data-reveal
                style="--reveal-delay: 120ms"
              >
                <a
                  href="/#appointment"
                  class="inline-flex h-14 items-center justify-center rounded-md bg-secondary px-7 font-bold text-surface transition-opacity hover:opacity-90"
                >
                  Request Appointment
                </a>
                <a
                  href="tel:7852720444"
                  class="inline-flex h-14 items-center justify-center rounded-md border border-surface/40 px-7 font-bold text-surface transition-colors hover:bg-surface/10"
                >
                  Call (785) 272-0444
                </a>
              </div>
            </div>
          </section>
        </div>

        <div class="hidden lg:block" aria-hidden="true"></div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
