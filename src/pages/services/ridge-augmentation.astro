---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import ServiceSidebar from "../../components/ServiceSidebar.astro";

const title = "Ridge Augmentation | Topeka, KS | Capital Oral Surgery";
const description =
  "Learn how ridge augmentation rebuilds the natural contour of the gums and jaw after tooth extraction or bone loss, often before dental implant placement.";

const currentHref = "/services/ridge-augmentation/";

const ridgeSteps = [
  {
    number: "01",
    title: "Tooth removal leaves a socket",
    body: "After a tooth is removed, an empty socket remains in the alveolar ridge, the part of the jawbone that surrounds tooth roots.",
  },
  {
    number: "02",
    title: "Bone may not fully hold its shape",
    body: "Many sockets heal on their own, but if the surrounding bone breaks down or cannot heal predictably, the height and width of the ridge may continue to deteriorate.",
  },
  {
    number: "03",
    title: "Graft material rebuilds support",
    body: "Bone graft material can be placed in the socket to help recreate the natural contour of the jaw and gum tissue.",
  },
  {
    number: "04",
    title: "The ridge is prepared for implants",
    body: "Once the grafted socket has healed, the alveolar ridge can be evaluated and prepared for dental implant placement when appropriate.",
  },
];

const ridgeBenefits = [
  "Rebuilds ridge height and width",
  "Improves implant placement options",
  "Helps restore natural gum contour",
  "May reduce need for later grafting",
];
---

<Layout title={title} description={description} ogImage="/images/specialized-care.jpg">
  <Header />
  <main>
    <section class="bg-midnight text-surface" aria-labelledby="service-heading">
      <div
        class="mx-auto grid min-h-[calc(100dvh-76px)] max-w-7xl items-center gap-10 px-5 py-14 lg:gap-14 xl:grid-cols-[minmax(0,610px)_minmax(360px,500px)] xl:justify-between xl:px-0"
      >
        <div data-reveal>
          <a
            href="/#procedures"
            class="inline-flex text-sm font-bold text-accent transition-colors hover:text-surface"
          >
            ← Services
          </a>
          <p class="mt-10 text-xs font-bold tracking-[.34em] text-secondary">
            Procedures
          </p>
          <h1
            id="service-heading"
            class="serif mt-5 max-w-[760px] text-5xl leading-[0.96] text-surface sm:text-6xl xl:text-[72px]"
          >
            Ridge augmentation.
          </h1>
          <p class="mt-7 max-w-[590px] text-lg leading-8 text-surface/75 sm:text-xl">
            Ridge augmentation helps recreate the natural contour of the gums and jaw
            after tooth extraction or bone loss. It can be an important step when the
            jaw needs more support for a future dental implant.
          </p>
          <div class="mt-9 flex flex-col gap-3 sm:flex-row">
            <a
              href="/#appointment"
              class="inline-flex h-14 items-center justify-center rounded-md bg-secondary px-7 font-bold text-surface transition-opacity hover:opacity-90 sm:min-w-[223px]"
            >
              Request Appointment
            </a>
            <a
              href="tel:7852720444"
              class="inline-flex h-14 items-center justify-center rounded-md border border-surface/40 px-7 font-bold text-surface transition-colors hover:bg-surface/10 sm:min-w-[216px]"
            >
              Call (785) 272-0444
            </a>
          </div>
        </div>

        <div
          class="relative mx-auto w-full max-w-[500px] lg:mx-0"
          data-reveal
          style="--reveal-delay: 120ms"
        >
          <div
            class="absolute -bottom-3 left-3 right-[-12px] top-3 rounded-lg border border-secondary"
            aria-hidden="true"
          >
          </div>
          <div class="relative aspect-[4/5] overflow-hidden rounded-lg bg-surface/5">
            <img
              src="/images/specialized-care.jpg"
              alt="Dental imaging equipment used to plan ridge augmentation"
              class="h-full w-full object-cover object-center"
              width="5184"
              height="3456"
              loading="eager"
              decoding="async"
              fetchpriority="high"
            />
          </div>
        </div>
      </div>
    </section>

    <section class="bg-background py-20 text-foreground lg:py-24">
      <div
        class="mx-auto grid max-w-[920px] gap-10 px-5 min-[1400px]:max-w-[1400px] min-[1400px]:grid-cols-[220px_minmax(0,840px)_220px] min-[1400px]:items-start min-[1400px]:gap-8 min-[1700px]:max-w-[1640px] min-[1700px]:grid-cols-[280px_minmax(0,920px)_280px] min-[1700px]:gap-12"
      >
        <ServiceSidebar groupLabel="Procedures" currentHref={currentHref} />

        <div class="grid gap-20 lg:gap-24 min-[1400px]:col-start-2">
          <section class="pb-2 lg:pb-0" aria-labelledby="overview-heading">
            <div class="max-w-5xl" data-reveal>
              <p class="text-xs font-bold tracking-[.34em] text-secondary">
                Rebuilding natural contour
              </p>
              <h2
                id="overview-heading"
                class="serif mt-4 text-4xl leading-tight sm:text-5xl"
              >
                A ridge augmentation restores the shape of the jaw after bone loss.
              </h2>
              <div class="mt-7 space-y-6 text-base leading-8 text-muted">
                <p>
                  The alveolar ridge is the part of the jawbone that surrounds the roots
                  of the teeth. When a tooth is removed, a socket is left behind in that
                  ridge.
                </p>
                <p>
                  In many cases, the socket fills naturally with bone and tissue. In
                  others, the bone around the socket can break down or lose its previous
                  height and width.
                </p>
                <p>
                  Rebuilding that original contour is not always medically necessary,
                  but it may be important for dental implant placement or for restoring
                  a more natural appearance of the gums and jaw.
                </p>
              </div>

              <div class="mt-8 rounded-lg border border-line bg-surface p-7 shadow-sm sm:p-8">
                <p class="text-xs font-bold tracking-[.28em] text-secondary">
                  Implant planning
                </p>
                <p class="mt-3 text-base leading-7 text-muted">
                  Dental implants need enough healthy bone for support. Ridge
                  augmentation can rebuild the bone needed to accommodate an implant in
                  a stronger, more natural position.
                </p>
              </div>
            </div>
          </section>

          <section class="pt-4 lg:pt-2" aria-labelledby="process-heading">
            <div class="max-w-3xl" data-reveal>
              <p class="text-xs font-bold tracking-[.34em] text-secondary">
                How it works
              </p>
              <h2
                id="process-heading"
                class="serif mt-4 text-4xl leading-tight sm:text-5xl"
              >
                The procedure preserves or rebuilds the socket before implant planning.
              </h2>
              <p class="mt-6 text-base leading-7 text-muted">
                Ridge augmentation is often performed immediately after a tooth is
                removed, which can help avoid the need for a second grafting procedure
                later.
              </p>
            </div>

            <div class="mt-12 grid gap-6 lg:grid-cols-2 lg:gap-7">
              {
                ridgeSteps.map(({ number, title, body }, index) => (
                  <article
                    class="rounded-lg border border-line bg-surface p-8 shadow-sm sm:p-9 lg:p-10"
                    data-reveal
                    style={`--reveal-delay: ${(index % 2) * 80}ms`}
                  >
                    <div class="flex h-10 w-10 items-center justify-center rounded-full bg-aqua-pale text-sm font-bold text-secondary">
                      {number}
                    </div>
                    <h3 class="serif mt-6 text-2xl font-bold text-foreground">
                      {title}
                    </h3>
                    <p class="mt-4 text-base leading-7 text-muted">{body}</p>
                  </article>
                ))
              }
            </div>
          </section>

          <section
            class="grid gap-10 rounded-lg bg-aqua-soft p-8 sm:p-10 lg:grid-cols-[minmax(0,1fr)_280px] lg:items-center lg:p-12"
            aria-labelledby="benefits-heading"
            data-reveal
          >
            <div>
              <p class="text-xs font-bold tracking-[.34em] text-secondary">
                Why it helps
              </p>
              <h2
                id="benefits-heading"
                class="serif mt-4 text-4xl leading-tight sm:text-5xl"
              >
                Better ridge shape can make future restoration more predictable.
              </h2>
              <p class="mt-6 text-base leading-7 text-muted">
                By supporting the socket as it heals, ridge augmentation can preserve
                more of the natural jaw shape and create a better foundation for future
                tooth replacement.
              </p>
            </div>
            <div class="grid gap-3 text-sm font-bold text-foreground">
              {ridgeBenefits.map((item) => (
                <p class="rounded-md bg-surface px-4 py-3">{item}</p>
              ))}
            </div>
          </section>

          <section class="grid gap-8 md:grid-cols-2">
            <article class="rounded-lg border border-line bg-surface p-8 shadow-sm sm:p-9 lg:p-10" data-reveal>
              <p class="text-xs font-bold tracking-[.28em] text-secondary">
                Graft placement
              </p>
              <h2 class="serif mt-5 text-3xl leading-tight text-foreground">
                Bone graft material is placed in the tooth socket.
              </h2>
              <p class="mt-6 text-base leading-7 text-muted">
                After graft material is placed, the gum tissue is positioned over the
                socket and secured with sutures. A space-maintaining product may be used
                to support new bone growth.
              </p>
            </article>

            <article
              class="rounded-lg border border-line bg-surface p-8 shadow-sm sm:p-9 lg:p-10"
              data-reveal
              style="--reveal-delay: 120ms"
            >
              <p class="text-xs font-bold tracking-[.28em] text-secondary">
                Comfort options
              </p>
              <h2 class="serif mt-5 text-3xl leading-tight text-foreground">
                Ridge augmentation is usually completed in the office.
              </h2>
              <p class="mt-6 text-base leading-7 text-muted">
                This procedure is typically performed with local anesthesia. Some
                patients may also choose sedative medication for additional comfort.
              </p>
            </article>
          </section>

          <section class="rounded-lg bg-midnight px-8 py-12 text-surface sm:px-10 lg:px-12 lg:py-14">
            <div class="grid gap-8 lg:grid-cols-[minmax(0,1fr)_auto] lg:items-center">
              <div data-reveal>
                <p class="text-xs font-bold tracking-[.34em] text-secondary">
                  Preserve the ridge
                </p>
                <h2 class="serif mt-4 text-4xl leading-tight sm:text-5xl">
                  Plan the socket before bone is lost.
                </h2>
                <p class="mt-5 max-w-[660px] text-base leading-7 text-surface/75">
                  We can evaluate the extraction site, discuss whether grafting is
                  needed, and help protect your options for future implant placement.
                </p>
              </div>
              <div
                class="flex flex-col gap-3 sm:flex-row lg:flex-col"
                data-reveal
                style="--reveal-delay: 120ms"
              >
                <a
                  href="/#appointment"
                  class="inline-flex h-14 items-center justify-center rounded-md bg-secondary px-7 font-bold text-surface transition-opacity hover:opacity-90"
                >
                  Request Appointment
                </a>
                <a
                  href="tel:7852720444"
                  class="inline-flex h-14 items-center justify-center rounded-md border border-surface/40 px-7 font-bold text-surface transition-colors hover:bg-surface/10"
                >
                  Call (785) 272-0444
                </a>
              </div>
            </div>
          </section>
        </div>

        <div class="hidden min-[1400px]:block" aria-hidden="true"></div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
