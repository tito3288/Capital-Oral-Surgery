---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import ServiceSidebar from "../../components/ServiceSidebar.astro";

const title =
  "Full Mouth Dental Implants | Topeka, KS | Capital Oral Surgery";
const description =
  "Explore full mouth dental implant options for missing upper or lower teeth, including implant-retained dentures, bar attachment dentures, screw-retained dentures, and individual implants.";

const currentHref = "/services/full-mouth-dental-implants/";

const lowerJawOptions = [
  {
    number: "01",
    title: "Ball attachment denture",
    body: "Two implants are placed in the lower jaw, and a denture is made to snap onto them. This can improve stability while chewing, though the denture can still move and may need periodic adjustments.",
  },
  {
    number: "02",
    title: "Bar attachment denture",
    body: "Four to six implants are placed, then connected with a custom support bar after healing. The denture snaps firmly onto the bar, allowing very little movement while still being removable for cleaning.",
  },
  {
    number: "03",
    title: "Screw-retained denture",
    body: "Five or more implants support a permanent denture that is secured to posts or a bar. It does not touch the gum tissue and is removed only during maintenance visits.",
  },
  {
    number: "04",
    title: "Individual implants",
    body: "All missing teeth can be replaced individually so they most closely resemble natural teeth. This usually requires eight or more implants and may depend on jawbone size and shape.",
  },
];

const upperJawOptions = [
  "Implant-retained upper denture",
  "Individual upper implants",
  "Palate-free denture design when possible",
  "More implants may be needed for upper-jaw support",
];
---

<Layout title={title} description={description} ogImage="/images/specialized-care.jpg">
  <Header />
  <main>
    <section class="bg-midnight text-surface" aria-labelledby="service-heading">
      <div
        class="mx-auto grid min-h-[calc(100dvh-76px)] max-w-7xl items-center gap-10 px-5 py-14 lg:gap-14 xl:grid-cols-[minmax(0,610px)_minmax(360px,500px)] xl:justify-between xl:px-0"
      >
        <div data-reveal>
          <a
            href="/#procedures"
            class="inline-flex text-sm font-bold text-accent transition-colors hover:text-surface"
          >
            ← Services
          </a>
          <p class="mt-10 text-xs font-bold tracking-[.34em] text-secondary">
            Dental implants
          </p>
          <h1
            id="service-heading"
            class="serif mt-5 max-w-[760px] text-5xl leading-[0.96] text-surface sm:text-6xl xl:text-[72px]"
          >
            Full mouth dental implants.
          </h1>
          <p class="mt-7 max-w-[590px] text-lg leading-8 text-surface/75 sm:text-xl">
            When most or all teeth are missing, dental implants can support a more
            stable, comfortable replacement than traditional dentures alone. Our team
            helps you compare removable and fixed full-arch options with clarity.
          </p>
          <div class="mt-9 flex flex-col gap-3 sm:flex-row">
            <a
              href="/#appointment"
              class="inline-flex h-14 items-center justify-center rounded-md bg-secondary px-7 font-bold text-surface transition-opacity hover:opacity-90 sm:min-w-[223px]"
            >
              Request Appointment
            </a>
            <a
              href="tel:7852720444"
              class="inline-flex h-14 items-center justify-center rounded-md border border-surface/40 px-7 font-bold text-surface transition-colors hover:bg-surface/10 sm:min-w-[216px]"
            >
              Call (785) 272-0444
            </a>
          </div>
        </div>

        <div
          class="relative mx-auto w-full max-w-[500px] lg:mx-0"
          data-reveal
          style="--reveal-delay: 120ms"
        >
          <div
            class="absolute -bottom-3 left-3 right-[-12px] top-3 rounded-lg border border-secondary"
            aria-hidden="true"
          >
          </div>
          <div class="relative aspect-[4/5] overflow-hidden rounded-lg bg-surface/5">
            <img
              src="/images/specialized-care.jpg"
              alt="3D dental imaging equipment used for dental implant planning"
              class="h-full w-full object-cover object-center"
              width="5184"
              height="3456"
              loading="eager"
              decoding="async"
              fetchpriority="high"
            />
          </div>
        </div>
      </div>
    </section>

    <section class="bg-background py-20 text-foreground lg:py-24">
      <div
        class="mx-auto grid max-w-[920px] gap-10 px-5 min-[1400px]:max-w-[1400px] min-[1400px]:grid-cols-[220px_minmax(0,840px)_220px] min-[1400px]:items-start min-[1400px]:gap-8 min-[1700px]:max-w-[1640px] min-[1700px]:grid-cols-[280px_minmax(0,920px)_280px] min-[1700px]:gap-12"
      >
        <ServiceSidebar groupLabel="Dental implants" currentHref={currentHref} />

        <div class="grid gap-20 lg:gap-24 min-[1400px]:col-start-2">
          <section class="pb-2 lg:pb-0" aria-labelledby="full-mouth-heading">
            <div class="max-w-5xl" data-reveal>
              <p class="text-xs font-bold tracking-[.34em] text-secondary">
                Full-arch replacement
              </p>
              <h2
                id="full-mouth-heading"
                class="serif mt-4 text-4xl leading-tight sm:text-5xl"
              >
                If dentures are not enough, implants can create a stronger foundation.
              </h2>
              <div class="mt-7 space-y-6 text-base leading-8 text-muted">
                <p>
                  Many patients can wear an upper denture comfortably, but lower
                  dentures can be more difficult to keep stable while eating and
                  speaking. Implant-supported options are available when all lower
                  teeth are missing.
                </p>
                <p>
                  Full mouth implant treatment is not one single solution. The right
                  plan depends on your jaw size and shape, the amount of available
                  bone, whether you prefer a removable or fixed restoration, and how
                  much maintenance you are comfortable managing.
                </p>
                <p>
                  Your consultation is the place to compare these choices carefully,
                  review imaging, and understand which option can give you the best
                  blend of stability, cleanability, comfort, and long-term support.
                </p>
              </div>

              <div class="mt-8 rounded-lg border border-line bg-surface p-7 shadow-sm sm:p-8">
                <p class="text-xs font-bold tracking-[.28em] text-secondary">
                  Removable vs fixed
                </p>
                <p class="mt-3 text-base leading-7 text-muted">
                  Some implant-supported dentures are removable for cleaning. Others are
                  secured to implants and removed only during maintenance visits. Both
                  can be excellent options when matched to the right patient.
                </p>
              </div>
            </div>
          </section>

          <section class="pt-4 lg:pt-2" aria-labelledby="lower-options-heading">
            <div class="max-w-3xl" data-reveal>
              <p class="text-xs font-bold tracking-[.34em] text-secondary">
                Lower jaw options
              </p>
              <h2
                id="lower-options-heading"
                class="serif mt-4 text-4xl leading-tight sm:text-5xl"
              >
                Four ways implants can support missing lower teeth.
              </h2>
              <p class="mt-6 text-base leading-7 text-muted">
                The lower jaw often benefits greatly from implant support. These options
                range from improved denture stability to permanent teeth that stay in
                place except during maintenance care.
              </p>
            </div>

            <div class="mt-12 grid gap-6 lg:grid-cols-2 lg:gap-7">
              {
                lowerJawOptions.map(({ number, title, body }, index) => (
                  <article
                    class="rounded-lg border border-line bg-surface p-8 shadow-sm sm:p-9 lg:p-10"
                    data-reveal
                    style={`--reveal-delay: ${(index % 2) * 80}ms`}
                  >
                    <div class="flex h-10 w-10 items-center justify-center rounded-full bg-aqua-pale text-sm font-bold text-secondary">
                      {number}
                    </div>
                    <h3 class="serif mt-6 text-2xl font-bold text-foreground">
                      {title}
                    </h3>
                    <p class="mt-4 text-base leading-7 text-muted">{body}</p>
                  </article>
                ))
              }
            </div>
          </section>

          <section
            class="grid gap-10 rounded-lg bg-aqua-soft p-8 sm:p-10 lg:grid-cols-[minmax(0,1fr)_280px] lg:items-center lg:p-12"
            aria-labelledby="upper-options-heading"
            data-reveal
          >
            <div>
              <p class="text-xs font-bold tracking-[.34em] text-secondary">
                Upper jaw options
              </p>
              <h2
                id="upper-options-heading"
                class="serif mt-4 text-4xl leading-tight sm:text-5xl"
              >
                Upper implants may need a different support plan.
              </h2>
              <p class="mt-6 text-base leading-7 text-muted">
                A similar range of treatment choices is available for missing upper
                teeth. Because upper jaw bone is often softer than lower jaw bone,
                more implants may be needed to support a new restoration.
              </p>
            </div>
            <div class="grid gap-3 text-sm font-bold text-foreground">
              {upperJawOptions.map((item) => (
                <p class="rounded-md bg-surface px-4 py-3">{item}</p>
              ))}
            </div>
          </section>

          <section class="grid gap-8 md:grid-cols-2">
            <article class="rounded-lg border border-line bg-surface p-8 shadow-sm sm:p-9 lg:p-10" data-reveal>
              <p class="text-xs font-bold tracking-[.28em] text-secondary">
                Implant-retained upper denture
              </p>
              <h2 class="serif mt-5 text-3xl leading-tight text-foreground">
                More natural taste and comfort may be possible.
              </h2>
              <p class="mt-6 text-base leading-7 text-muted">
                Depending on the number of implants placed, it may be possible to avoid
                covering the roof of your mouth with a complete denture. This can help
                with taste, temperature awareness, and a more natural feel.
              </p>
            </article>

            <article
              class="rounded-lg border border-line bg-surface p-8 shadow-sm sm:p-9 lg:p-10"
              data-reveal
              style="--reveal-delay: 120ms"
            >
              <p class="text-xs font-bold tracking-[.28em] text-secondary">
                Individual upper implants
              </p>
              <h2 class="serif mt-5 text-3xl leading-tight text-foreground">
                Fixed teeth can closely resemble natural teeth.
              </h2>
              <p class="mt-6 text-base leading-7 text-muted">
                Patients who want a non-removable restoration similar to natural teeth
                may need eight to ten individual implants, followed by abutments and
                new replacement crowns after healing.
              </p>
            </article>
          </section>

          <section class="rounded-lg bg-midnight px-8 py-12 text-surface sm:px-10 lg:px-12 lg:py-14">
            <div class="grid gap-8 lg:grid-cols-[minmax(0,1fr)_auto] lg:items-center">
              <div data-reveal>
                <p class="text-xs font-bold tracking-[.34em] text-secondary">
                  Reclaim confidence
                </p>
                <h2 class="serif mt-4 text-4xl leading-tight sm:text-5xl">
                  Find the right full-mouth plan.
                </h2>
                <p class="mt-5 max-w-[660px] text-base leading-7 text-surface/75">
                  We will evaluate your jaw, review your goals, and help you understand
                  which full mouth implant solution fits your anatomy, lifestyle, and
                  long-term care needs.
                </p>
              </div>
              <div
                class="flex flex-col gap-3 sm:flex-row lg:flex-col"
                data-reveal
                style="--reveal-delay: 120ms"
              >
                <a
                  href="/#appointment"
                  class="inline-flex h-14 items-center justify-center rounded-md bg-secondary px-7 font-bold text-surface transition-opacity hover:opacity-90"
                >
                  Request Appointment
                </a>
                <a
                  href="tel:7852720444"
                  class="inline-flex h-14 items-center justify-center rounded-md border border-surface/40 px-7 font-bold text-surface transition-colors hover:bg-surface/10"
                >
                  Call (785) 272-0444
                </a>
              </div>
            </div>
          </section>
        </div>

        <div class="hidden min-[1400px]:block" aria-hidden="true"></div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
