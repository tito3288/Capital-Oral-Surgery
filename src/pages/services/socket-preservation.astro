---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import ServiceSidebar from "../../components/ServiceSidebar.astro";

const title = "Socket Preservation | Topeka, KS | Capital Oral Surgery";
const description =
  "Learn how socket preservation uses bone grafting after tooth extraction to help maintain jawbone shape and support future dental implant options.";

const currentHref = "/services/socket-preservation/";

const preservationSteps = [
  {
    number: "01",
    title: "Remove the tooth carefully",
    body: "The tooth is removed while protecting as much surrounding socket bone and gum tissue as possible.",
  },
  {
    number: "02",
    title: "Place graft material",
    body: "Bone graft material is placed into the empty socket to support the area where the tooth root used to be.",
  },
  {
    number: "03",
    title: "Protect the graft",
    body: "The grafted site may be covered with a membrane or secured with sutures to help stabilize the area as healing begins.",
  },
  {
    number: "04",
    title: "Plan the restoration",
    body: "After healing, the preserved socket can be evaluated for implant placement or another tooth replacement option.",
  },
];

const preservationBenefits = [
  "Helps maintain socket width and height",
  "Reduces ridge collapse after extraction",
  "Supports future dental implant planning",
  "Can reduce the need for later grafting",
];
---

<Layout title={title} description={description} ogImage="/images/specialized-care.jpg">
  <Header />
  <main>
    <section class="bg-midnight text-surface" aria-labelledby="service-heading">
      <div
        class="mx-auto grid min-h-[calc(100dvh-76px)] max-w-7xl items-center gap-14 px-5 py-14 lg:grid-cols-[minmax(0,610px)_minmax(380px,500px)] lg:px-0"
      >
        <div data-reveal>
          <a
            href="/#procedures"
            class="inline-flex text-sm font-bold text-accent transition-colors hover:text-surface"
          >
            ← Services
          </a>
          <p class="mt-10 text-xs font-bold uppercase tracking-[.34em] text-secondary">
            Procedures
          </p>
          <h1
            id="service-heading"
            class="serif mt-5 max-w-[760px] text-5xl leading-[0.96] text-surface sm:text-6xl lg:text-[72px]"
          >
            Socket preservation.
          </h1>
          <p class="mt-7 max-w-[590px] text-lg leading-8 text-surface/75 sm:text-xl">
            Socket preservation is a bone grafting procedure performed after tooth
            extraction to help maintain the shape of the jaw and protect future tooth
            replacement options.
          </p>
          <div class="mt-9 flex flex-col gap-3 sm:flex-row">
            <a
              href="/#appointment"
              class="inline-flex h-14 items-center justify-center rounded-md bg-secondary px-7 font-bold text-surface transition-opacity hover:opacity-90 sm:min-w-[223px]"
            >
              Request Appointment
            </a>
            <a
              href="tel:7852720444"
              class="inline-flex h-14 items-center justify-center rounded-md border border-surface/40 px-7 font-bold text-surface transition-colors hover:bg-surface/10 sm:min-w-[216px]"
            >
              Call (785) 272-0444
            </a>
          </div>
        </div>

        <div
          class="relative mx-auto w-full max-w-[500px] lg:mx-0"
          data-reveal
          style="--reveal-delay: 120ms"
        >
          <div
            class="absolute -bottom-3 left-3 right-[-12px] top-3 rounded-lg border border-secondary"
            aria-hidden="true"
          >
          </div>
          <div class="relative aspect-[4/5] overflow-hidden rounded-lg bg-surface/5">
            <img
              src="/images/specialized-care.jpg"
              alt="Dental imaging equipment used to plan socket preservation"
              class="h-full w-full object-cover object-center"
              width="5184"
              height="3456"
              loading="eager"
              decoding="async"
              fetchpriority="high"
            />
          </div>
        </div>
      </div>
    </section>

    <section class="bg-background py-20 text-foreground lg:py-24">
      <div
        class="mx-auto grid max-w-[1600px] gap-10 px-5 lg:grid-cols-[minmax(0,1fr)_minmax(0,920px)_minmax(0,1fr)] lg:items-start lg:gap-12"
      >
        <ServiceSidebar groupLabel="Procedures" currentHref={currentHref} />

        <div class="grid gap-20 lg:col-start-2 lg:gap-24">
          <section class="pb-2 lg:pb-0" aria-labelledby="overview-heading">
            <div class="max-w-5xl" data-reveal>
              <p class="text-xs font-bold uppercase tracking-[.34em] text-secondary">
                Preserving Bone After Extraction
              </p>
              <h2
                id="overview-heading"
                class="serif mt-4 text-4xl leading-tight sm:text-5xl"
              >
                The best time to protect the socket is often when the tooth is removed.
              </h2>
              <div class="mt-7 space-y-6 text-base leading-8 text-muted">
                <p>
                  When a tooth is extracted, the empty socket can begin to shrink as the
                  body remodels the bone. This may reduce the height and width available
                  for a future dental implant.
                </p>
                <p>
                  Socket preservation places grafting material into the extraction site
                  to help the area heal with more stable bone volume and contour.
                </p>
                <p>
                  Preserving the socket does not guarantee that no future grafting will
                  be needed, but it can make implant planning more predictable and may
                  simplify treatment later.
                </p>
              </div>

              <div class="mt-8 rounded-lg border border-line bg-surface p-7 shadow-sm sm:p-8">
                <p class="text-xs font-bold uppercase tracking-[.28em] text-secondary">
                  Why timing matters
                </p>
                <p class="mt-3 text-base leading-7 text-muted">
                  Once the socket has collapsed or narrowed, rebuilding the ridge can
                  become more involved. Grafting at extraction can help preserve the
                  foundation before that change occurs.
                </p>
              </div>
            </div>
          </section>

          <section class="pt-4 lg:pt-2" aria-labelledby="process-heading">
            <div class="max-w-3xl" data-reveal>
              <p class="text-xs font-bold uppercase tracking-[.34em] text-secondary">
                How It Works
              </p>
              <h2
                id="process-heading"
                class="serif mt-4 text-4xl leading-tight sm:text-5xl"
              >
                The graft supports the socket while your body heals.
              </h2>
              <p class="mt-6 text-base leading-7 text-muted">
                The details depend on the tooth location, the condition of the socket
                walls, and whether implant placement is planned soon or after additional
                healing.
              </p>
            </div>

            <div class="mt-12 grid gap-6 lg:grid-cols-2 lg:gap-7">
              {
                preservationSteps.map(({ number, title, body }, index) => (
                  <article
                    class="rounded-lg border border-line bg-surface p-8 shadow-sm sm:p-9 lg:p-10"
                    data-reveal
                    style={`--reveal-delay: ${(index % 2) * 80}ms`}
                  >
                    <div class="flex h-10 w-10 items-center justify-center rounded-full bg-aqua-pale text-sm font-bold text-secondary">
                      {number}
                    </div>
                    <h3 class="serif mt-6 text-2xl font-bold text-foreground">
                      {title}
                    </h3>
                    <p class="mt-4 text-base leading-7 text-muted">{body}</p>
                  </article>
                ))
              }
            </div>
          </section>

          <section
            class="grid gap-10 rounded-lg bg-aqua-soft p-8 sm:p-10 lg:grid-cols-[minmax(0,1fr)_280px] lg:items-center lg:p-12"
            aria-labelledby="benefits-heading"
            data-reveal
          >
            <div>
              <p class="text-xs font-bold uppercase tracking-[.34em] text-secondary">
                Why It Helps
              </p>
              <h2
                id="benefits-heading"
                class="serif mt-4 text-4xl leading-tight sm:text-5xl"
              >
                Preserving the socket can protect future replacement options.
              </h2>
              <p class="mt-6 text-base leading-7 text-muted">
                Maintaining ridge shape after extraction helps the surgeon plan a more
                stable, natural-feeling tooth replacement when the time is right.
              </p>
            </div>
            <div class="grid gap-3 text-sm font-bold text-foreground">
              {preservationBenefits.map((item) => (
                <p class="rounded-md bg-surface px-4 py-3">{item}</p>
              ))}
            </div>
          </section>

          <section class="grid gap-8 md:grid-cols-2">
            <article class="rounded-lg border border-line bg-surface p-8 shadow-sm sm:p-9 lg:p-10" data-reveal>
              <p class="text-xs font-bold uppercase tracking-[.28em] text-secondary">
                Implant Planning
              </p>
              <h2 class="serif mt-5 text-3xl leading-tight text-foreground">
                A preserved socket may be easier to restore.
              </h2>
              <p class="mt-6 text-base leading-7 text-muted">
                Dental implants need enough healthy bone for support. Socket
                preservation helps maintain the bone volume needed to evaluate implant
                placement after healing.
              </p>
            </article>

            <article
              class="rounded-lg border border-line bg-surface p-8 shadow-sm sm:p-9 lg:p-10"
              data-reveal
              style="--reveal-delay: 120ms"
            >
              <p class="text-xs font-bold uppercase tracking-[.28em] text-secondary">
                Healing Expectations
              </p>
              <h2 class="serif mt-5 text-3xl leading-tight text-foreground">
                The graft becomes part of a longer treatment plan.
              </h2>
              <p class="mt-6 text-base leading-7 text-muted">
                After socket preservation, the area needs time to heal before the next
                restorative step. Your surgeon will explain the expected timeline based
                on your anatomy and goals.
              </p>
            </article>
          </section>

          <section class="rounded-lg bg-midnight px-8 py-12 text-surface sm:px-10 lg:px-12 lg:py-14">
            <div class="grid gap-8 lg:grid-cols-[minmax(0,1fr)_auto] lg:items-center">
              <div data-reveal>
                <p class="text-xs font-bold uppercase tracking-[.34em] text-secondary">
                  Preserve the Foundation
                </p>
                <h2 class="serif mt-4 text-4xl leading-tight sm:text-5xl">
                  Ask about grafting before extraction.
                </h2>
                <p class="mt-5 max-w-[660px] text-base leading-7 text-surface/75">
                  We can evaluate the tooth, review your future replacement options, and
                  explain whether socket preservation should be part of your plan.
                </p>
              </div>
              <div
                class="flex flex-col gap-3 sm:flex-row lg:flex-col"
                data-reveal
                style="--reveal-delay: 120ms"
              >
                <a
                  href="/#appointment"
                  class="inline-flex h-14 items-center justify-center rounded-md bg-secondary px-7 font-bold text-surface transition-opacity hover:opacity-90"
                >
                  Request Appointment
                </a>
                <a
                  href="tel:7852720444"
                  class="inline-flex h-14 items-center justify-center rounded-md border border-surface/40 px-7 font-bold text-surface transition-colors hover:bg-surface/10"
                >
                  Call (785) 272-0444
                </a>
              </div>
            </div>
          </section>
        </div>

        <div class="hidden lg:block" aria-hidden="true"></div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
