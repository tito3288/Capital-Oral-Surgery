---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import ServiceSidebar from "../../components/ServiceSidebar.astro";

const title =
  "Cost of Dental Implants | Topeka, KS | Capital Oral Surgery";
const description =
  "Understand what affects dental implant cost, including longevity, jawbone health, quality of life, surgical steps, restorations, insurance, and financing.";

const currentHref = "/services/cost-of-dental-implants/";

const valueFactors = [
  {
    number: "01",
    title: "Longevity",
    body: "Dentures and bridges may cost less at first, but they often need repair or replacement every five to ten years. Properly placed and cared-for implants can last much longer.",
  },
  {
    number: "02",
    title: "Jaw Bone Health",
    body: "When a tooth is missing, jawbone can deteriorate beneath the surface. Implants integrate with bone, helping preserve strength, facial structure, and future oral health.",
  },
  {
    number: "03",
    title: "Quality of Life",
    body: "Dental implants are the closest replacement to natural teeth. They can make it easier to eat healthy foods and avoid the daily hassles that can come with removable dentures.",
  },
  {
    number: "04",
    title: "Long-Term Investment",
    body: "Implants are an investment in health, function, appearance, and confidence. A stable set of teeth can support nutrition and preserve facial contours over time.",
  },
];

const quoteItems = [
  "Exams and office visits",
  "Tooth or root extraction",
  "Bone grafting when needed",
  "Titanium implant placement",
  "Crown or restoration placement",
  "X-rays and post-operative care",
];
---

<Layout title={title} description={description} ogImage="/images/specialized-care.jpg">
  <Header />
  <main>
    <section class="bg-midnight text-surface" aria-labelledby="service-heading">
      <div
        class="mx-auto grid min-h-[calc(100dvh-76px)] max-w-7xl items-center gap-14 px-5 py-14 lg:grid-cols-[minmax(0,610px)_minmax(380px,500px)] lg:px-0"
      >
        <div data-reveal>
          <a
            href="/#procedures"
            class="inline-flex text-sm font-bold text-accent transition-colors hover:text-surface"
          >
            ← Services
          </a>
          <p class="mt-10 text-xs font-bold uppercase tracking-[.34em] text-secondary">
            Dental Implants
          </p>
          <h1
            id="service-heading"
            class="serif mt-5 max-w-[760px] text-5xl leading-[0.96] text-surface sm:text-6xl lg:text-[72px]"
          >
            Cost of dental implants.
          </h1>
          <p class="mt-7 max-w-[590px] text-lg leading-8 text-surface/75 sm:text-xl">
            Dental implant cost depends on your anatomy, the number of teeth being
            replaced, whether grafting is needed, and the restoration plan. The best
            estimate comes after a consultation built around your specific case.
          </p>
          <div class="mt-9 flex flex-col gap-3 sm:flex-row">
            <a
              href="/#appointment"
              class="inline-flex h-14 items-center justify-center rounded-md bg-secondary px-7 font-bold text-surface transition-opacity hover:opacity-90 sm:min-w-[223px]"
            >
              Request Appointment
            </a>
            <a
              href="tel:7852720444"
              class="inline-flex h-14 items-center justify-center rounded-md border border-surface/40 px-7 font-bold text-surface transition-colors hover:bg-surface/10 sm:min-w-[216px]"
            >
              Call (785) 272-0444
            </a>
          </div>
        </div>

        <div
          class="relative mx-auto w-full max-w-[500px] lg:mx-0"
          data-reveal
          style="--reveal-delay: 120ms"
        >
          <div
            class="absolute -bottom-3 left-3 right-[-12px] top-3 rounded-lg border border-secondary"
            aria-hidden="true"
          >
          </div>
          <div class="relative aspect-[4/5] overflow-hidden rounded-lg bg-surface/5">
            <img
              src="/images/specialized-care.jpg"
              alt="3D dental imaging equipment used for dental implant planning"
              class="h-full w-full object-cover object-center"
              width="5184"
              height="3456"
              loading="eager"
              decoding="async"
              fetchpriority="high"
            />
          </div>
        </div>
      </div>
    </section>

    <section class="bg-background py-20 text-foreground lg:py-24">
      <div
        class="mx-auto grid max-w-[1600px] gap-10 px-5 lg:grid-cols-[minmax(0,1fr)_minmax(0,920px)_minmax(0,1fr)] lg:items-start lg:gap-12"
      >
        <ServiceSidebar groupLabel="Dental Implants" currentHref={currentHref} />

        <div class="grid gap-20 lg:col-start-2 lg:gap-24">
          <section class="pb-2 lg:pb-0" aria-labelledby="cost-heading">
            <div class="max-w-5xl" data-reveal>
              <p class="text-xs font-bold uppercase tracking-[.34em] text-secondary">
                Considering Cost
              </p>
              <h2
                id="cost-heading"
                class="serif mt-4 text-4xl leading-tight sm:text-5xl"
              >
                The lowest initial price is not always the lowest long-term cost.
              </h2>
              <div class="mt-7 space-y-6 text-base leading-8 text-muted">
                <p>
                  Dental implants have been available for decades, but they can still
                  feel unfamiliar when patients compare quotes. A fair comparison should
                  look beyond the first appointment or the first invoice.
                </p>
                <p>
                  Dentures and bridges may be less expensive initially, but they can
                  require repair or replacement over time. Implants, when properly
                  placed and cared for, are designed as a long-term tooth replacement.
                </p>
                <p>
                  Cost also reflects the health value of preserving jawbone, restoring
                  chewing function, and reducing the daily inconvenience that can come
                  with removable appliances.
                </p>
              </div>

              <div class="mt-8 rounded-lg border border-line bg-surface p-7 shadow-sm sm:p-8">
                <p class="text-xs font-bold uppercase tracking-[.28em] text-secondary">
                  Accurate estimates are personal
                </p>
                <p class="mt-3 text-base leading-7 text-muted">
                  The only way to receive a specific price for your case is through a
                  consultation, imaging, and a treatment plan based on your anatomy and
                  goals.
                </p>
              </div>
            </div>
          </section>

          <section class="pt-4 lg:pt-2" aria-labelledby="value-heading">
            <div class="max-w-3xl" data-reveal>
              <p class="text-xs font-bold uppercase tracking-[.34em] text-secondary">
                Value Factors
              </p>
              <h2
                id="value-heading"
                class="serif mt-4 text-4xl leading-tight sm:text-5xl"
              >
                Implant cost is tied to health, function, and durability.
              </h2>
              <p class="mt-6 text-base leading-7 text-muted">
                The right treatment decision balances immediate cost with longevity,
                jawbone preservation, appearance, quality of life, and future dental
                maintenance.
              </p>
            </div>

            <div class="mt-12 grid gap-6 lg:grid-cols-2 lg:gap-7">
              {
                valueFactors.map(({ number, title, body }, index) => (
                  <article
                    class="rounded-lg border border-line bg-surface p-8 shadow-sm sm:p-9 lg:p-10"
                    data-reveal
                    style={`--reveal-delay: ${(index % 2) * 80}ms`}
                  >
                    <div class="flex h-10 w-10 items-center justify-center rounded-full bg-aqua-pale text-sm font-bold text-secondary">
                      {number}
                    </div>
                    <h3 class="serif mt-6 text-2xl font-bold text-foreground">
                      {title}
                    </h3>
                    <p class="mt-4 text-base leading-7 text-muted">{body}</p>
                  </article>
                ))
              }
            </div>
          </section>

          <section
            class="grid gap-10 rounded-lg bg-aqua-soft p-8 sm:p-10 lg:grid-cols-[minmax(0,1fr)_280px] lg:items-center lg:p-12"
            aria-labelledby="quotes-heading"
            data-reveal
          >
            <div>
              <p class="text-xs font-bold uppercase tracking-[.34em] text-secondary">
                Comparing Quotes
              </p>
              <h2
                id="quotes-heading"
                class="serif mt-4 text-4xl leading-tight sm:text-5xl"
              >
                Make sure each quote includes the same treatment steps.
              </h2>
              <p class="mt-6 text-base leading-7 text-muted">
                Dental implant treatment can involve multiple steps and sometimes
                multiple professionals. When comparing quotes, confirm what is included
                so you are comparing the same scope of care.
              </p>
            </div>
            <div class="grid gap-3 text-sm font-bold text-foreground">
              {quoteItems.map((item) => (
                <p class="rounded-md bg-surface px-4 py-3">{item}</p>
              ))}
            </div>
          </section>

          <section class="grid gap-8 md:grid-cols-2">
            <article class="rounded-lg border border-line bg-surface p-8 shadow-sm sm:p-9 lg:p-10" data-reveal>
              <p class="text-xs font-bold uppercase tracking-[.28em] text-secondary">
                Insurance
              </p>
              <h2 class="serif mt-5 text-3xl leading-tight text-foreground">
                Coverage can vary widely.
              </h2>
              <p class="mt-6 text-base leading-7 text-muted">
                Start by checking with your dental insurance carrier to learn what
                portion, if any, of implant treatment is covered. Many plans treat
                implant care differently from other dental services.
              </p>
            </article>

            <article
              class="rounded-lg border border-line bg-surface p-8 shadow-sm sm:p-9 lg:p-10"
              data-reveal
              style="--reveal-delay: 120ms"
            >
              <p class="text-xs font-bold uppercase tracking-[.28em] text-secondary">
                Financing
              </p>
              <h2 class="serif mt-5 text-3xl leading-tight text-foreground">
                Payment options may help make care manageable.
              </h2>
              <p class="mt-6 text-base leading-7 text-muted">
                Health care credit companies may offer no-interest or low-interest
                loans for medical and dental procedures, including dental implants.
                Our team can help you understand available options.
              </p>
            </article>
          </section>

          <section class="rounded-lg bg-midnight px-8 py-12 text-surface sm:px-10 lg:px-12 lg:py-14">
            <div class="grid gap-8 lg:grid-cols-[minmax(0,1fr)_auto] lg:items-center">
              <div data-reveal>
                <p class="text-xs font-bold uppercase tracking-[.34em] text-secondary">
                  Schedule Your Consultation
                </p>
                <h2 class="serif mt-4 text-4xl leading-tight sm:text-5xl">
                  Get a cost estimate for your case.
                </h2>
                <p class="mt-5 max-w-[660px] text-base leading-7 text-surface/75">
                  We will review your needs, imaging, and treatment options so you can
                  understand the investment involved before moving forward.
                </p>
              </div>
              <div
                class="flex flex-col gap-3 sm:flex-row lg:flex-col"
                data-reveal
                style="--reveal-delay: 120ms"
              >
                <a
                  href="/#appointment"
                  class="inline-flex h-14 items-center justify-center rounded-md bg-secondary px-7 font-bold text-surface transition-opacity hover:opacity-90"
                >
                  Request Appointment
                </a>
                <a
                  href="tel:7852720444"
                  class="inline-flex h-14 items-center justify-center rounded-md border border-surface/40 px-7 font-bold text-surface transition-colors hover:bg-surface/10"
                >
                  Call (785) 272-0444
                </a>
              </div>
            </div>
          </section>
        </div>

        <div class="hidden lg:block" aria-hidden="true"></div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
