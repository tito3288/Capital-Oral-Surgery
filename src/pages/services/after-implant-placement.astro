---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import ServiceSidebar from "../../components/ServiceSidebar.astro";

const title =
  "After Implant Placement | Dental Implant FAQ in Topeka, KS | Capital Oral Surgery";
const description =
  "Answers to common questions after dental implant placement, including temporary teeth, healing, cleaning, restoration timing, and implant maintenance.";

const currentHref = "/services/after-implant-placement/";

const faqCards = [
  {
    number: "01",
    title: "What can I use for teeth while implants heal?",
    body: "Temporary removable teeth, a temporary bridge, or a modified denture may be available while implants heal. In some cases, temporary transitional implants or immediate loading can provide non-removable teeth during healing.",
  },
  {
    number: "02",
    title: "What problems can happen after surgery?",
    body: "Most patients do not experience severe pain, and medication may be prescribed to support recovery. Infection, adjacent tooth injury, or altered nerve sensation are uncommon but possible concerns that should be reported promptly.",
  },
  {
    number: "03",
    title: "How long do implants last?",
    body: "Dental implants usually last a long time. Long-term studies show strong success rates, though an implant that fails to heal or becomes loose may need removal and replacement after healing.",
  },
  {
    number: "04",
    title: "When are replacement teeth attached?",
    body: "Replacement teeth are usually attached once the jawbone has healed firmly around the implant. Depending on your case, restoration may begin immediately, shortly after placement, or after a longer healing phase.",
  },
];

const maintenanceItems = [
  "Brush and clean implant-supported teeth regularly",
  "Use floss or recommended cleaning aids",
  "Visit your dentist for hygiene and maintenance",
  "Expect periodic repairs or adjustments over time",
  "Keep all scheduled surgical and restorative visits",
];
---

<Layout title={title} description={description} ogImage="/images/specialized-care.jpg">
  <Header />
  <main>
    <section class="bg-midnight text-surface" aria-labelledby="service-heading">
      <div
        class="mx-auto grid min-h-[calc(100dvh-76px)] max-w-7xl items-center gap-14 px-5 py-14 lg:grid-cols-[minmax(0,610px)_minmax(380px,500px)] lg:px-0"
      >
        <div data-reveal>
          <a
            href="/#procedures"
            class="inline-flex text-sm font-bold text-accent transition-colors hover:text-surface"
          >
            ← Services
          </a>
          <p class="mt-10 text-xs font-bold uppercase tracking-[.34em] text-secondary">
            Dental Implants
          </p>
          <h1
            id="service-heading"
            class="serif mt-5 max-w-[760px] text-5xl leading-[0.96] text-surface sm:text-6xl lg:text-[72px]"
          >
            After implant placement.
          </h1>
          <p class="mt-7 max-w-[590px] text-lg leading-8 text-surface/75 sm:text-xl">
            Healing after dental implant surgery is easier when you know what to expect.
            These answers explain temporary teeth, recovery concerns, restoration
            timing, cleaning, maintenance, and care coordination.
          </p>
          <div class="mt-9 flex flex-col gap-3 sm:flex-row">
            <a
              href="/#appointment"
              class="inline-flex h-14 items-center justify-center rounded-md bg-secondary px-7 font-bold text-surface transition-opacity hover:opacity-90 sm:min-w-[223px]"
            >
              Request Appointment
            </a>
            <a
              href="tel:7852720444"
              class="inline-flex h-14 items-center justify-center rounded-md border border-surface/40 px-7 font-bold text-surface transition-colors hover:bg-surface/10 sm:min-w-[216px]"
            >
              Call (785) 272-0444
            </a>
          </div>
        </div>

        <div
          class="relative mx-auto w-full max-w-[500px] lg:mx-0"
          data-reveal
          style="--reveal-delay: 120ms"
        >
          <div
            class="absolute -bottom-3 left-3 right-[-12px] top-3 rounded-lg border border-secondary"
            aria-hidden="true"
          >
          </div>
          <div class="relative aspect-[4/5] overflow-hidden rounded-lg bg-surface/5">
            <img
              src="/images/specialized-care.jpg"
              alt="3D dental imaging equipment used for dental implant planning"
              class="h-full w-full object-cover object-center"
              width="5184"
              height="3456"
              loading="eager"
              decoding="async"
              fetchpriority="high"
            />
          </div>
        </div>
      </div>
    </section>

    <section class="bg-background py-20 text-foreground lg:py-24">
      <div
        class="mx-auto grid max-w-[1600px] gap-10 px-5 lg:grid-cols-[minmax(0,1fr)_minmax(0,920px)_minmax(0,1fr)] lg:items-start lg:gap-12"
      >
        <ServiceSidebar groupLabel="Dental Implants" currentHref={currentHref} />

        <div class="grid gap-20 lg:col-start-2 lg:gap-24">
          <section class="pb-2 lg:pb-0" aria-labelledby="healing-heading">
            <div class="max-w-5xl" data-reveal>
              <p class="text-xs font-bold uppercase tracking-[.34em] text-secondary">
                After Surgery
              </p>
              <h2
                id="healing-heading"
                class="serif mt-4 text-4xl leading-tight sm:text-5xl"
              >
                Practical answers for the healing and restoration phase.
              </h2>
              <div class="mt-7 space-y-6 text-base leading-8 text-muted">
                <p>
                  The period after implant placement can involve temporary teeth,
                  healing visits, restorative planning, and routine maintenance. Your
                  treatment sequence depends on the number of teeth being replaced,
                  bone healing, implant stability, and your final restoration.
                </p>
                <p>
                  Pain medication and antibiotics may be prescribed to support an easier
                  recovery. If you notice post-operative numbness, unusual tingling, or
                  signs of infection, contact the office so your care can be managed
                  appropriately.
                </p>
                <p>
                  Every implant case is different, so your surgeon and dentist will
                  review the most appropriate timeline for your replacement teeth.
                </p>
              </div>

              <div class="mt-8 rounded-lg border border-line bg-surface p-7 shadow-sm sm:p-8">
                <p class="text-xs font-bold uppercase tracking-[.28em] text-secondary">
                  Call with questions
                </p>
                <p class="mt-3 text-base leading-7 text-muted">
                  If something feels different than expected after surgery, it is always
                  better to call. Early communication helps us guide your recovery.
                </p>
              </div>
            </div>
          </section>

          <section class="pt-4 lg:pt-2" aria-labelledby="faq-heading">
            <div class="max-w-3xl" data-reveal>
              <p class="text-xs font-bold uppercase tracking-[.34em] text-secondary">
                Common Questions
              </p>
              <h2
                id="faq-heading"
                class="serif mt-4 text-4xl leading-tight sm:text-5xl"
              >
                What patients ask most after implant placement.
              </h2>
              <p class="mt-6 text-base leading-7 text-muted">
                These questions cover the early healing period, long-term expectations,
                and when the final restorative work begins.
              </p>
            </div>

            <div class="mt-12 grid gap-6 lg:grid-cols-2 lg:gap-7">
              {
                faqCards.map(({ number, title, body }, index) => (
                  <article
                    class="rounded-lg border border-line bg-surface p-8 shadow-sm sm:p-9 lg:p-10"
                    data-reveal
                    style={`--reveal-delay: ${(index % 2) * 80}ms`}
                  >
                    <div class="flex h-10 w-10 items-center justify-center rounded-full bg-aqua-pale text-sm font-bold text-secondary">
                      {number}
                    </div>
                    <h3 class="serif mt-6 text-2xl font-bold text-foreground">
                      {title}
                    </h3>
                    <p class="mt-4 text-base leading-7 text-muted">{body}</p>
                  </article>
                ))
              }
            </div>
          </section>

          <section
            class="grid gap-10 rounded-lg bg-aqua-soft p-8 sm:p-10 lg:grid-cols-[minmax(0,1fr)_280px] lg:items-center lg:p-12"
            aria-labelledby="maintenance-heading"
            data-reveal
          >
            <div>
              <p class="text-xs font-bold uppercase tracking-[.34em] text-secondary">
                Cleaning and Maintenance
              </p>
              <h2
                id="maintenance-heading"
                class="serif mt-4 text-4xl leading-tight sm:text-5xl"
              >
                Implant-supported teeth need regular care, just like natural teeth.
              </h2>
              <p class="mt-6 text-base leading-7 text-muted">
                Cleaning, hygiene visits, and maintenance help protect your implant
                restoration. Components can wear over time, so repairs, relines, screw
                tightening, clip replacement, or adjustments may eventually be needed.
              </p>
            </div>
            <div class="grid gap-3 text-sm font-bold text-foreground">
              {maintenanceItems.map((item) => (
                <p class="rounded-md bg-surface px-4 py-3">{item}</p>
              ))}
            </div>
          </section>

          <section class="grid gap-8 md:grid-cols-2">
            <article class="rounded-lg border border-line bg-surface p-8 shadow-sm sm:p-9 lg:p-10" data-reveal>
              <p class="text-xs font-bold uppercase tracking-[.28em] text-secondary">
                Care Team
              </p>
              <h2 class="serif mt-5 text-3xl leading-tight text-foreground">
                Will one doctor do everything?
              </h2>
              <p class="mt-6 text-base leading-7 text-muted">
                Usually, your oral surgeon places the implant and performs related
                surgical care, while your general dentist provides temporary and
                permanent replacement teeth. Both doctors help plan your treatment.
              </p>
            </article>

            <article
              class="rounded-lg border border-line bg-surface p-8 shadow-sm sm:p-9 lg:p-10"
              data-reveal
              style="--reveal-delay: 120ms"
            >
              <p class="text-xs font-bold uppercase tracking-[.28em] text-secondary">
                Cost Planning
              </p>
              <h2 class="serif mt-5 text-3xl leading-tight text-foreground">
                Costs depend on the full treatment plan.
              </h2>
              <p class="mt-6 text-base leading-7 text-muted">
                Estimates may include diagnostic work, surgical templates, implants,
                abutments, crowns, dentures, temporary restorations, and periodic
                maintenance. Insurance coverage can also vary.
              </p>
            </article>
          </section>

          <section class="rounded-lg bg-midnight px-8 py-12 text-surface sm:px-10 lg:px-12 lg:py-14">
            <div class="grid gap-8 lg:grid-cols-[minmax(0,1fr)_auto] lg:items-center">
              <div data-reveal>
                <p class="text-xs font-bold uppercase tracking-[.34em] text-secondary">
                  Reclaim Confidence
                </p>
                <h2 class="serif mt-4 text-4xl leading-tight sm:text-5xl">
                  Have a question after implant placement?
                </h2>
                <p class="mt-5 max-w-[660px] text-base leading-7 text-surface/75">
                  Our team is here to help you understand healing, temporary teeth,
                  restoration timing, and the next steps in your implant treatment.
                </p>
              </div>
              <div
                class="flex flex-col gap-3 sm:flex-row lg:flex-col"
                data-reveal
                style="--reveal-delay: 120ms"
              >
                <a
                  href="/#appointment"
                  class="inline-flex h-14 items-center justify-center rounded-md bg-secondary px-7 font-bold text-surface transition-opacity hover:opacity-90"
                >
                  Request Appointment
                </a>
                <a
                  href="tel:7852720444"
                  class="inline-flex h-14 items-center justify-center rounded-md border border-surface/40 px-7 font-bold text-surface transition-colors hover:bg-surface/10"
                >
                  Call (785) 272-0444
                </a>
              </div>
            </div>
          </section>
        </div>

        <div class="hidden lg:block" aria-hidden="true"></div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
