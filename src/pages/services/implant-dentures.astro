---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import ServiceSidebar from "../../components/ServiceSidebar.astro";

const title =
  "Implant Dentures | Implant Supported Overdentures in Topeka, KS | Capital Oral Surgery";
const description =
  "Learn how implant-supported overdentures can replace missing teeth with improved denture stability, fewer implants, and renewed confidence.";

const currentHref = "/services/implant-dentures/";

const treatmentSteps = [
  {
    number: "01",
    title: "Implants are placed",
    body: "A small number of dental implants are strategically positioned to support a full replacement arch. The treatment plan is customized to your anatomy and restorative goals.",
  },
  {
    number: "02",
    title: "Attachments are selected",
    body: "Implant dentures can connect with bar-and-clip systems or abutment-based attachments such as ball, magnet, or resilient stud attachments. Your team chooses the best fit early in planning.",
  },
  {
    number: "03",
    title: "Temporary teeth may be added",
    body: "In many cases, a temporary set of teeth can be placed on the same day as surgery, helping you return to everyday life while the implants begin healing.",
  },
  {
    number: "04",
    title: "Final bridge or denture is restored",
    body: "After a short healing period, your dentist places the final restoration so you can chew, speak, and smile with greater comfort and confidence.",
  },
];

const advantages = [
  "Cost-effective full-arch replacement",
  "Fewer implants needed per jaw",
  "Reduced need for bone grafting in some cases",
  "Faster treatment and healing time",
  "Documented clinical outcomes",
];
---

<Layout title={title} description={description} ogImage="/images/specialized-care.jpg">
  <Header />
  <main>
    <section class="bg-midnight text-surface" aria-labelledby="service-heading">
      <div
        class="mx-auto grid min-h-[calc(100dvh-76px)] max-w-7xl items-center gap-10 px-5 py-14 lg:gap-14 xl:grid-cols-[minmax(0,610px)_minmax(360px,500px)] xl:justify-between xl:px-0"
      >
        <div data-reveal>
          <a
            href="/#procedures"
            class="inline-flex text-sm font-bold text-accent transition-colors hover:text-surface"
          >
            ← Services
          </a>
          <p class="mt-10 text-xs font-bold tracking-[.34em] text-secondary">
            Dental implants
          </p>
          <h1
            id="service-heading"
            class="serif mt-5 max-w-[760px] text-5xl leading-[0.96] text-surface sm:text-6xl xl:text-[72px]"
          >
            Implant dentures.
          </h1>
          <p class="mt-7 max-w-[590px] text-lg leading-8 text-surface/75 sm:text-xl">
            Implant-supported overdentures replace a full set of missing teeth with a
            restoration supported by dental implants. They can make dentures feel more
            secure, more comfortable, and easier to trust while eating and speaking.
          </p>
          <div class="mt-9 flex flex-col gap-3 sm:flex-row">
            <a
              href="/#appointment"
              class="inline-flex h-14 items-center justify-center rounded-md bg-secondary px-7 font-bold text-surface transition-opacity hover:opacity-90 sm:min-w-[223px]"
            >
              Request Appointment
            </a>
            <a
              href="tel:7852720444"
              class="inline-flex h-14 items-center justify-center rounded-md border border-surface/40 px-7 font-bold text-surface transition-colors hover:bg-surface/10 sm:min-w-[216px]"
            >
              Call (785) 272-0444
            </a>
          </div>
        </div>

        <div
          class="relative mx-auto w-full max-w-[500px] lg:mx-0"
          data-reveal
          style="--reveal-delay: 120ms"
        >
          <div
            class="absolute -bottom-3 left-3 right-[-12px] top-3 rounded-lg border border-secondary"
            aria-hidden="true"
          >
          </div>
          <div class="relative aspect-[4/5] overflow-hidden rounded-lg bg-surface/5">
            <img
              src="/images/specialized-care.jpg"
              alt="3D dental imaging equipment used for dental implant planning"
              class="h-full w-full object-cover object-center"
              width="5184"
              height="3456"
              loading="eager"
              decoding="async"
              fetchpriority="high"
            />
          </div>
        </div>
      </div>
    </section>

    <section class="bg-background py-20 text-foreground lg:py-24">
      <div
        class="mx-auto grid max-w-[920px] gap-10 px-5 min-[1400px]:max-w-[1400px] min-[1400px]:grid-cols-[220px_minmax(0,840px)_220px] min-[1400px]:items-start min-[1400px]:gap-8 min-[1700px]:max-w-[1640px] min-[1700px]:grid-cols-[280px_minmax(0,920px)_280px] min-[1700px]:gap-12"
      >
        <ServiceSidebar groupLabel="Dental implants" currentHref={currentHref} />

        <div class="grid gap-20 lg:gap-24 min-[1400px]:col-start-2">
          <section class="pb-2 lg:pb-0" aria-labelledby="overdenture-heading">
            <div class="max-w-5xl" data-reveal>
              <p class="text-xs font-bold tracking-[.34em] text-secondary">
                Implant-supported overdentures
              </p>
              <h2
                id="overdenture-heading"
                class="serif mt-4 text-4xl leading-tight sm:text-5xl"
              >
                A more stable way to replace a full set of teeth.
              </h2>
              <div class="mt-7 space-y-6 text-base leading-8 text-muted">
                <p>
                  Standard dentures are unsecured prostheses with real limitations.
                  They can feel painful, inconvenient, or unstable, and they may make
                  chewing favorite foods difficult.
                </p>
                <p>
                  Implant dentures use dental implants to support a full replacement
                  bridge or denture. Fewer implants may be needed than some other
                  full-arch approaches, which can reduce treatment time and cost.
                </p>
                <p>
                  Because the restoration is connected to implants, it can feel more
                  stable in the bone and may reduce the need for bone grafting to
                  increase bone volume in some patients.
                </p>
              </div>

              <div class="mt-8 rounded-lg border border-line bg-surface p-7 shadow-sm sm:p-8">
                <p class="text-xs font-bold tracking-[.28em] text-secondary">
                  A practical full-arch option
                </p>
                <p class="mt-3 text-base leading-7 text-muted">
                  Implant dentures are designed for patients who want better stability
                  than conventional dentures while keeping treatment efficient,
                  cleanable, and cost-conscious.
                </p>
              </div>
            </div>
          </section>

          <section class="pt-4 lg:pt-2" aria-labelledby="treatment-heading">
            <div class="max-w-3xl" data-reveal>
              <p class="text-xs font-bold tracking-[.34em] text-secondary">
                Treatment concept
              </p>
              <h2
                id="treatment-heading"
                class="serif mt-4 text-4xl leading-tight sm:text-5xl"
              >
                The attachment system is chosen around your needs.
              </h2>
              <p class="mt-6 text-base leading-7 text-muted">
                Implant-supported overdentures may stay connected with bar-and-clip
                attachment methods or abutment-based attachments. The right system is
                selected early based on anatomy, comfort, cleaning needs, stability,
                and the final restoration design.
              </p>
            </div>

            <div class="mt-12 grid gap-6 lg:grid-cols-2 lg:gap-7">
              {
                treatmentSteps.map(({ number, title, body }, index) => (
                  <article
                    class="rounded-lg border border-line bg-surface p-8 shadow-sm sm:p-9 lg:p-10"
                    data-reveal
                    style={`--reveal-delay: ${(index % 2) * 80}ms`}
                  >
                    <div class="flex h-10 w-10 items-center justify-center rounded-full bg-aqua-pale text-sm font-bold text-secondary">
                      {number}
                    </div>
                    <h3 class="serif mt-6 text-2xl font-bold text-foreground">
                      {title}
                    </h3>
                    <p class="mt-4 text-base leading-7 text-muted">{body}</p>
                  </article>
                ))
              }
            </div>
          </section>

          <section
            class="grid gap-10 rounded-lg bg-aqua-soft p-8 sm:p-10 lg:grid-cols-[minmax(0,1fr)_280px] lg:items-center lg:p-12"
            aria-labelledby="advantages-heading"
            data-reveal
          >
            <div>
              <p class="text-xs font-bold tracking-[.34em] text-secondary">
                Advantages
              </p>
              <h2
                id="advantages-heading"
                class="serif mt-4 text-4xl leading-tight sm:text-5xl"
              >
                Implant dentures can make everyday life feel easier again.
              </h2>
              <p class="mt-6 text-base leading-7 text-muted">
                With improved stability and fewer implants than some full-arch
                methods, implant-supported overdentures can help patients regain
                confidence while keeping care practical.
              </p>
            </div>
            <div class="grid gap-3 text-sm font-bold text-foreground">
              {advantages.map((item) => (
                <p class="rounded-md bg-surface px-4 py-3">{item}</p>
              ))}
            </div>
          </section>

          <section class="grid gap-8 md:grid-cols-2">
            <article class="rounded-lg border border-line bg-surface p-8 shadow-sm sm:p-9 lg:p-10" data-reveal>
              <p class="text-xs font-bold tracking-[.28em] text-secondary">
                Same-day temporaries
              </p>
              <h2 class="serif mt-5 text-3xl leading-tight text-foreground">
                Temporary teeth may be placed the day of surgery.
              </h2>
              <p class="mt-6 text-base leading-7 text-muted">
                In many cases, temporary teeth can be attached after implant placement.
                This helps you lead a more normal life during the first phase of
                healing before the final restoration is placed.
              </p>
            </article>

            <article
              class="rounded-lg border border-line bg-surface p-8 shadow-sm sm:p-9 lg:p-10"
              data-reveal
              style="--reveal-delay: 120ms"
            >
              <p class="text-xs font-bold tracking-[.28em] text-secondary">
                Final restoration
              </p>
              <h2 class="serif mt-5 text-3xl leading-tight text-foreground">
                Your dentist completes the final bridge or denture.
              </h2>
              <p class="mt-6 text-base leading-7 text-muted">
                After a short healing period, your dentist places the final restoration.
                The goal is improved quality of life, renewed confidence, and the
                ability to enjoy more of your favorite foods again.
              </p>
            </article>
          </section>

          <section class="rounded-lg bg-midnight px-8 py-12 text-surface sm:px-10 lg:px-12 lg:py-14">
            <div class="grid gap-8 lg:grid-cols-[minmax(0,1fr)_auto] lg:items-center">
              <div data-reveal>
                <p class="text-xs font-bold tracking-[.34em] text-secondary">
                  Reclaim confidence
                </p>
                <h2 class="serif mt-4 text-4xl leading-tight sm:text-5xl">
                  See if implant dentures fit your goals.
                </h2>
                <p class="mt-5 max-w-[660px] text-base leading-7 text-surface/75">
                  We will evaluate your jaw, discuss attachment options, and help you
                  understand whether implant-supported overdentures are a strong fit.
                </p>
              </div>
              <div
                class="flex flex-col gap-3 sm:flex-row lg:flex-col"
                data-reveal
                style="--reveal-delay: 120ms"
              >
                <a
                  href="/#appointment"
                  class="inline-flex h-14 items-center justify-center rounded-md bg-secondary px-7 font-bold text-surface transition-opacity hover:opacity-90"
                >
                  Request Appointment
                </a>
                <a
                  href="tel:7852720444"
                  class="inline-flex h-14 items-center justify-center rounded-md border border-surface/40 px-7 font-bold text-surface transition-colors hover:bg-surface/10"
                >
                  Call (785) 272-0444
                </a>
              </div>
            </div>
          </section>
        </div>

        <div class="hidden min-[1400px]:block" aria-hidden="true"></div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
