---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import ServiceSidebar from "../../components/ServiceSidebar.astro";

const title = "Sinus Lift | Topeka, KS | Capital Oral Surgery";
const description =
  "Learn how a sinus lift adds bone to the upper back jaw when the sinus is too close for dental implant placement.";

const currentHref = "/services/sinus-lift/";

const sinusSteps = [
  {
    number: "01",
    title: "Evaluate bone height",
    body: "Imaging shows how much bone remains between the upper jaw and the maxillary sinus where a future implant may be placed.",
  },
  {
    number: "02",
    title: "Access the sinus area",
    body: "The surgeon creates a small opening in the upper jaw near the missing molar or premolar site to reach the sinus membrane safely.",
  },
  {
    number: "03",
    title: "Lift the membrane",
    body: "The sinus membrane is gently elevated to create space between the sinus floor and the jawbone.",
  },
  {
    number: "04",
    title: "Place bone graft material",
    body: "Bone graft material is added into that space so the area can heal with more height and support for future implant placement.",
  },
];

const sinusBenefits = [
  "Adds bone height in the upper back jaw",
  "Improves implant placement options",
  "Restores support after long-term molar loss",
  "Helps create a stronger implant foundation",
];
---

<Layout title={title} description={description} ogImage="/images/specialized-care.jpg">
  <Header />
  <main>
    <section class="bg-midnight text-surface" aria-labelledby="service-heading">
      <div
        class="mx-auto grid min-h-[calc(100dvh-76px)] max-w-7xl items-center gap-14 px-5 py-14 lg:grid-cols-[minmax(0,610px)_minmax(380px,500px)] lg:px-0"
      >
        <div data-reveal>
          <a
            href="/#procedures"
            class="inline-flex text-sm font-bold text-accent transition-colors hover:text-surface"
          >
            ← Services
          </a>
          <p class="mt-10 text-xs font-bold uppercase tracking-[.34em] text-secondary">
            Procedures
          </p>
          <h1
            id="service-heading"
            class="serif mt-5 max-w-[760px] text-5xl leading-[0.96] text-surface sm:text-6xl lg:text-[72px]"
          >
            Sinus lift.
          </h1>
          <p class="mt-7 max-w-[590px] text-lg leading-8 text-surface/75 sm:text-xl">
            A sinus lift adds bone to the upper back jaw when the maxillary sinus sits
            too close to the area where a dental implant needs support.
          </p>
          <div class="mt-9 flex flex-col gap-3 sm:flex-row">
            <a
              href="/#appointment"
              class="inline-flex h-14 items-center justify-center rounded-md bg-secondary px-7 font-bold text-surface transition-opacity hover:opacity-90 sm:min-w-[223px]"
            >
              Request Appointment
            </a>
            <a
              href="tel:7852720444"
              class="inline-flex h-14 items-center justify-center rounded-md border border-surface/40 px-7 font-bold text-surface transition-colors hover:bg-surface/10 sm:min-w-[216px]"
            >
              Call (785) 272-0444
            </a>
          </div>
        </div>

        <div
          class="relative mx-auto w-full max-w-[500px] lg:mx-0"
          data-reveal
          style="--reveal-delay: 120ms"
        >
          <div
            class="absolute -bottom-3 left-3 right-[-12px] top-3 rounded-lg border border-secondary"
            aria-hidden="true"
          >
          </div>
          <div class="relative aspect-[4/5] overflow-hidden rounded-lg bg-surface/5">
            <img
              src="/images/specialized-care.jpg"
              alt="Dental imaging equipment used to plan a sinus lift"
              class="h-full w-full object-cover object-center"
              width="5184"
              height="3456"
              loading="eager"
              decoding="async"
              fetchpriority="high"
            />
          </div>
        </div>
      </div>
    </section>

    <section class="bg-background py-20 text-foreground lg:py-24">
      <div
        class="mx-auto grid max-w-[1600px] gap-10 px-5 lg:grid-cols-[minmax(0,1fr)_minmax(0,920px)_minmax(0,1fr)] lg:items-start lg:gap-12"
      >
        <ServiceSidebar groupLabel="Procedures" currentHref={currentHref} />

        <div class="grid gap-20 lg:col-start-2 lg:gap-24">
          <section class="pb-2 lg:pb-0" aria-labelledby="overview-heading">
            <div class="max-w-5xl" data-reveal>
              <p class="text-xs font-bold uppercase tracking-[.34em] text-secondary">
                Upper Jaw Bone Grafting
              </p>
              <h2
                id="overview-heading"
                class="serif mt-4 text-4xl leading-tight sm:text-5xl"
              >
                Sinus position can limit implant-ready bone in the upper back jaw.
              </h2>
              <div class="mt-7 space-y-6 text-base leading-8 text-muted">
                <p>
                  The maxillary sinuses sit above the upper back teeth. When upper
                  molars or premolars are removed, the sinus may expand downward while
                  the supporting jawbone shrinks.
                </p>
                <p>
                  This can leave too little bone height for a dental implant. A sinus
                  lift, also called sinus augmentation, creates space for graft material
                  beneath the sinus membrane.
                </p>
                <p>
                  After healing, the grafted area can provide more stable support for
                  implant placement and long-term restoration.
                </p>
              </div>

              <div class="mt-8 rounded-lg border border-line bg-surface p-7 shadow-sm sm:p-8">
                <p class="text-xs font-bold uppercase tracking-[.28em] text-secondary">
                  Why timing matters
                </p>
                <p class="mt-3 text-base leading-7 text-muted">
                  The longer upper back teeth are missing, the more likely sinus changes
                  and bone loss may affect implant planning.
                </p>
              </div>
            </div>
          </section>

          <section class="pt-4 lg:pt-2" aria-labelledby="process-heading">
            <div class="max-w-3xl" data-reveal>
              <p class="text-xs font-bold uppercase tracking-[.34em] text-secondary">
                How It Works
              </p>
              <h2
                id="process-heading"
                class="serif mt-4 text-4xl leading-tight sm:text-5xl"
              >
                The sinus membrane is lifted so new bone can form beneath it.
              </h2>
              <p class="mt-6 text-base leading-7 text-muted">
                The exact approach depends on your anatomy, the amount of bone present,
                and whether implant placement is planned at the same visit or after the
                graft has healed.
              </p>
            </div>

            <div class="mt-12 grid gap-6 lg:grid-cols-2 lg:gap-7">
              {
                sinusSteps.map(({ number, title, body }, index) => (
                  <article
                    class="rounded-lg border border-line bg-surface p-8 shadow-sm sm:p-9 lg:p-10"
                    data-reveal
                    style={`--reveal-delay: ${(index % 2) * 80}ms`}
                  >
                    <div class="flex h-10 w-10 items-center justify-center rounded-full bg-aqua-pale text-sm font-bold text-secondary">
                      {number}
                    </div>
                    <h3 class="serif mt-6 text-2xl font-bold text-foreground">
                      {title}
                    </h3>
                    <p class="mt-4 text-base leading-7 text-muted">{body}</p>
                  </article>
                ))
              }
            </div>
          </section>

          <section
            class="grid gap-10 rounded-lg bg-aqua-soft p-8 sm:p-10 lg:grid-cols-[minmax(0,1fr)_280px] lg:items-center lg:p-12"
            aria-labelledby="benefits-heading"
            data-reveal
          >
            <div>
              <p class="text-xs font-bold uppercase tracking-[.34em] text-secondary">
                Why It Helps
              </p>
              <h2
                id="benefits-heading"
                class="serif mt-4 text-4xl leading-tight sm:text-5xl"
              >
                Added bone height can make implant treatment possible.
              </h2>
              <p class="mt-6 text-base leading-7 text-muted">
                A sinus lift helps restore the vertical bone support needed in the upper
                back jaw, where natural bone is often limited after long-term tooth loss.
              </p>
            </div>
            <div class="grid gap-3 text-sm font-bold text-foreground">
              {sinusBenefits.map((item) => (
                <p class="rounded-md bg-surface px-4 py-3">{item}</p>
              ))}
            </div>
          </section>

          <section class="grid gap-8 md:grid-cols-2">
            <article class="rounded-lg border border-line bg-surface p-8 shadow-sm sm:p-9 lg:p-10" data-reveal>
              <p class="text-xs font-bold uppercase tracking-[.28em] text-secondary">
                Healing Timeline
              </p>
              <h2 class="serif mt-5 text-3xl leading-tight text-foreground">
                The graft needs time to become a stronger foundation.
              </h2>
              <p class="mt-6 text-base leading-7 text-muted">
                Depending on the amount of bone needed, the graft may heal before an
                implant is placed, or the implant may be placed at the same appointment
                when anatomy allows.
              </p>
            </article>

            <article
              class="rounded-lg border border-line bg-surface p-8 shadow-sm sm:p-9 lg:p-10"
              data-reveal
              style="--reveal-delay: 120ms"
            >
              <p class="text-xs font-bold uppercase tracking-[.28em] text-secondary">
                Careful Planning
              </p>
              <h2 class="serif mt-5 text-3xl leading-tight text-foreground">
                Imaging helps protect the sinus and guide graft placement.
              </h2>
              <p class="mt-6 text-base leading-7 text-muted">
                Detailed planning allows the surgeon to evaluate sinus anatomy, bone
                height, and the safest way to rebuild support for your restoration.
              </p>
            </article>
          </section>

          <section class="rounded-lg bg-midnight px-8 py-12 text-surface sm:px-10 lg:px-12 lg:py-14">
            <div class="grid gap-8 lg:grid-cols-[minmax(0,1fr)_auto] lg:items-center">
              <div data-reveal>
                <p class="text-xs font-bold uppercase tracking-[.34em] text-secondary">
                  Rebuild Upper Jaw Support
                </p>
                <h2 class="serif mt-4 text-4xl leading-tight sm:text-5xl">
                  Find out whether a sinus lift is needed.
                </h2>
                <p class="mt-5 max-w-[660px] text-base leading-7 text-surface/75">
                  We will review your imaging and explain whether sinus augmentation
                  belongs in your implant treatment plan.
                </p>
              </div>
              <div
                class="flex flex-col gap-3 sm:flex-row lg:flex-col"
                data-reveal
                style="--reveal-delay: 120ms"
              >
                <a
                  href="/#appointment"
                  class="inline-flex h-14 items-center justify-center rounded-md bg-secondary px-7 font-bold text-surface transition-opacity hover:opacity-90"
                >
                  Request Appointment
                </a>
                <a
                  href="tel:7852720444"
                  class="inline-flex h-14 items-center justify-center rounded-md border border-surface/40 px-7 font-bold text-surface transition-colors hover:bg-surface/10"
                >
                  Call (785) 272-0444
                </a>
              </div>
            </div>
          </section>
        </div>

        <div class="hidden lg:block" aria-hidden="true"></div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
