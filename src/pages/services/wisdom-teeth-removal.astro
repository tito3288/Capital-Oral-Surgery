---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import ServiceSidebar from "../../components/ServiceSidebar.astro";

const title =
  "Wisdom Teeth Removal | Topeka, KS | Capital Oral Surgery";
const description =
  "Learn about wisdom teeth evaluation, removal, anesthesia, recovery, cost, and common concerns at Capital Oral Surgery in Topeka, KS.";

const currentHref = "/services/wisdom-teeth-removal/";

const removalReasons = [
  {
    number: "01",
    title: "Infection",
    body: "When there is not enough room for full eruption, gum tissue around a wisdom tooth can become irritated or infected, causing recurrent pain, swelling, and difficulty chewing or swallowing.",
  },
  {
    number: "02",
    title: "Cyst formation",
    body: "Cysts can develop around impacted wisdom teeth and gradually damage nearby jawbone or teeth. These problems are often harder to treat when removal is delayed.",
  },
  {
    number: "03",
    title: "Crowding",
    body: "Impacted wisdom teeth may contribute to crowding, especially around the lower front teeth after braces or during early adulthood.",
  },
  {
    number: "04",
    title: "Adjacent tooth damage",
    body: "If a wisdom tooth is difficult to clean around, the second molar in front of it can be affected by gum disease, bone loss, or decay.",
  },
];

const surgeryDay = [
  "Anesthesia options reviewed at consultation",
  "Adult escort needed for the appointment and rest of day",
  "Typical procedure time is about 30 to 60 minutes",
  "Most patients are in the office about 90 minutes",
  "Modern monitoring and sterilization protocols",
];
---

<Layout title={title} description={description} ogImage="/images/specialized-care.jpg">
  <Header />
  <main>
    <section class="bg-midnight text-surface" aria-labelledby="service-heading">
      <div
        class="mx-auto grid min-h-[calc(100dvh-76px)] max-w-7xl items-center gap-10 px-5 py-14 lg:gap-14 xl:grid-cols-[minmax(0,610px)_minmax(360px,500px)] xl:justify-between xl:px-0"
      >
        <div data-reveal>
          <a
            href="/#procedures"
            class="inline-flex text-sm font-bold text-accent transition-colors hover:text-surface"
          >
            ← Services
          </a>
          <p class="mt-10 text-xs font-bold tracking-[.34em] text-secondary">
            Wisdom teeth
          </p>
          <h1
            id="service-heading"
            class="serif mt-5 max-w-[760px] text-5xl leading-[0.96] text-surface sm:text-6xl xl:text-[72px]"
          >
            Wisdom teeth removal.
          </h1>
          <p class="mt-7 max-w-[590px] text-lg leading-8 text-surface/75 sm:text-xl">
            Wisdom teeth are often evaluated in the teenage years so potential problems
            can be identified early. Our surgeons use imaging, examination, and
            anesthesia planning to make removal as safe and comfortable as possible.
          </p>
          <div class="mt-9 flex flex-col gap-3 sm:flex-row">
            <a
              href="/#appointment"
              class="inline-flex h-14 items-center justify-center rounded-md bg-secondary px-7 font-bold text-surface transition-opacity hover:opacity-90 sm:min-w-[223px]"
            >
              Request Appointment
            </a>
            <a
              href="tel:7852720444"
              class="inline-flex h-14 items-center justify-center rounded-md border border-surface/40 px-7 font-bold text-surface transition-colors hover:bg-surface/10 sm:min-w-[216px]"
            >
              Call (785) 272-0444
            </a>
          </div>
        </div>

        <div
          class="relative mx-auto w-full max-w-[500px] lg:mx-0"
          data-reveal
          style="--reveal-delay: 120ms"
        >
          <div
            class="absolute -bottom-3 left-3 right-[-12px] top-3 rounded-lg border border-secondary"
            aria-hidden="true"
          >
          </div>
          <div class="relative aspect-[4/5] overflow-hidden rounded-lg bg-surface/5">
            <img
              src="/images/specialized-care.jpg"
              alt="3D dental imaging equipment used for oral surgery planning"
              class="h-full w-full object-cover object-center"
              width="5184"
              height="3456"
              loading="eager"
              decoding="async"
              fetchpriority="high"
            />
          </div>
        </div>
      </div>
    </section>

    <section class="bg-background py-20 text-foreground lg:py-24">
      <div
        class="mx-auto grid max-w-[920px] gap-10 px-5 min-[1400px]:max-w-[1400px] min-[1400px]:grid-cols-[220px_minmax(0,840px)_220px] min-[1400px]:items-start min-[1400px]:gap-8 min-[1700px]:max-w-[1640px] min-[1700px]:grid-cols-[280px_minmax(0,920px)_280px] min-[1700px]:gap-12"
      >
        <ServiceSidebar groupLabel="Wisdom teeth" currentHref={currentHref} />

        <div class="grid gap-20 lg:gap-24 min-[1400px]:col-start-2">
          <section class="pb-2 lg:pb-0" aria-labelledby="evaluation-heading">
            <div class="max-w-5xl" data-reveal>
              <p class="text-xs font-bold tracking-[.34em] text-secondary">
                Oral examination
              </p>
              <h2
                id="evaluation-heading"
                class="serif mt-4 text-4xl leading-tight sm:text-5xl"
              >
                Early evaluation helps prevent future wisdom tooth problems.
              </h2>
              <div class="mt-7 space-y-6 text-base leading-8 text-muted">
                <p>
                  With an oral examination and x-rays, our doctors can evaluate the
                  position of your wisdom teeth and predict whether present or future
                  problems are likely.
                </p>
                <p>
                  Studies have shown that early evaluation and treatment can lead to a
                  better outcome. Patients are often first evaluated in their mid-teenage
                  years by a dentist, orthodontist, or oral and maxillofacial surgeon.
                </p>
                <p>
                  All outpatient wisdom tooth surgery is performed with appropriate
                  anesthesia to maximize comfort. Our doctors are trained, licensed, and
                  experienced in providing anesthesia options for oral surgery patients.
                </p>
              </div>

              <div class="mt-8 rounded-lg border border-line bg-surface p-7 shadow-sm sm:p-8">
                <p class="text-xs font-bold tracking-[.28em] text-secondary">
                  Best timing
                </p>
                <p class="mt-3 text-base leading-7 text-muted">
                  Many patients heal faster and more predictably when wisdom teeth are
                  treated in the teenage years or early twenties, before roots fully
                  mature and jawbone becomes denser.
                </p>
              </div>
            </div>
          </section>

          <section class="pt-4 lg:pt-2" aria-labelledby="reasons-heading">
            <div class="max-w-3xl" data-reveal>
              <p class="text-xs font-bold tracking-[.34em] text-secondary">
                Why remove wisdom teeth
              </p>
              <h2
                id="reasons-heading"
                class="serif mt-4 text-4xl leading-tight sm:text-5xl"
              >
                Limited space can create several long-term concerns.
              </h2>
              <p class="mt-6 text-base leading-7 text-muted">
                If there is not enough room for third molars to fully erupt, impacted
                wisdom teeth can cause problems with gum tissue, neighboring teeth, jaw
                bone, and future dental stability.
              </p>
            </div>

            <div class="mt-12 grid gap-6 lg:grid-cols-2 lg:gap-7">
              {
                removalReasons.map(({ number, title, body }, index) => (
                  <article
                    class="rounded-lg border border-line bg-surface p-8 shadow-sm sm:p-9 lg:p-10"
                    data-reveal
                    style={`--reveal-delay: ${(index % 2) * 80}ms`}
                  >
                    <div class="flex h-10 w-10 items-center justify-center rounded-full bg-aqua-pale text-sm font-bold text-secondary">
                      {number}
                    </div>
                    <h3 class="serif mt-6 text-2xl font-bold text-foreground">
                      {title}
                    </h3>
                    <p class="mt-4 text-base leading-7 text-muted">{body}</p>
                  </article>
                ))
              }
            </div>
          </section>

          <section
            class="grid gap-10 rounded-lg bg-aqua-soft p-8 sm:p-10 lg:grid-cols-[minmax(0,1fr)_280px] lg:items-center lg:p-12"
            aria-labelledby="day-heading"
            data-reveal
          >
            <div>
              <p class="text-xs font-bold tracking-[.34em] text-secondary">
                Day of surgery
              </p>
              <h2
                id="day-heading"
                class="serif mt-4 text-4xl leading-tight sm:text-5xl"
              >
                Sedation and monitoring help make the visit calm.
              </h2>
              <p class="mt-6 text-base leading-7 text-muted">
                Most patients prefer to be unaware of the experience and choose sedation.
                At consultation, anesthesia options are reviewed, and the team explains
                how to prepare for the appointment.
              </p>
            </div>
            <div class="grid gap-3 text-sm font-bold text-foreground">
              {surgeryDay.map((item) => (
                <p class="rounded-md bg-surface px-4 py-3">{item}</p>
              ))}
            </div>
          </section>

          <section class="grid gap-8 md:grid-cols-2">
            <article class="rounded-lg border border-line bg-surface p-8 shadow-sm sm:p-9 lg:p-10" data-reveal>
              <p class="text-xs font-bold tracking-[.28em] text-secondary">
                Before surgery
              </p>
              <h2 class="serif mt-5 text-3xl leading-tight text-foreground">
                Fasting instructions matter for anesthesia safety.
              </h2>
              <p class="mt-6 text-base leading-7 text-muted">
                On the day of surgery, it is important to follow food and drink
                instructions closely. Having anything in your stomach can increase the
                risk of anesthetic complications, including nausea and vomiting.
              </p>
            </article>

            <article
              class="rounded-lg border border-line bg-surface p-8 shadow-sm sm:p-9 lg:p-10"
              data-reveal
              style="--reveal-delay: 120ms"
            >
              <p class="text-xs font-bold tracking-[.28em] text-secondary">
                Recovery
              </p>
              <h2 class="serif mt-5 text-3xl leading-tight text-foreground">
                Most post-op changes improve within several days.
              </h2>
              <p class="mt-6 text-base leading-7 text-muted">
                Dissolving stitches, gum swelling, and a pulling sensation can be normal.
                Clear liquids are usually recommended first, with your diet increasing
                gradually as your body permits.
              </p>
            </article>
          </section>

          <section class="rounded-lg bg-midnight px-8 py-12 text-surface sm:px-10 lg:px-12 lg:py-14">
            <div class="grid gap-8 lg:grid-cols-[minmax(0,1fr)_auto] lg:items-center">
              <div data-reveal>
                <p class="text-xs font-bold tracking-[.34em] text-secondary">
                  Schedule a consultation
                </p>
                <h2 class="serif mt-4 text-4xl leading-tight sm:text-5xl">
                  Have questions before wisdom teeth removal?
                </h2>
                <p class="mt-5 max-w-[660px] text-base leading-7 text-surface/75">
                  We will review your x-rays, discuss anesthesia options, answer your
                  questions, and explain cost and insurance expectations before surgery.
                </p>
              </div>
              <div
                class="flex flex-col gap-3 sm:flex-row lg:flex-col"
                data-reveal
                style="--reveal-delay: 120ms"
              >
                <a
                  href="/#appointment"
                  class="inline-flex h-14 items-center justify-center rounded-md bg-secondary px-7 font-bold text-surface transition-opacity hover:opacity-90"
                >
                  Request Appointment
                </a>
                <a
                  href="tel:7852720444"
                  class="inline-flex h-14 items-center justify-center rounded-md border border-surface/40 px-7 font-bold text-surface transition-colors hover:bg-surface/10"
                >
                  Call (785) 272-0444
                </a>
              </div>
            </div>
          </section>
        </div>

        <div class="hidden min-[1400px]:block" aria-hidden="true"></div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
