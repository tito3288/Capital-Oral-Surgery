---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import ServiceSidebar from "../../components/ServiceSidebar.astro";

const title = "TMJ Disorder | Topeka, KS | Capital Oral Surgery";
const description =
  "Learn about TMJ disorders, common symptoms, causes, self-care, splint therapy, bite correction, and when surgery may be considered.";

const currentHref = "/services/tmj/";

const tmjSignals = [
  {
    number: "01",
    title: "Pain or stiffness",
    body: "Sore jaw muscles, frequent headaches, neck aches, or pain that worsens with clenching can be signs of TMJ strain.",
  },
  {
    number: "02",
    title: "Clicking or locking",
    body: "The jaw may click, pop, grate, catch, or lock when opening, closing, eating, or yawning.",
  },
  {
    number: "03",
    title: "Clenching or grinding",
    body: "Grinding and clenching can tighten the jaw muscles, stress the joints, and contribute to worn, sensitive, loose, or broken teeth.",
  },
  {
    number: "04",
    title: "Bite changes",
    body: "Teeth may meet differently over time, or it may become harder to bite or tear food with the front teeth.",
  },
];

const selfCare = [
  "Rest your jaw",
  "Keep teeth apart when not eating or swallowing",
  "Choose soft foods",
  "Use ice and heat as directed",
  "Practice jaw exercises and good posture",
];
---

<Layout title={title} description={description} ogImage="/images/specialized-care.jpg">
  <Header />
  <main>
    <section class="bg-midnight text-surface" aria-labelledby="service-heading">
      <div
        class="mx-auto grid min-h-[calc(100dvh-76px)] max-w-7xl items-center gap-10 px-5 py-14 lg:gap-14 xl:grid-cols-[minmax(0,610px)_minmax(360px,500px)] xl:justify-between xl:px-0"
      >
        <div data-reveal>
          <a
            href="/#procedures"
            class="inline-flex text-sm font-bold text-accent transition-colors hover:text-surface"
          >
            ← Services
          </a>
          <p class="mt-10 text-xs font-bold tracking-[.34em] text-secondary">
            Procedures
          </p>
          <h1
            id="service-heading"
            class="serif mt-5 max-w-[760px] text-5xl leading-[0.96] text-surface sm:text-6xl xl:text-[72px]"
          >
            TMJ disorders.
          </h1>
          <p class="mt-7 max-w-[590px] text-lg leading-8 text-surface/75 sm:text-xl">
            TMJ disorders affect the jaw joints and chewing muscles. Pain, clicking,
            locking, bite changes, or trouble opening can often be improved with a
            thoughtful mix of self-care and professional treatment.
          </p>
          <div class="mt-9 flex flex-col gap-3 sm:flex-row">
            <a
              href="/#appointment"
              class="inline-flex h-14 items-center justify-center rounded-md bg-secondary px-7 font-bold text-surface transition-opacity hover:opacity-90 sm:min-w-[223px]"
            >
              Request Appointment
            </a>
            <a
              href="tel:7852720444"
              class="inline-flex h-14 items-center justify-center rounded-md border border-surface/40 px-7 font-bold text-surface transition-colors hover:bg-surface/10 sm:min-w-[216px]"
            >
              Call (785) 272-0444
            </a>
          </div>
        </div>

        <div
          class="relative mx-auto w-full max-w-[500px] lg:mx-0"
          data-reveal
          style="--reveal-delay: 120ms"
        >
          <div
            class="absolute -bottom-3 left-3 right-[-12px] top-3 rounded-lg border border-secondary"
            aria-hidden="true"
          >
          </div>
          <div class="relative aspect-[4/5] overflow-hidden rounded-lg bg-surface/5">
            <img
              src="/images/specialized-care.jpg"
              alt="Dental imaging equipment used to evaluate jaw joints and oral surgery concerns"
              class="h-full w-full object-cover object-center"
              width="5184"
              height="3456"
              loading="eager"
              decoding="async"
              fetchpriority="high"
            />
          </div>
        </div>
      </div>
    </section>

    <section class="bg-background py-20 text-foreground lg:py-24">
      <div
        class="mx-auto grid max-w-[920px] gap-10 px-5 min-[1400px]:max-w-[1400px] min-[1400px]:grid-cols-[220px_minmax(0,840px)_220px] min-[1400px]:items-start min-[1400px]:gap-8 min-[1700px]:max-w-[1640px] min-[1700px]:grid-cols-[280px_minmax(0,920px)_280px] min-[1700px]:gap-12"
      >
        <ServiceSidebar groupLabel="Procedures" currentHref={currentHref} />

        <div class="grid gap-20 lg:gap-24 min-[1400px]:col-start-2">
          <section class="pb-2 lg:pb-0" aria-labelledby="overview-heading">
            <div class="max-w-5xl" data-reveal>
              <p class="text-xs font-bold tracking-[.34em] text-secondary">
                Jaw joint health
              </p>
              <h2
                id="overview-heading"
                class="serif mt-4 text-4xl leading-tight sm:text-5xl"
              >
                TMJ problems happen when the joints and chewing muscles stop working together comfortably.
              </h2>
              <div class="mt-7 space-y-6 text-base leading-8 text-muted">
                <p>
                  TMJ stands for temporomandibular joint, the right and left joints that
                  connect the jaw to the skull. When these joints, muscles, ligaments,
                  or cartilage disks are strained, symptoms can show up as pain,
                  clicking, grating, or limited opening.
                </p>
                <p>
                  TMJ disorders can develop from clenching or grinding, injury,
                  arthritis, joint disease, bite changes, or a disk that slips out of
                  position.
                </p>
                <p>
                  Early evaluation matters because some TMJ problems can become more
                  serious over time. Treatment is usually gradual and works best when
                  self-care and professional care are combined.
                </p>
              </div>

              <div class="mt-8 rounded-lg border border-line bg-surface p-7 shadow-sm sm:p-8">
                <p class="text-xs font-bold tracking-[.28em] text-secondary">
                  Treatment takes time
                </p>
                <p class="mt-3 text-base leading-7 text-muted">
                  No single treatment resolves every TMJ disorder. The first goal is
                  often to calm muscle spasm, reduce inflammation, and improve daily jaw
                  comfort.
                </p>
              </div>
            </div>
          </section>

          <section class="pt-4 lg:pt-2" aria-labelledby="symptoms-heading">
            <div class="max-w-3xl" data-reveal>
              <p class="text-xs font-bold tracking-[.34em] text-secondary">
                Do you have a TMJ disorder?
              </p>
              <h2
                id="symptoms-heading"
                class="serif mt-4 text-4xl leading-tight sm:text-5xl"
              >
                Jaw pain, clicking, stiffness, and bite changes are useful clues.
              </h2>
              <p class="mt-6 text-base leading-7 text-muted">
                The more symptoms you recognize, the more helpful it may be to have the
                joint, bite, and chewing muscles evaluated.
              </p>
            </div>

            <div class="mt-12 grid gap-6 lg:grid-cols-2 lg:gap-7">
              {
                tmjSignals.map(({ number, title, body }, index) => (
                  <article
                    class="rounded-lg border border-line bg-surface p-8 shadow-sm sm:p-9 lg:p-10"
                    data-reveal
                    style={`--reveal-delay: ${(index % 2) * 80}ms`}
                  >
                    <div class="flex h-10 w-10 items-center justify-center rounded-full bg-aqua-pale text-sm font-bold text-secondary">
                      {number}
                    </div>
                    <h3 class="serif mt-6 text-2xl font-bold text-foreground">
                      {title}
                    </h3>
                    <p class="mt-4 text-base leading-7 text-muted">{body}</p>
                  </article>
                ))
              }
            </div>
          </section>

          <section
            class="grid gap-10 rounded-lg bg-aqua-soft p-8 sm:p-10 lg:grid-cols-[minmax(0,1fr)_280px] lg:items-center lg:p-12"
            aria-labelledby="self-care-heading"
            data-reveal
          >
            <div>
              <p class="text-xs font-bold tracking-[.34em] text-secondary">
                Self-care and support
              </p>
              <h2
                id="self-care-heading"
                class="serif mt-4 text-4xl leading-tight sm:text-5xl"
              >
                Simple habits can reduce strain while treatment takes effect.
              </h2>
              <p class="mt-6 text-base leading-7 text-muted">
                Treatment may include medication, anti-inflammatory support, injections,
                physical therapy, stress management, or an appliance depending on the
                diagnosis.
              </p>
            </div>
            <div class="grid gap-3 text-sm font-bold text-foreground">
              {selfCare.map((item) => (
                <p class="rounded-md bg-surface px-4 py-3">{item}</p>
              ))}
            </div>
          </section>

          <section class="grid gap-8 md:grid-cols-2">
            <article class="rounded-lg border border-line bg-surface p-8 shadow-sm sm:p-9 lg:p-10" data-reveal>
              <p class="text-xs font-bold tracking-[.28em] text-secondary">
                Splints and night guards
              </p>
              <h2 class="serif mt-5 text-3xl leading-tight text-foreground">
                Appliances can relax muscles and protect the joint.
              </h2>
              <p class="mt-6 text-base leading-7 text-muted">
                A clear plastic splint or night guard fits over the teeth to help keep
                them apart, reduce clenching or grinding, protect tooth wear, and lower
                muscle tension.
              </p>
            </article>

            <article
              class="rounded-lg border border-line bg-surface p-8 shadow-sm sm:p-9 lg:p-10"
              data-reveal
              style="--reveal-delay: 120ms"
            >
              <p class="text-xs font-bold tracking-[.28em] text-secondary">
                Bite correction or surgery
              </p>
              <h2 class="serif mt-5 text-3xl leading-tight text-foreground">
                More involved care is reserved for specific cases.
              </h2>
              <p class="mt-6 text-base leading-7 text-muted">
                If TMJ problems affect how teeth fit together, bite adjustment,
                orthodontics, restorative work, or jaw reconstruction may be discussed.
                Surgery is usually reserved for severe cases that do not respond to
                appliance therapy or involve significant joint problems.
              </p>
            </article>
          </section>

          <section class="rounded-lg bg-midnight px-8 py-12 text-surface sm:px-10 lg:px-12 lg:py-14">
            <div class="grid gap-8 lg:grid-cols-[minmax(0,1fr)_auto] lg:items-center">
              <div data-reveal>
                <p class="text-xs font-bold tracking-[.34em] text-secondary">
                  Healthier jaw function
                </p>
                <h2 class="serif mt-4 text-4xl leading-tight sm:text-5xl">
                  Start with a TMJ evaluation.
                </h2>
                <p class="mt-5 max-w-[660px] text-base leading-7 text-surface/75">
                  We will listen to your symptoms, evaluate your jaw function, and
                  explain which treatment options may help you feel more comfortable.
                </p>
              </div>
              <div
                class="flex flex-col gap-3 sm:flex-row lg:flex-col"
                data-reveal
                style="--reveal-delay: 120ms"
              >
                <a
                  href="/#appointment"
                  class="inline-flex h-14 items-center justify-center rounded-md bg-secondary px-7 font-bold text-surface transition-opacity hover:opacity-90"
                >
                  Request Appointment
                </a>
                <a
                  href="tel:7852720444"
                  class="inline-flex h-14 items-center justify-center rounded-md border border-surface/40 px-7 font-bold text-surface transition-colors hover:bg-surface/10"
                >
                  Call (785) 272-0444
                </a>
              </div>
            </div>
          </section>
        </div>

        <div class="hidden min-[1400px]:block" aria-hidden="true"></div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
