---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import ServiceSidebar from "../../components/ServiceSidebar.astro";

const title = "Nitrous Oxide | Laughing Gas | Topeka, KS";
const description =
  "Learn about nitrous oxide sedation, also known as laughing gas, including how it works, advantages, recovery, and when it may not be recommended.";

const currentHref = "/services/nitrous-oxide/";

const advantages = [
  {
    number: "01",
    title: "Adjustable relaxation",
    body: "The depth of sedation can be increased or decreased during the visit, giving the team control over your comfort level.",
  },
  {
    number: "02",
    title: "Rapid effect",
    body: "Nitrous oxide reaches the brain quickly, and its relaxing and pain-controlling effects can develop within just a few minutes.",
  },
  {
    number: "03",
    title: "No lingering hangover",
    body: "The effects wear off quickly after the gas is stopped, so patients usually do not feel a lingering sedated effect afterward.",
  },
  {
    number: "04",
    title: "Helpful for gagging",
    body: "Inhalation sedation can be very effective for minimizing gagging during dental or oral surgery treatment.",
  },
];

const considerations = [
  "COPD",
  "Emphysema",
  "Chest or breathing difficulties",
  "Multiple sclerosis",
  "A cold or congestion",
];
---

<Layout title={title} description={description} ogImage="/images/specialized-care.jpg">
  <Header />
  <main>
    <section class="bg-midnight text-surface" aria-labelledby="service-heading">
      <div
        class="mx-auto grid min-h-[calc(100dvh-76px)] max-w-7xl items-center gap-14 px-5 py-14 lg:grid-cols-[minmax(0,610px)_minmax(380px,500px)] lg:px-0"
      >
        <div data-reveal>
          <a
            href="/#procedures"
            class="inline-flex text-sm font-bold text-accent transition-colors hover:text-surface"
          >
            ← Services
          </a>
          <p class="mt-10 text-xs font-bold uppercase tracking-[.34em] text-secondary">
            Procedures
          </p>
          <h1
            id="service-heading"
            class="serif mt-5 max-w-[760px] text-5xl leading-[0.96] text-surface sm:text-6xl lg:text-[72px]"
          >
            Nitrous oxide.
          </h1>
          <p class="mt-7 max-w-[590px] text-lg leading-8 text-surface/75 sm:text-xl">
            Nitrous oxide, often called laughing gas, is a sweet-smelling, non-irritating
            gas used to help patients feel relaxed while remaining conscious and in
            control during treatment.
          </p>
          <div class="mt-9 flex flex-col gap-3 sm:flex-row">
            <a
              href="/#appointment"
              class="inline-flex h-14 items-center justify-center rounded-md bg-secondary px-7 font-bold text-surface transition-opacity hover:opacity-90 sm:min-w-[223px]"
            >
              Request Appointment
            </a>
            <a
              href="tel:7852720444"
              class="inline-flex h-14 items-center justify-center rounded-md border border-surface/40 px-7 font-bold text-surface transition-colors hover:bg-surface/10 sm:min-w-[216px]"
            >
              Call (785) 272-0444
            </a>
          </div>
        </div>

        <div
          class="relative mx-auto w-full max-w-[500px] lg:mx-0"
          data-reveal
          style="--reveal-delay: 120ms"
        >
          <div
            class="absolute -bottom-3 left-3 right-[-12px] top-3 rounded-lg border border-secondary"
            aria-hidden="true"
          >
          </div>
          <div class="relative aspect-[4/5] overflow-hidden rounded-lg bg-surface/5">
            <img
              src="/images/specialized-care.jpg"
              alt="Oral surgery equipment used during nitrous oxide sedation planning"
              class="h-full w-full object-cover object-center"
              width="5184"
              height="3456"
              loading="eager"
              decoding="async"
              fetchpriority="high"
            />
          </div>
        </div>
      </div>
    </section>

    <section class="bg-background py-20 text-foreground lg:py-24">
      <div
        class="mx-auto grid max-w-[1600px] gap-10 px-5 lg:grid-cols-[minmax(0,1fr)_minmax(0,920px)_minmax(0,1fr)] lg:items-start lg:gap-12"
      >
        <ServiceSidebar groupLabel="Procedures" currentHref={currentHref} />

        <div class="grid gap-20 lg:col-start-2 lg:gap-24">
          <section class="pb-2 lg:pb-0" aria-labelledby="overview-heading">
            <div class="max-w-5xl" data-reveal>
              <p class="text-xs font-bold uppercase tracking-[.34em] text-secondary">
                Laughing Gas
              </p>
              <h2
                id="overview-heading"
                class="serif mt-4 text-4xl leading-tight sm:text-5xl"
              >
                Nitrous oxide helps take the edge off while you stay awake.
              </h2>
              <div class="mt-7 space-y-6 text-base leading-8 text-muted">
                <p>
                  Nitrous oxide has been used as a primary means of sedation in
                  dentistry for many years. It is breathed through a nasal mask as a
                  mixture of nitrous oxide and oxygen.
                </p>
                <p>
                  Patients are able to breathe on their own and remain in control of
                  bodily functions. Some patients feel calm and light, some may feel
                  drowsy, and mild amnesia can occur.
                </p>
                <p>
                  The mixture includes oxygen, and the level of nitrous oxide can be
                  adjusted during the appointment to match the desired relaxation level.
                </p>
              </div>

              <div class="mt-8 rounded-lg border border-line bg-surface p-7 shadow-sm sm:p-8">
                <p class="text-xs font-bold uppercase tracking-[.28em] text-secondary">
                  Quick recovery
                </p>
                <p class="mt-3 text-base leading-7 text-muted">
                  Nitrous oxide works rapidly and wears off quickly once the gas is
                  stopped, which is one reason many patients appreciate it for lighter
                  sedation needs.
                </p>
              </div>
            </div>
          </section>

          <section class="pt-4 lg:pt-2" aria-labelledby="advantages-heading">
            <div class="max-w-3xl" data-reveal>
              <p class="text-xs font-bold uppercase tracking-[.34em] text-secondary">
                Advantages
              </p>
              <h2
                id="advantages-heading"
                class="serif mt-4 text-4xl leading-tight sm:text-5xl"
              >
                The experience is flexible, fast, and easy to adjust.
              </h2>
              <p class="mt-6 text-base leading-7 text-muted">
                Nitrous oxide may be used for simple procedures or as part of a broader
                anesthesia plan, depending on the treatment and patient comfort.
              </p>
            </div>

            <div class="mt-12 grid gap-6 lg:grid-cols-2 lg:gap-7">
              {
                advantages.map(({ number, title, body }, index) => (
                  <article
                    class="rounded-lg border border-line bg-surface p-8 shadow-sm sm:p-9 lg:p-10"
                    data-reveal
                    style={`--reveal-delay: ${(index % 2) * 80}ms`}
                  >
                    <div class="flex h-10 w-10 items-center justify-center rounded-full bg-aqua-pale text-sm font-bold text-secondary">
                      {number}
                    </div>
                    <h3 class="serif mt-6 text-2xl font-bold text-foreground">
                      {title}
                    </h3>
                    <p class="mt-4 text-base leading-7 text-muted">{body}</p>
                  </article>
                ))
              }
            </div>
          </section>

          <section
            class="grid gap-10 rounded-lg bg-aqua-soft p-8 sm:p-10 lg:grid-cols-[minmax(0,1fr)_280px] lg:items-center lg:p-12"
            aria-labelledby="considerations-heading"
            data-reveal
          >
            <div>
              <p class="text-xs font-bold uppercase tracking-[.34em] text-secondary">
                When to Discuss Alternatives
              </p>
              <h2
                id="considerations-heading"
                class="serif mt-4 text-4xl leading-tight sm:text-5xl"
              >
                Breathing conditions may change whether nitrous oxide is appropriate.
              </h2>
              <p class="mt-6 text-base leading-7 text-muted">
                Nitrous oxide is not recommended for patients diagnosed with chronic
                obstructive pulmonary disease. Other breathing or medical concerns
                should be reviewed before treatment.
              </p>
            </div>
            <div class="grid gap-3 text-sm font-bold text-foreground">
              {considerations.map((item) => (
                <p class="rounded-md bg-surface px-4 py-3">{item}</p>
              ))}
            </div>
          </section>

          <section class="grid gap-8 md:grid-cols-2">
            <article class="rounded-lg border border-line bg-surface p-8 shadow-sm sm:p-9 lg:p-10" data-reveal>
              <p class="text-xs font-bold uppercase tracking-[.28em] text-secondary">
                Five-Minute Trial
              </p>
              <h2 class="serif mt-5 text-3xl leading-tight text-foreground">
                You can ask how it feels before committing.
              </h2>
              <p class="mt-6 text-base leading-7 text-muted">
                If you are unsure about nitrous oxide, ask whether a short trial is
                appropriate so you can experience the sensation before proceeding with
                this sedation method.
              </p>
            </article>

            <article
              class="rounded-lg border border-line bg-surface p-8 shadow-sm sm:p-9 lg:p-10"
              data-reveal
              style="--reveal-delay: 120ms"
            >
              <p class="text-xs font-bold uppercase tracking-[.28em] text-secondary">
                Conscious Sedation
              </p>
              <h2 class="serif mt-5 text-3xl leading-tight text-foreground">
                You remain awake and responsive.
              </h2>
              <p class="mt-6 text-base leading-7 text-muted">
                Nitrous oxide is designed to relax you, not fully put you to sleep. You
                can still breathe independently and respond to instructions during the
                appointment.
              </p>
            </article>
          </section>

          <section class="rounded-lg bg-midnight px-8 py-12 text-surface sm:px-10 lg:px-12 lg:py-14">
            <div class="grid gap-8 lg:grid-cols-[minmax(0,1fr)_auto] lg:items-center">
              <div data-reveal>
                <p class="text-xs font-bold uppercase tracking-[.34em] text-secondary">
                  Calm, Conscious Comfort
                </p>
                <h2 class="serif mt-4 text-4xl leading-tight sm:text-5xl">
                  Ask if nitrous oxide fits your visit.
                </h2>
                <p class="mt-5 max-w-[660px] text-base leading-7 text-surface/75">
                  We will review your health history, procedure, and comfort goals to
                  decide whether nitrous oxide is a good option.
                </p>
              </div>
              <div
                class="flex flex-col gap-3 sm:flex-row lg:flex-col"
                data-reveal
                style="--reveal-delay: 120ms"
              >
                <a
                  href="/#appointment"
                  class="inline-flex h-14 items-center justify-center rounded-md bg-secondary px-7 font-bold text-surface transition-opacity hover:opacity-90"
                >
                  Request Appointment
                </a>
                <a
                  href="tel:7852720444"
                  class="inline-flex h-14 items-center justify-center rounded-md border border-surface/40 px-7 font-bold text-surface transition-colors hover:bg-surface/10"
                >
                  Call (785) 272-0444
                </a>
              </div>
            </div>
          </section>
        </div>

        <div class="hidden lg:block" aria-hidden="true"></div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
