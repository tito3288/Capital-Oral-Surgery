---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import ServiceSidebar from "../../components/ServiceSidebar.astro";

const title =
  "Single Tooth Implant | Dental Implant Placement in Topeka, KS | Capital Oral Surgery";
const description =
  "Learn how single tooth dental implants are placed, what healing looks like, and when implants may be recommended at Capital Oral Surgery in Topeka, KS.";

const currentHref = "/services/single-tooth-implant/";

const placementSteps = [
  {
    number: "01",
    title: "Planning",
    body: "Your surgeon reviews your health history, imaging, bone anatomy, and comfort options before surgery. Antibiotics, IV sedation, nitrous oxide, and local anesthesia may be discussed at your consultation.",
  },
  {
    number: "02",
    title: "Numbing and comfort",
    body: "A local anesthetic is used to numb the area where the implant will be placed. The goal is a calm, precise visit with your comfort clearly planned before treatment begins.",
  },
  {
    number: "03",
    title: "Implant placement",
    body: "Once you are comfortable, the surgeon makes a small incision in the gum tissue, prepares the space with specialized instruments, and gently places the titanium implant into the bone.",
  },
  {
    number: "04",
    title: "Healing",
    body: "In some cases the top of the implant remains visible through the gum. In other cases, it is better for early healing to have the implant covered by the gum tissue.",
  },
];

const implantSequence = [
  "Tooth loss",
  "Healed bone",
  "Implant placed",
  "Healing",
  "Implant restored",
];
---

<Layout title={title} description={description} ogImage="/images/specialized-care.jpg">
  <Header />
  <main>
    <section class="bg-midnight text-surface" aria-labelledby="service-heading">
      <div
        class="mx-auto grid min-h-[calc(100dvh-76px)] max-w-7xl items-center gap-10 px-5 py-14 lg:gap-14 xl:grid-cols-[minmax(0,610px)_minmax(360px,500px)] xl:justify-between xl:px-0"
      >
        <div data-reveal>
          <a
            href="/#procedures"
            class="inline-flex text-sm font-bold text-accent transition-colors hover:text-surface"
          >
            ← Services
          </a>
          <p class="mt-10 text-xs font-bold tracking-[.34em] text-secondary">
            Dental implants
          </p>
          <h1
            id="service-heading"
            class="serif mt-5 max-w-[720px] text-5xl leading-[0.96] text-surface sm:text-6xl xl:text-[72px]"
          >
            Single tooth implant.
          </h1>
          <p class="mt-7 max-w-[590px] text-lg leading-8 text-surface/75 sm:text-xl">
            A single dental implant can replace one missing tooth with a stable,
            natural-feeling foundation. Our surgeons plan each placement carefully,
            focusing on comfort, precision, healing, and long-term support for your
            final crown.
          </p>
          <div class="mt-9 flex flex-col gap-3 sm:flex-row">
            <a
              href="/#appointment"
              class="inline-flex h-14 items-center justify-center rounded-md bg-secondary px-7 font-bold text-surface transition-opacity hover:opacity-90 sm:min-w-[223px]"
            >
              Request Appointment
            </a>
            <a
              href="tel:7852720444"
              class="inline-flex h-14 items-center justify-center rounded-md border border-surface/40 px-7 font-bold text-surface transition-colors hover:bg-surface/10 sm:min-w-[216px]"
            >
              Call (785) 272-0444
            </a>
          </div>
        </div>

        <div
          class="relative mx-auto w-full max-w-[500px] lg:mx-0"
          data-reveal
          style="--reveal-delay: 120ms"
        >
          <div
            class="absolute -bottom-3 left-3 right-[-12px] top-3 rounded-lg border border-secondary"
            aria-hidden="true"
          >
          </div>
          <div class="relative aspect-[4/5] overflow-hidden rounded-lg bg-surface/5">
            <img
              src="/images/specialized-care.jpg"
              alt="3D dental imaging equipment used for oral surgery planning"
              class="h-full w-full object-cover object-center"
              width="5184"
              height="3456"
              loading="eager"
              decoding="async"
              fetchpriority="high"
            />
          </div>
        </div>
      </div>
    </section>

    <section class="bg-background py-20 text-foreground lg:py-24">
      <div
        class="mx-auto grid max-w-[920px] gap-10 px-5 min-[1400px]:max-w-[1400px] min-[1400px]:grid-cols-[220px_minmax(0,840px)_220px] min-[1400px]:items-start min-[1400px]:gap-8 min-[1700px]:max-w-[1640px] min-[1700px]:grid-cols-[280px_minmax(0,920px)_280px] min-[1700px]:gap-12"
      >
        <ServiceSidebar groupLabel="Dental implants" currentHref={currentHref} />

        <div class="grid gap-20 lg:gap-24 min-[1400px]:col-start-2">
          <section class="pb-2 lg:pb-0" aria-labelledby="placement-heading">
            <div class="max-w-5xl" data-reveal>
              <p class="text-xs font-bold tracking-[.34em] text-secondary">
                Implant placement
              </p>
              <h2
                id="placement-heading"
                class="serif mt-4 text-4xl leading-tight sm:text-5xl"
              >
                Precise treatment, planned around your comfort.
              </h2>
              <div class="mt-7 space-y-6 text-base leading-8 text-muted">
                <p>
                  Placing one dental implant often takes 30 to 60 minutes, though each
                  patient’s timing and number of appointments can vary. Your surgeon
                  brings careful attention to the details of your case before and during
                  treatment.
                </p>
                <p>
                  Before surgery, comfort options such as IV sedation or nitrous oxide
                  may be reviewed with you. A local anesthetic is also used to numb the
                  implant site.
                </p>
                <p>
                  When you are comfortable, the surgeon gently opens the gum tissue,
                  prepares the bone with specialized instruments, and places the titanium
                  implant. Depending on healing needs, the implant may be visible or
                  covered by gum tissue during the early phase.
                </p>
              </div>

              <div class="mt-8 rounded-lg border border-line bg-surface p-7 shadow-sm sm:p-8">
                <p class="text-xs font-bold tracking-[.28em] text-secondary">
                  Appointment timing
                </p>
                <p class="mt-3 text-base leading-7 text-muted">
                  Single implant placement is usually a focused visit, but complete
                  treatment includes planning, healing checks, and coordination with
                  your dentist for the final crown.
                </p>
              </div>
            </div>
          </section>

          <section class="pt-4 lg:pt-2" aria-labelledby="process-heading">
            <div class="max-w-3xl" data-reveal>
              <p class="text-xs font-bold tracking-[.34em] text-secondary">
                What to expect
              </p>
              <h2
                id="process-heading"
                class="serif mt-4 text-4xl leading-tight sm:text-5xl"
              >
                A straightforward sequence from planning to restoration.
              </h2>
              <p class="mt-6 text-base leading-7 text-muted">
                Implant treatment is a collaboration between your oral surgeon and
                restorative dentist. The surgeon places the implant and monitors
                healing; your dentist completes the visible replacement tooth.
              </p>
            </div>

            <div class="mt-12 grid gap-6 lg:grid-cols-2 lg:gap-7">
              {
                placementSteps.map(({ number, title, body }, index) => (
                  <article
                    class="rounded-lg border border-line bg-surface p-7 shadow-sm sm:p-8"
                    data-reveal
                    style={`--reveal-delay: ${(index % 2) * 80}ms`}
                  >
                    <div class="flex h-10 w-10 items-center justify-center rounded-full bg-aqua-pale text-sm font-bold text-secondary">
                      {number}
                    </div>
                    <h3 class="serif mt-6 text-2xl font-bold text-foreground">
                      {title}
                    </h3>
                    <p class="mt-4 text-base leading-7 text-muted">{body}</p>
                  </article>
                ))
              }
            </div>
          </section>

          <section
            class="grid gap-10 rounded-lg bg-aqua-soft p-8 sm:p-10 lg:grid-cols-[minmax(0,1fr)_280px] lg:items-center lg:p-12"
            aria-labelledby="healing-heading"
            data-reveal
          >
            <div>
              <p class="text-xs font-bold tracking-[.34em] text-secondary">
                Healing and follow-up
              </p>
              <h2
                id="healing-heading"
                class="serif mt-4 text-4xl leading-tight sm:text-5xl"
              >
                Healing time is personal, so follow-up matters.
              </h2>
              <p class="mt-6 text-base leading-7 text-muted">
                Healing varies from person to person based on bone quality and quantity.
                After the first healing phase, your surgeon may place an abutment or
                healing cap during a brief follow-up visit so gum tissue can mature and
                the implant can be accessed for restoration.
              </p>
            </div>
            <div class="grid gap-3 text-sm font-bold text-foreground">
              {implantSequence.map((item) => (
                <p class="rounded-md bg-surface px-4 py-3">{item}</p>
              ))}
            </div>
          </section>

          <section class="grid gap-8 md:grid-cols-2">
            <article class="rounded-lg border border-line bg-surface p-8 shadow-sm sm:p-9 lg:p-10" data-reveal>
              <p class="text-xs font-bold tracking-[.28em] text-secondary">
                Placement timing
              </p>
              <h2 class="serif mt-5 text-3xl leading-tight text-foreground">
                When are implants placed?
              </h2>
              <p class="mt-6 text-base leading-7 text-muted">
                Implants are often placed several months after extraction. In some
                cases, an implant can be placed immediately after a tooth is removed,
                though infection or bone concerns may make immediate placement a poor
                fit.
              </p>
            </article>

            <article
              class="rounded-lg border border-line bg-surface p-8 shadow-sm sm:p-9 lg:p-10"
              data-reveal
              style="--reveal-delay: 120ms"
            >
              <p class="text-xs font-bold tracking-[.28em] text-secondary">
                Implant count
              </p>
              <h2 class="serif mt-5 text-3xl leading-tight text-foreground">
                How many implants do I need?
              </h2>
              <p class="mt-6 text-base leading-7 text-muted">
                Most often, one implant is placed for each missing tooth. Larger back
                teeth may need a different plan because they naturally have multiple
                roots, and additional options exist when most or all teeth are missing.
              </p>
            </article>
          </section>

          <section class="rounded-lg bg-midnight px-8 py-12 text-surface sm:px-10 lg:px-12 lg:py-14">
            <div class="grid gap-8 lg:grid-cols-[minmax(0,1fr)_auto] lg:items-center">
              <div data-reveal>
                <p class="text-xs font-bold tracking-[.34em] text-secondary">
                  Reclaim confidence
                </p>
                <h2 class="serif mt-4 text-4xl leading-tight sm:text-5xl">
                  Start with a consultation.
                </h2>
                <p class="mt-5 max-w-[660px] text-base leading-7 text-surface/75">
                  We will evaluate your needs, review imaging, and explain whether a
                  single tooth implant is the right path for your smile.
                </p>
              </div>
              <div
                class="flex flex-col gap-3 sm:flex-row lg:flex-col"
                data-reveal
                style="--reveal-delay: 120ms"
              >
                <a
                  href="/#appointment"
                  class="inline-flex h-14 items-center justify-center rounded-md bg-secondary px-7 font-bold text-surface transition-opacity hover:opacity-90"
                >
                  Request Appointment
                </a>
                <a
                  href="tel:7852720444"
                  class="inline-flex h-14 items-center justify-center rounded-md border border-surface/40 px-7 font-bold text-surface transition-colors hover:bg-surface/10"
                >
                  Call (785) 272-0444
                </a>
              </div>
            </div>
          </section>
        </div>

        <div class="hidden min-[1400px]:block" aria-hidden="true"></div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
