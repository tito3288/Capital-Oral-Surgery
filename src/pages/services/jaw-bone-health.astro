---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import ServiceSidebar from "../../components/ServiceSidebar.astro";

const title = "Jaw Bone Health | Topeka, KS | Capital Oral Surgery";
const description =
  "Learn why jaw bone health matters, how teeth help preserve bone, and how bone grafting can support future tooth replacement options.";

const currentHref = "/services/jaw-bone-health/";

const healthFactors = [
  {
    number: "01",
    title: "Tooth-root stimulation",
    body: "Natural tooth roots stimulate the surrounding jawbone during chewing. That stimulation helps the bone maintain its height, width, and density.",
  },
  {
    number: "02",
    title: "Timely tooth replacement",
    body: "When a tooth is missing, the bone no longer receives the same signal to stay strong. Earlier evaluation can help preserve more replacement options.",
  },
  {
    number: "03",
    title: "Healthy gums and support",
    body: "Periodontal disease can damage the structures that hold teeth in place, including the bone around them. Treating infection helps protect the jaw.",
  },
  {
    number: "04",
    title: "Restorative planning",
    body: "Dental implants can help restore function while giving the jawbone helpful stimulation again, but they need enough healthy bone for support.",
  },
];

const boneLossCauses = [
  "Missing teeth",
  "Periodontal disease",
  "Dental trauma",
  "Infection",
  "Poorly fitting dentures",
];
---

<Layout title={title} description={description} ogImage="/images/specialized-care.jpg">
  <Header />
  <main>
    <section class="bg-midnight text-surface" aria-labelledby="service-heading">
      <div
        class="mx-auto grid min-h-[calc(100dvh-76px)] max-w-7xl items-center gap-14 px-5 py-14 lg:grid-cols-[minmax(0,610px)_minmax(380px,500px)] lg:px-0"
      >
        <div data-reveal>
          <a
            href="/#procedures"
            class="inline-flex text-sm font-bold text-accent transition-colors hover:text-surface"
          >
            ← Services
          </a>
          <p class="mt-10 text-xs font-bold uppercase tracking-[.34em] text-secondary">
            Procedures
          </p>
          <h1
            id="service-heading"
            class="serif mt-5 max-w-[760px] text-5xl leading-[0.96] text-surface sm:text-6xl lg:text-[72px]"
          >
            Jaw bone health.
          </h1>
          <p class="mt-7 max-w-[590px] text-lg leading-8 text-surface/75 sm:text-xl">
            Healthy jawbone supports your teeth, bite, facial structure, and future
            replacement options. When bone begins to shrink, bone grafting and implant
            planning can help restore a stronger foundation.
          </p>
          <div class="mt-9 flex flex-col gap-3 sm:flex-row">
            <a
              href="/#appointment"
              class="inline-flex h-14 items-center justify-center rounded-md bg-secondary px-7 font-bold text-surface transition-opacity hover:opacity-90 sm:min-w-[223px]"
            >
              Request Appointment
            </a>
            <a
              href="tel:7852720444"
              class="inline-flex h-14 items-center justify-center rounded-md border border-surface/40 px-7 font-bold text-surface transition-colors hover:bg-surface/10 sm:min-w-[216px]"
            >
              Call (785) 272-0444
            </a>
          </div>
        </div>

        <div
          class="relative mx-auto w-full max-w-[500px] lg:mx-0"
          data-reveal
          style="--reveal-delay: 120ms"
        >
          <div
            class="absolute -bottom-3 left-3 right-[-12px] top-3 rounded-lg border border-secondary"
            aria-hidden="true"
          >
          </div>
          <div class="relative aspect-[4/5] overflow-hidden rounded-lg bg-surface/5">
            <img
              src="/images/specialized-care.jpg"
              alt="Dental imaging equipment used to evaluate jaw bone health"
              class="h-full w-full object-cover object-center"
              width="5184"
              height="3456"
              loading="eager"
              decoding="async"
              fetchpriority="high"
            />
          </div>
        </div>
      </div>
    </section>

    <section class="bg-background py-20 text-foreground lg:py-24">
      <div
        class="mx-auto grid max-w-[1600px] gap-10 px-5 lg:grid-cols-[minmax(0,1fr)_minmax(0,920px)_minmax(0,1fr)] lg:items-start lg:gap-12"
      >
        <ServiceSidebar groupLabel="Procedures" currentHref={currentHref} />

        <div class="grid gap-20 lg:col-start-2 lg:gap-24">
          <section class="pb-2 lg:pb-0" aria-labelledby="importance-heading">
            <div class="max-w-5xl" data-reveal>
              <p class="text-xs font-bold uppercase tracking-[.34em] text-secondary">
                Why Bone Health Matters
              </p>
              <h2
                id="importance-heading"
                class="serif mt-4 text-4xl leading-tight sm:text-5xl"
              >
                The jawbone stays strongest when it has healthy teeth to support.
              </h2>
              <div class="mt-7 space-y-6 text-base leading-8 text-muted">
                <p>
                  Natural teeth are anchored in the jawbone. Every time you chew, the
                  roots send small forces into the bone and help tell the body to keep
                  that bone dense and useful.
                </p>
                <p>
                  When a tooth is lost, that stimulation disappears. Over time, the bone
                  in that area can shrink or change shape, which may make future tooth
                  replacement more complex.
                </p>
                <p>
                  Protecting jawbone health is one reason oral surgeons evaluate
                  missing teeth, infection, gum disease, and implant options with care.
                </p>
              </div>

              <div class="mt-8 rounded-lg border border-line bg-surface p-7 shadow-sm sm:p-8">
                <p class="text-xs font-bold uppercase tracking-[.28em] text-secondary">
                  Early evaluation helps
                </p>
                <p class="mt-3 text-base leading-7 text-muted">
                  The sooner bone loss is identified, the more options there may be for
                  preserving bone, rebuilding support, and planning a stable
                  restoration.
                </p>
              </div>
            </div>
          </section>

          <section class="pt-4 lg:pt-2" aria-labelledby="factors-heading">
            <div class="max-w-3xl" data-reveal>
              <p class="text-xs font-bold uppercase tracking-[.34em] text-secondary">
                What Keeps Bone Strong
              </p>
              <h2
                id="factors-heading"
                class="serif mt-4 text-4xl leading-tight sm:text-5xl"
              >
                Bone health depends on stimulation, stability, and infection control.
              </h2>
              <p class="mt-6 text-base leading-7 text-muted">
                Good planning looks at the full picture: tooth position, gum health,
                bite forces, missing teeth, and whether grafting is needed before an
                implant can be placed safely.
              </p>
            </div>

            <div class="mt-12 grid gap-6 lg:grid-cols-2 lg:gap-7">
              {
                healthFactors.map(({ number, title, body }, index) => (
                  <article
                    class="rounded-lg border border-line bg-surface p-8 shadow-sm sm:p-9 lg:p-10"
                    data-reveal
                    style={`--reveal-delay: ${(index % 2) * 80}ms`}
                  >
                    <div class="flex h-10 w-10 items-center justify-center rounded-full bg-aqua-pale text-sm font-bold text-secondary">
                      {number}
                    </div>
                    <h3 class="serif mt-6 text-2xl font-bold text-foreground">
                      {title}
                    </h3>
                    <p class="mt-4 text-base leading-7 text-muted">{body}</p>
                  </article>
                ))
              }
            </div>
          </section>

          <section
            class="grid gap-10 rounded-lg bg-aqua-soft p-8 sm:p-10 lg:grid-cols-[minmax(0,1fr)_280px] lg:items-center lg:p-12"
            aria-labelledby="causes-heading"
            data-reveal
          >
            <div>
              <p class="text-xs font-bold uppercase tracking-[.34em] text-secondary">
                Bone Loss Risks
              </p>
              <h2
                id="causes-heading"
                class="serif mt-4 text-4xl leading-tight sm:text-5xl"
              >
                Several oral health problems can reduce jawbone volume.
              </h2>
              <p class="mt-6 text-base leading-7 text-muted">
                Bone loss is often gradual, which means patients may not notice it right
                away. Imaging helps show whether the jaw has enough support for the
                treatment being planned.
              </p>
            </div>
            <div class="grid gap-3 text-sm font-bold text-foreground">
              {boneLossCauses.map((item) => (
                <p class="rounded-md bg-surface px-4 py-3">{item}</p>
              ))}
            </div>
          </section>

          <section class="grid gap-8 md:grid-cols-2">
            <article class="rounded-lg border border-line bg-surface p-8 shadow-sm sm:p-9 lg:p-10" data-reveal>
              <p class="text-xs font-bold uppercase tracking-[.28em] text-secondary">
                Bone Grafting
              </p>
              <h2 class="serif mt-5 text-3xl leading-tight text-foreground">
                Grafting can rebuild areas that have thinned.
              </h2>
              <p class="mt-6 text-base leading-7 text-muted">
                When bone has resorbed, grafting material can be placed to encourage new
                bone formation. The goal is to create healthier height, width, and
                density for future treatment.
              </p>
            </article>

            <article
              class="rounded-lg border border-line bg-surface p-8 shadow-sm sm:p-9 lg:p-10"
              data-reveal
              style="--reveal-delay: 120ms"
            >
              <p class="text-xs font-bold uppercase tracking-[.28em] text-secondary">
                Dental Implants
              </p>
              <h2 class="serif mt-5 text-3xl leading-tight text-foreground">
                Implants can help restore healthy function.
              </h2>
              <p class="mt-6 text-base leading-7 text-muted">
                Dental implants can replace tooth roots and support crowns, bridges, or
                dentures. They are planned around the amount and quality of bone
                available.
              </p>
            </article>
          </section>

          <section class="rounded-lg bg-midnight px-8 py-12 text-surface sm:px-10 lg:px-12 lg:py-14">
            <div class="grid gap-8 lg:grid-cols-[minmax(0,1fr)_auto] lg:items-center">
              <div data-reveal>
                <p class="text-xs font-bold uppercase tracking-[.34em] text-secondary">
                  Protect Your Options
                </p>
                <h2 class="serif mt-4 text-4xl leading-tight sm:text-5xl">
                  Let us evaluate your jawbone health.
                </h2>
                <p class="mt-5 max-w-[660px] text-base leading-7 text-surface/75">
                  We can review your imaging, explain what has changed, and recommend
                  the next step for preserving or rebuilding support.
                </p>
              </div>
              <div
                class="flex flex-col gap-3 sm:flex-row lg:flex-col"
                data-reveal
                style="--reveal-delay: 120ms"
              >
                <a
                  href="/#appointment"
                  class="inline-flex h-14 items-center justify-center rounded-md bg-secondary px-7 font-bold text-surface transition-opacity hover:opacity-90"
                >
                  Request Appointment
                </a>
                <a
                  href="tel:7852720444"
                  class="inline-flex h-14 items-center justify-center rounded-md border border-surface/40 px-7 font-bold text-surface transition-colors hover:bg-surface/10"
                >
                  Call (785) 272-0444
                </a>
              </div>
            </div>
          </section>
        </div>

        <div class="hidden lg:block" aria-hidden="true"></div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
