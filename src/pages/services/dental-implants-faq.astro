---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import ServiceSidebar from "../../components/ServiceSidebar.astro";

const title =
  "Dental Implants FAQ | Topeka, KS | Capital Oral Surgery";
const description =
  "Answers to common dental implant questions about longevity, recovery, pain, bone grafting, treatment timing, cost, and choosing an oral surgery team.";

const currentHref = "/services/dental-implants-faq/";

const faqCards = [
  {
    number: "01",
    title: "How long do dental implants last?",
    body: "Titanium implants are designed to integrate with the jawbone and can last a very long time. The visible restorations, such as crowns or fixed dentures, may eventually need repair or replacement.",
  },
  {
    number: "02",
    title: "Will i miss work?",
    body: "Some patients return to work the next day after a single tooth implant. Patients receiving multiple implants may rest at home for two or three days before returning to normal activity.",
  },
  {
    number: "03",
    title: "Do dental implants hurt?",
    body: "The area is numbed with local anesthetic, and sedation may be used to ease anxiety. Mild pain and swelling during the first few days are commonly managed with over-the-counter medication, ice, and head elevation.",
  },
  {
    number: "04",
    title: "Will i need bone grafts?",
    body: "It depends on your jawbone health. If there is not enough width, height, or density to support implants, bone grafting may be recommended to strengthen and reshape the jawbone.",
  },
];

const quickAnswers = [
  "Single implant surgery can take as little as 30 minutes",
  "Multiple implants may take several hours",
  "Typical healing before restoration is three to four months",
  "Immediate implants may reduce the wait to six to eight weeks",
  "Cost and treatment time vary by patient",
];
---

<Layout title={title} description={description} ogImage="/images/specialized-care.jpg">
  <Header />
  <main>
    <section class="bg-midnight text-surface" aria-labelledby="service-heading">
      <div
        class="mx-auto grid min-h-[calc(100dvh-76px)] max-w-7xl items-center gap-10 px-5 py-14 lg:gap-14 xl:grid-cols-[minmax(0,610px)_minmax(360px,500px)] xl:justify-between xl:px-0"
      >
        <div data-reveal>
          <a
            href="/#procedures"
            class="inline-flex text-sm font-bold text-accent transition-colors hover:text-surface"
          >
            ← Services
          </a>
          <p class="mt-10 text-xs font-bold tracking-[.34em] text-secondary">
            Dental implants
          </p>
          <h1
            id="service-heading"
            class="serif mt-5 max-w-[760px] text-5xl leading-[0.96] text-surface sm:text-6xl xl:text-[72px]"
          >
            Dental implants FAQ.
          </h1>
          <p class="mt-7 max-w-[590px] text-lg leading-8 text-surface/75 sm:text-xl">
            Dental implant treatment raises good questions about comfort, timing,
            healing, cost, and long-term success. These answers help you understand
            what to expect before your consultation.
          </p>
          <div class="mt-9 flex flex-col gap-3 sm:flex-row">
            <a
              href="/#appointment"
              class="inline-flex h-14 items-center justify-center rounded-md bg-secondary px-7 font-bold text-surface transition-opacity hover:opacity-90 sm:min-w-[223px]"
            >
              Request Appointment
            </a>
            <a
              href="tel:7852720444"
              class="inline-flex h-14 items-center justify-center rounded-md border border-surface/40 px-7 font-bold text-surface transition-colors hover:bg-surface/10 sm:min-w-[216px]"
            >
              Call (785) 272-0444
            </a>
          </div>
        </div>

        <div
          class="relative mx-auto w-full max-w-[500px] lg:mx-0"
          data-reveal
          style="--reveal-delay: 120ms"
        >
          <div
            class="absolute -bottom-3 left-3 right-[-12px] top-3 rounded-lg border border-secondary"
            aria-hidden="true"
          >
          </div>
          <div class="relative aspect-[4/5] overflow-hidden rounded-lg bg-surface/5">
            <img
              src="/images/specialized-care.jpg"
              alt="3D dental imaging equipment used for dental implant planning"
              class="h-full w-full object-cover object-center"
              width="5184"
              height="3456"
              loading="eager"
              decoding="async"
              fetchpriority="high"
            />
          </div>
        </div>
      </div>
    </section>

    <section class="bg-background py-20 text-foreground lg:py-24">
      <div
        class="mx-auto grid max-w-[920px] gap-10 px-5 min-[1400px]:max-w-[1400px] min-[1400px]:grid-cols-[220px_minmax(0,840px)_220px] min-[1400px]:items-start min-[1400px]:gap-8 min-[1700px]:max-w-[1640px] min-[1700px]:grid-cols-[280px_minmax(0,920px)_280px] min-[1700px]:gap-12"
      >
        <ServiceSidebar groupLabel="Dental implants" currentHref={currentHref} />

        <div class="grid gap-20 lg:gap-24 min-[1400px]:col-start-2">
          <section class="pb-2 lg:pb-0" aria-labelledby="faq-intro-heading">
            <div class="max-w-5xl" data-reveal>
              <p class="text-xs font-bold tracking-[.34em] text-secondary">
                Frequently asked questions
              </p>
              <h2
                id="faq-intro-heading"
                class="serif mt-4 text-4xl leading-tight sm:text-5xl"
              >
                Clear answers help you feel ready for implant treatment.
              </h2>
              <div class="mt-7 space-y-6 text-base leading-8 text-muted">
                <p>
                  Our oral surgeons use current technology, careful planning, and high
                  quality materials to support precise implant placement and natural
                  looking results.
                </p>
                <p>
                  Many doctors refer complex dental implant cases to our office because
                  implant care requires training, judgment, and experience. We want you
                  to understand your options before making a decision.
                </p>
                <p>
                  A consultation is still the best way to answer questions specific to
                  your health, jawbone, number of missing teeth, timeline, and budget.
                </p>
              </div>

              <div class="mt-8 rounded-lg border border-line bg-surface p-7 shadow-sm sm:p-8">
                <p class="text-xs font-bold tracking-[.28em] text-secondary">
                  Why choose a specialist?
                </p>
                <p class="mt-3 text-base leading-7 text-muted">
                  Implant placement can become complex when bone loss, multiple missing
                  teeth, or medical considerations are involved. A specialist team can
                  plan for precision, comfort, and long-term stability.
                </p>
              </div>
            </div>
          </section>

          <section class="pt-4 lg:pt-2" aria-labelledby="faq-heading">
            <div class="max-w-3xl" data-reveal>
              <p class="text-xs font-bold tracking-[.34em] text-secondary">
                Patient questions
              </p>
              <h2
                id="faq-heading"
                class="serif mt-4 text-4xl leading-tight sm:text-5xl"
              >
                The questions patients ask most before implant surgery.
              </h2>
              <p class="mt-6 text-base leading-7 text-muted">
                These answers cover longevity, work recovery, pain, swelling, and when
                grafting may be needed before implant treatment.
              </p>
            </div>

            <div class="mt-12 grid gap-6 lg:grid-cols-2 lg:gap-7">
              {
                faqCards.map(({ number, title, body }, index) => (
                  <article
                    class="rounded-lg border border-line bg-surface p-8 shadow-sm sm:p-9 lg:p-10"
                    data-reveal
                    style={`--reveal-delay: ${(index % 2) * 80}ms`}
                  >
                    <div class="flex h-10 w-10 items-center justify-center rounded-full bg-aqua-pale text-sm font-bold text-secondary">
                      {number}
                    </div>
                    <h3 class="serif mt-6 text-2xl font-bold text-foreground">
                      {title}
                    </h3>
                    <p class="mt-4 text-base leading-7 text-muted">{body}</p>
                  </article>
                ))
              }
            </div>
          </section>

          <section
            class="grid gap-10 rounded-lg bg-aqua-soft p-8 sm:p-10 lg:grid-cols-[minmax(0,1fr)_280px] lg:items-center lg:p-12"
            aria-labelledby="timing-heading"
            data-reveal
          >
            <div>
              <p class="text-xs font-bold tracking-[.34em] text-secondary">
                Treatment timing
              </p>
              <h2
                id="timing-heading"
                class="serif mt-4 text-4xl leading-tight sm:text-5xl"
              >
                The total timeline depends on surgery, healing, and restoration.
              </h2>
              <p class="mt-6 text-base leading-7 text-muted">
                Implant surgery can be quick for one tooth and longer for multiple
                implants. After surgery, the jawbone and gums usually need time to heal
                before permanent restorations are placed.
              </p>
            </div>
            <div class="grid gap-3 text-sm font-bold text-foreground">
              {quickAnswers.map((item) => (
                <p class="rounded-md bg-surface px-4 py-3">{item}</p>
              ))}
            </div>
          </section>

          <section class="grid gap-8 md:grid-cols-2">
            <article class="rounded-lg border border-line bg-surface p-8 shadow-sm sm:p-9 lg:p-10" data-reveal>
              <p class="text-xs font-bold tracking-[.28em] text-secondary">
                Cost considerations
              </p>
              <h2 class="serif mt-5 text-3xl leading-tight text-foreground">
                Are there downsides to dental implants?
              </h2>
              <p class="mt-6 text-base leading-7 text-muted">
                Dental implants can be more expensive than other tooth replacement
                options, and insurance coverage varies. They also require healing time
                before the final restoration is attached.
              </p>
            </article>

            <article
              class="rounded-lg border border-line bg-surface p-8 shadow-sm sm:p-9 lg:p-10"
              data-reveal
              style="--reveal-delay: 120ms"
            >
              <p class="text-xs font-bold tracking-[.28em] text-secondary">
                Consultation
              </p>
              <h2 class="serif mt-5 text-3xl leading-tight text-foreground">
                Your exact answer depends on your case.
              </h2>
              <p class="mt-6 text-base leading-7 text-muted">
                Your jawbone health, number of missing teeth, medical history, and
                restorative goals all affect the recommendation. A consultation helps
                clarify timing, grafting needs, cost, and next steps.
              </p>
            </article>
          </section>

          <section class="rounded-lg bg-midnight px-8 py-12 text-surface sm:px-10 lg:px-12 lg:py-14">
            <div class="grid gap-8 lg:grid-cols-[minmax(0,1fr)_auto] lg:items-center">
              <div data-reveal>
                <p class="text-xs font-bold tracking-[.34em] text-secondary">
                  Reclaim confidence
                </p>
                <h2 class="serif mt-4 text-4xl leading-tight sm:text-5xl">
                  Bring us your implant questions.
                </h2>
                <p class="mt-5 max-w-[660px] text-base leading-7 text-surface/75">
                  We will review your goals, explain your options, and help you decide
                  whether dental implants are the right solution for your smile.
                </p>
              </div>
              <div
                class="flex flex-col gap-3 sm:flex-row lg:flex-col"
                data-reveal
                style="--reveal-delay: 120ms"
              >
                <a
                  href="/#appointment"
                  class="inline-flex h-14 items-center justify-center rounded-md bg-secondary px-7 font-bold text-surface transition-opacity hover:opacity-90"
                >
                  Request Appointment
                </a>
                <a
                  href="tel:7852720444"
                  class="inline-flex h-14 items-center justify-center rounded-md border border-surface/40 px-7 font-bold text-surface transition-colors hover:bg-surface/10"
                >
                  Call (785) 272-0444
                </a>
              </div>
            </div>
          </section>
        </div>

        <div class="hidden min-[1400px]:block" aria-hidden="true"></div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
