---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import ServiceSidebar from "../../components/ServiceSidebar.astro";

const title =
  "Bone Grafting for Dental Implants | Topeka, KS | Capital Oral Surgery";
const description =
  "Learn why bone grafting may be needed before dental implant placement, including socket grafting, ridge grafting, and sinus grafting in Topeka, KS.";

const currentHref = "/services/bone-grafting-for-implants/";

const graftingScenarios = [
  {
    number: "01",
    title: "Socket grafting",
    body: "When socket walls are thin after extraction, grafting material may be placed at the time the tooth is removed to help the body fill the space with bone.",
  },
  {
    number: "02",
    title: "Thin ridge grafting",
    body: "If a tooth was removed years ago and the bony ridge has become very thin, grafting can rebuild width and volume before implant placement.",
  },
  {
    number: "03",
    title: "Sinus grafting",
    body: "When upper back teeth have been missing for a long time, the sinus may sit low near the implant site. Bone can be added to restore height for implants of proper length.",
  },
  {
    number: "04",
    title: "Implant-site preparation",
    body: "Some grafts heal before implant placement, while others may be completed at the same time as implant surgery depending on anatomy and treatment goals.",
  },
];

const graftingBenefits = [
  "Maintains socket width and volume",
  "Improves implant placement options",
  "Rebuilds thin jawbone areas",
  "Restores bone height near the sinus",
  "Supports long-term implant stability",
];
---

<Layout title={title} description={description} ogImage="/images/specialized-care.jpg">
  <Header />
  <main>
    <section class="bg-midnight text-surface" aria-labelledby="service-heading">
      <div
        class="mx-auto grid min-h-[calc(100dvh-76px)] max-w-7xl items-center gap-10 px-5 py-14 lg:gap-14 xl:grid-cols-[minmax(0,610px)_minmax(360px,500px)] xl:justify-between xl:px-0"
      >
        <div data-reveal>
          <a
            href="/#procedures"
            class="inline-flex text-sm font-bold text-accent transition-colors hover:text-surface"
          >
            ← Services
          </a>
          <p class="mt-10 text-xs font-bold tracking-[.34em] text-secondary">
            Dental implants
          </p>
          <h1
            id="service-heading"
            class="serif mt-5 max-w-[760px] text-5xl leading-[0.96] text-surface sm:text-6xl xl:text-[72px]"
          >
            Bone grafting for implants.
          </h1>
          <p class="mt-7 max-w-[590px] text-lg leading-8 text-surface/75 sm:text-xl">
            Dental implants need healthy bone for long-term support. When bone volume
            is limited after extraction, long-term tooth loss, or sinus changes, bone
            grafting can rebuild the foundation needed for implant placement.
          </p>
          <div class="mt-9 flex flex-col gap-3 sm:flex-row">
            <a
              href="/#appointment"
              class="inline-flex h-14 items-center justify-center rounded-md bg-secondary px-7 font-bold text-surface transition-opacity hover:opacity-90 sm:min-w-[223px]"
            >
              Request Appointment
            </a>
            <a
              href="tel:7852720444"
              class="inline-flex h-14 items-center justify-center rounded-md border border-surface/40 px-7 font-bold text-surface transition-colors hover:bg-surface/10 sm:min-w-[216px]"
            >
              Call (785) 272-0444
            </a>
          </div>
        </div>

        <div
          class="relative mx-auto w-full max-w-[500px] lg:mx-0"
          data-reveal
          style="--reveal-delay: 120ms"
        >
          <div
            class="absolute -bottom-3 left-3 right-[-12px] top-3 rounded-lg border border-secondary"
            aria-hidden="true"
          >
          </div>
          <div class="relative aspect-[4/5] overflow-hidden rounded-lg bg-surface/5">
            <img
              src="/images/specialized-care.jpg"
              alt="3D dental imaging equipment used for dental implant planning"
              class="h-full w-full object-cover object-center"
              width="5184"
              height="3456"
              loading="eager"
              decoding="async"
              fetchpriority="high"
            />
          </div>
        </div>
      </div>
    </section>

    <section class="bg-background py-20 text-foreground lg:py-24">
      <div
        class="mx-auto grid max-w-[920px] gap-10 px-5 min-[1400px]:max-w-[1400px] min-[1400px]:grid-cols-[220px_minmax(0,840px)_220px] min-[1400px]:items-start min-[1400px]:gap-8 min-[1700px]:max-w-[1640px] min-[1700px]:grid-cols-[280px_minmax(0,920px)_280px] min-[1700px]:gap-12"
      >
        <ServiceSidebar groupLabel="Dental implants" currentHref={currentHref} />

        <div class="grid gap-20 lg:gap-24 min-[1400px]:col-start-2">
          <section class="pb-2 lg:pb-0" aria-labelledby="bone-heading">
            <div class="max-w-5xl" data-reveal>
              <p class="text-xs font-bold tracking-[.34em] text-secondary">
                Implant foundation
              </p>
              <h2
                id="bone-heading"
                class="serif mt-4 text-4xl leading-tight sm:text-5xl"
              >
                Do you have enough bone for dental implants?
              </h2>
              <div class="mt-7 space-y-6 text-base leading-8 text-muted">
                <p>
                  After tooth extraction, thick socket walls often fill naturally with
                  bone in two to three months. When socket walls are thin, especially
                  near the front teeth, healing can be less predictable.
                </p>
                <p>
                  In those situations, bone grafting may be placed at the time of
                  extraction to help your body fill the empty socket with bone. This
                  helps maintain the width and volume needed for implant placement
                  several months later.
                </p>
                <p>
                  Bone grafting can also rebuild areas where teeth were removed years
                  ago and the ridge has become too thin to support an implant safely.
                </p>
              </div>

              <div class="mt-8 rounded-lg border border-line bg-surface p-7 shadow-sm sm:p-8">
                <p class="text-xs font-bold tracking-[.28em] text-secondary">
                  Timing matters
                </p>
                <p class="mt-3 text-base leading-7 text-muted">
                  Preserving bone at the time of extraction can simplify future implant
                  planning and may reduce the need for more complex reconstruction later.
                </p>
              </div>
            </div>
          </section>

          <section class="pt-4 lg:pt-2" aria-labelledby="scenarios-heading">
            <div class="max-w-3xl" data-reveal>
              <p class="text-xs font-bold tracking-[.34em] text-secondary">
                Grafting scenarios
              </p>
              <h2
                id="scenarios-heading"
                class="serif mt-4 text-4xl leading-tight sm:text-5xl"
              >
                Different bone concerns call for different grafting plans.
              </h2>
              <p class="mt-6 text-base leading-7 text-muted">
                Bone grafting is usually a relatively comfortable office procedure.
                Many different grafting materials are available, including your own
                bone when that is the best option.
              </p>
            </div>

            <div class="mt-12 grid gap-6 lg:grid-cols-2 lg:gap-7">
              {
                graftingScenarios.map(({ number, title, body }, index) => (
                  <article
                    class="rounded-lg border border-line bg-surface p-8 shadow-sm sm:p-9 lg:p-10"
                    data-reveal
                    style={`--reveal-delay: ${(index % 2) * 80}ms`}
                  >
                    <div class="flex h-10 w-10 items-center justify-center rounded-full bg-aqua-pale text-sm font-bold text-secondary">
                      {number}
                    </div>
                    <h3 class="serif mt-6 text-2xl font-bold text-foreground">
                      {title}
                    </h3>
                    <p class="mt-4 text-base leading-7 text-muted">{body}</p>
                  </article>
                ))
              }
            </div>
          </section>

          <section
            class="grid gap-10 rounded-lg bg-aqua-soft p-8 sm:p-10 lg:grid-cols-[minmax(0,1fr)_280px] lg:items-center lg:p-12"
            aria-labelledby="benefits-heading"
            data-reveal
          >
            <div>
              <p class="text-xs font-bold tracking-[.34em] text-secondary">
                Benefits
              </p>
              <h2
                id="benefits-heading"
                class="serif mt-4 text-4xl leading-tight sm:text-5xl"
              >
                Bone grafting restores options for implant placement.
              </h2>
              <p class="mt-6 text-base leading-7 text-muted">
                The purpose of grafting is to create enough healthy bone height, width,
                and volume for an implant to be placed with better support and
                long-term stability.
              </p>
            </div>
            <div class="grid gap-3 text-sm font-bold text-foreground">
              {graftingBenefits.map((item) => (
                <p class="rounded-md bg-surface px-4 py-3">{item}</p>
              ))}
            </div>
          </section>

          <section class="grid gap-8 md:grid-cols-2">
            <article class="rounded-lg border border-line bg-surface p-8 shadow-sm sm:p-9 lg:p-10" data-reveal>
              <p class="text-xs font-bold tracking-[.28em] text-secondary">
                Thin ridge grafting
              </p>
              <h2 class="serif mt-5 text-3xl leading-tight text-foreground">
                Older extraction sites may need rebuilding.
              </h2>
              <p class="mt-6 text-base leading-7 text-muted">
                If the bony ridge is extremely thin, grafting material can be placed
                beside the existing bone and allowed to heal for up to six months before
                the ridge is re-entered and the implant is placed.
              </p>
            </article>

            <article
              class="rounded-lg border border-line bg-surface p-8 shadow-sm sm:p-9 lg:p-10"
              data-reveal
              style="--reveal-delay: 120ms"
            >
              <p class="text-xs font-bold tracking-[.28em] text-secondary">
                Sinus grafting
              </p>
              <h2 class="serif mt-5 text-3xl leading-tight text-foreground">
                Upper back teeth can need added bone height.
              </h2>
              <p class="mt-6 text-base leading-7 text-muted">
                If the sinus sits low into the tooth-bearing area, the sinus membrane
                can be gently elevated and bone added to restore enough height for
                implants of adequate length.
              </p>
            </article>
          </section>

          <section class="rounded-lg bg-midnight px-8 py-12 text-surface sm:px-10 lg:px-12 lg:py-14">
            <div class="grid gap-8 lg:grid-cols-[minmax(0,1fr)_auto] lg:items-center">
              <div data-reveal>
                <p class="text-xs font-bold tracking-[.34em] text-secondary">
                  Reclaim confidence
                </p>
                <h2 class="serif mt-4 text-4xl leading-tight sm:text-5xl">
                  Find out whether grafting is needed.
                </h2>
                <p class="mt-5 max-w-[660px] text-base leading-7 text-surface/75">
                  We will review your imaging, bone volume, and implant goals to
                  determine whether bone grafting should be part of your treatment plan.
                </p>
              </div>
              <div
                class="flex flex-col gap-3 sm:flex-row lg:flex-col"
                data-reveal
                style="--reveal-delay: 120ms"
              >
                <a
                  href="/#appointment"
                  class="inline-flex h-14 items-center justify-center rounded-md bg-secondary px-7 font-bold text-surface transition-opacity hover:opacity-90"
                >
                  Request Appointment
                </a>
                <a
                  href="tel:7852720444"
                  class="inline-flex h-14 items-center justify-center rounded-md border border-surface/40 px-7 font-bold text-surface transition-colors hover:bg-surface/10"
                >
                  Call (785) 272-0444
                </a>
              </div>
            </div>
          </section>
        </div>

        <div class="hidden min-[1400px]:block" aria-hidden="true"></div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
