---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import ServiceSidebar from "../../components/ServiceSidebar.astro";

const title = "About Bone Grafting | Topeka, KS | Capital Oral Surgery";
const description =
  "Learn how dental bone grafting replaces lost jawbone, supports implant planning, and helps restore function and facial structure.";

const currentHref = "/services/about-bone-grafting/";

const graftTypes = [
  {
    number: "01",
    title: "Autogenous bone",
    body: "In some cases, bone can be taken from another area of your own body and transferred to the area that needs rebuilding.",
  },
  {
    number: "02",
    title: "Tissue-bank bone",
    body: "Processed donor bone can provide a framework for your body to gradually replace and remodel with new bone during healing.",
  },
  {
    number: "03",
    title: "Synthetic or specialty materials",
    body: "Some grafting plans use advanced materials designed to support new bone formation and protect the shape of the grafted site.",
  },
  {
    number: "04",
    title: "Guided regeneration",
    body: "A protective membrane may be placed beneath the gum tissue to help shield the graft and encourage bone to grow in the right space.",
  },
];

const graftGoals = [
  "Restore jawbone height and width",
  "Improve dental implant options",
  "Support function and facial structure",
  "Repair defects from trauma or disease",
];
---

<Layout title={title} description={description} ogImage="/images/specialized-care.jpg">
  <Header />
  <main>
    <section class="bg-midnight text-surface" aria-labelledby="service-heading">
      <div
        class="mx-auto grid min-h-[calc(100dvh-76px)] max-w-7xl items-center gap-10 px-5 py-14 lg:gap-14 xl:grid-cols-[minmax(0,610px)_minmax(360px,500px)] xl:justify-between xl:px-0"
      >
        <div data-reveal>
          <a
            href="/#procedures"
            class="inline-flex text-sm font-bold text-accent transition-colors hover:text-surface"
          >
            ← Services
          </a>
          <p class="mt-10 text-xs font-bold tracking-[.34em] text-secondary">
            Procedures
          </p>
          <h1
            id="service-heading"
            class="serif mt-5 max-w-[760px] text-5xl leading-[0.96] text-surface sm:text-6xl xl:text-[72px]"
          >
            About bone grafting.
          </h1>
          <p class="mt-7 max-w-[590px] text-lg leading-8 text-surface/75 sm:text-xl">
            Bone grafting is a way to replace or rebuild missing jawbone. It can
            restore the foundation needed for implants, improve oral function, and help
            preserve natural facial support.
          </p>
          <div class="mt-9 flex flex-col gap-3 sm:flex-row">
            <a
              href="/#appointment"
              class="inline-flex h-14 items-center justify-center rounded-md bg-secondary px-7 font-bold text-surface transition-opacity hover:opacity-90 sm:min-w-[223px]"
            >
              Request Appointment
            </a>
            <a
              href="tel:7852720444"
              class="inline-flex h-14 items-center justify-center rounded-md border border-surface/40 px-7 font-bold text-surface transition-colors hover:bg-surface/10 sm:min-w-[216px]"
            >
              Call (785) 272-0444
            </a>
          </div>
        </div>

        <div
          class="relative mx-auto w-full max-w-[500px] lg:mx-0"
          data-reveal
          style="--reveal-delay: 120ms"
        >
          <div
            class="absolute -bottom-3 left-3 right-[-12px] top-3 rounded-lg border border-secondary"
            aria-hidden="true"
          >
          </div>
          <div class="relative aspect-[4/5] overflow-hidden rounded-lg bg-surface/5">
            <img
              src="/images/specialized-care.jpg"
              alt="Dental imaging equipment used to plan bone grafting treatment"
              class="h-full w-full object-cover object-center"
              width="5184"
              height="3456"
              loading="eager"
              decoding="async"
              fetchpriority="high"
            />
          </div>
        </div>
      </div>
    </section>

    <section class="bg-background py-20 text-foreground lg:py-24">
      <div
        class="mx-auto grid max-w-[920px] gap-10 px-5 min-[1400px]:max-w-[1400px] min-[1400px]:grid-cols-[220px_minmax(0,840px)_220px] min-[1400px]:items-start min-[1400px]:gap-8 min-[1700px]:max-w-[1640px] min-[1700px]:grid-cols-[280px_minmax(0,920px)_280px] min-[1700px]:gap-12"
      >
        <ServiceSidebar groupLabel="Procedures" currentHref={currentHref} />

        <div class="grid gap-20 lg:gap-24 min-[1400px]:col-start-2">
          <section class="pb-2 lg:pb-0" aria-labelledby="overview-heading">
            <div class="max-w-5xl" data-reveal>
              <p class="text-xs font-bold tracking-[.34em] text-secondary">
                Bone grafting overview
              </p>
              <h2
                id="overview-heading"
                class="serif mt-4 text-4xl leading-tight sm:text-5xl"
              >
                Lost jawbone can often be rebuilt with modern grafting techniques.
              </h2>
              <div class="mt-7 space-y-6 text-base leading-8 text-muted">
                <p>
                  Teeth help stimulate and maintain the bone around them. When teeth are
                  missing for a long period of time, the jawbone can shrink, leaving
                  less height, width, or quality for future tooth replacement.
                </p>
                <p>
                  Bone grafting places graft material where support is needed. Over
                  time, the grafted area can become a stronger foundation for dental
                  implants or other restorative planning.
                </p>
                <p>
                  The size and location of the defect determine whether the procedure is
                  a focused site graft or a more advanced reconstruction.
                </p>
              </div>

              <div class="mt-8 rounded-lg border border-line bg-surface p-7 shadow-sm sm:p-8">
                <p class="text-xs font-bold tracking-[.28em] text-secondary">
                  Planning starts with imaging
                </p>
                <p class="mt-3 text-base leading-7 text-muted">
                  Detailed imaging helps the surgeon evaluate bone volume, choose the
                  right grafting approach, and explain how the graft fits into the full
                  treatment timeline.
                </p>
              </div>
            </div>
          </section>

          <section class="pt-4 lg:pt-2" aria-labelledby="materials-heading">
            <div class="max-w-3xl" data-reveal>
              <p class="text-xs font-bold tracking-[.34em] text-secondary">
                Grafting materials
              </p>
              <h2
                id="materials-heading"
                class="serif mt-4 text-4xl leading-tight sm:text-5xl"
              >
                Different graft sources can support different treatment needs.
              </h2>
              <p class="mt-6 text-base leading-7 text-muted">
                Grafting material acts as a scaffold for healing. Depending on the
                amount of bone needed, it may come from your own body, a tissue bank, or
                another carefully selected grafting material.
              </p>
            </div>

            <div class="mt-12 grid gap-6 lg:grid-cols-2 lg:gap-7">
              {
                graftTypes.map(({ number, title, body }, index) => (
                  <article
                    class="rounded-lg border border-line bg-surface p-8 shadow-sm sm:p-9 lg:p-10"
                    data-reveal
                    style={`--reveal-delay: ${(index % 2) * 80}ms`}
                  >
                    <div class="flex h-10 w-10 items-center justify-center rounded-full bg-aqua-pale text-sm font-bold text-secondary">
                      {number}
                    </div>
                    <h3 class="serif mt-6 text-2xl font-bold text-foreground">
                      {title}
                    </h3>
                    <p class="mt-4 text-base leading-7 text-muted">{body}</p>
                  </article>
                ))
              }
            </div>
          </section>

          <section
            class="grid gap-10 rounded-lg bg-aqua-soft p-8 sm:p-10 lg:grid-cols-[minmax(0,1fr)_280px] lg:items-center lg:p-12"
            aria-labelledby="goals-heading"
            data-reveal
          >
            <div>
              <p class="text-xs font-bold tracking-[.34em] text-secondary">
                Treatment goals
              </p>
              <h2
                id="goals-heading"
                class="serif mt-4 text-4xl leading-tight sm:text-5xl"
              >
                The goal is a healthier foundation, not just more bone.
              </h2>
              <p class="mt-6 text-base leading-7 text-muted">
                Bone grafting can improve the quality and quantity of bone available
                for restoration while helping preserve oral function and appearance.
              </p>
            </div>
            <div class="grid gap-3 text-sm font-bold text-foreground">
              {graftGoals.map((item) => (
                <p class="rounded-md bg-surface px-4 py-3">{item}</p>
              ))}
            </div>
          </section>

          <section class="grid gap-8 md:grid-cols-2">
            <article class="rounded-lg border border-line bg-surface p-8 shadow-sm sm:p-9 lg:p-10" data-reveal>
              <p class="text-xs font-bold tracking-[.28em] text-secondary">
                Minor grafting
              </p>
              <h2 class="serif mt-5 text-3xl leading-tight text-foreground">
                Many grafts focus on a specific implant site.
              </h2>
              <p class="mt-6 text-base leading-7 text-muted">
                Smaller grafts are often used to repair an extraction site or rebuild a
                localized area before implant placement. Healing time varies by the
                amount of bone needed and the final restoration plan.
              </p>
            </article>

            <article
              class="rounded-lg border border-line bg-surface p-8 shadow-sm sm:p-9 lg:p-10"
              data-reveal
              style="--reveal-delay: 120ms"
            >
              <p class="text-xs font-bold tracking-[.28em] text-secondary">
                Major grafting
              </p>
              <h2 class="serif mt-5 text-3xl leading-tight text-foreground">
                Larger defects require a more detailed surgical plan.
              </h2>
              <p class="mt-6 text-base leading-7 text-muted">
                More extensive grafting may be needed after trauma, tumor surgery, or
                congenital defects. These procedures are planned carefully around the
                size of the defect and the healthiest donor or grafting source.
              </p>
            </article>
          </section>

          <section class="rounded-lg bg-midnight px-8 py-12 text-surface sm:px-10 lg:px-12 lg:py-14">
            <div class="grid gap-8 lg:grid-cols-[minmax(0,1fr)_auto] lg:items-center">
              <div data-reveal>
                <p class="text-xs font-bold tracking-[.34em] text-secondary">
                  Rebuild the foundation
                </p>
                <h2 class="serif mt-4 text-4xl leading-tight sm:text-5xl">
                  Find out whether grafting is part of your plan.
                </h2>
                <p class="mt-5 max-w-[660px] text-base leading-7 text-surface/75">
                  Our team will review your imaging, explain the condition of your
                  jawbone, and map out the next step with clarity.
                </p>
              </div>
              <div
                class="flex flex-col gap-3 sm:flex-row lg:flex-col"
                data-reveal
                style="--reveal-delay: 120ms"
              >
                <a
                  href="/#appointment"
                  class="inline-flex h-14 items-center justify-center rounded-md bg-secondary px-7 font-bold text-surface transition-opacity hover:opacity-90"
                >
                  Request Appointment
                </a>
                <a
                  href="tel:7852720444"
                  class="inline-flex h-14 items-center justify-center rounded-md border border-surface/40 px-7 font-bold text-surface transition-colors hover:bg-surface/10"
                >
                  Call (785) 272-0444
                </a>
              </div>
            </div>
          </section>
        </div>

        <div class="hidden min-[1400px]:block" aria-hidden="true"></div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
