---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import ServiceSidebar from "../../components/ServiceSidebar.astro";

const title = "Anesthesia | Oral Surgery Sedation | Topeka, KS";
const description =
  "Learn about oral surgery anesthesia options at Capital Oral Surgery, including local anesthesia, nitrous oxide, IV sedation, office-based general anesthesia, and hospital-based anesthesia.";

const currentHref = "/services/anesthesia/";

const anesthesiaOptions = [
  {
    number: "01",
    title: "Local anesthetic",
    body: "The patient remains fully conscious while the treatment area is numbed. Local anesthetic is used in oral surgery procedures and may be combined with other anesthesia options.",
  },
  {
    number: "02",
    title: "Nitrous oxide with local anesthetic",
    body: "A mixture of nitrous oxide and oxygen is delivered through a nasal breathing mask. Patients remain conscious, relaxed, and in control.",
  },
  {
    number: "03",
    title: "Office-based IV or general anesthesia",
    body: "Medication is given through an IV so the patient is deeply relaxed or asleep and unaware of the procedure while vital signs are closely monitored.",
  },
  {
    number: "04",
    title: "Hospital or surgery center anesthesia",
    body: "For extensive procedures or certain medical conditions, anesthesia may be administered by an anesthesiologist in a hospital or surgery center setting.",
  },
];

const comfortFactors = [
  "Type and length of procedure",
  "Patient anxiety or apprehension",
  "Medical history and medications",
  "Presence of infection",
  "Need for extensive reconstruction",
];
---

<Layout title={title} description={description} ogImage="/images/specialized-care.jpg">
  <Header />
  <main>
    <section class="bg-midnight text-surface" aria-labelledby="service-heading">
      <div
        class="mx-auto grid min-h-[calc(100dvh-76px)] max-w-7xl items-center gap-10 px-5 py-14 lg:gap-14 xl:grid-cols-[minmax(0,610px)_minmax(360px,500px)] xl:justify-between xl:px-0"
      >
        <div data-reveal>
          <a
            href="/#procedures"
            class="inline-flex text-sm font-bold text-accent transition-colors hover:text-surface"
          >
            ← Services
          </a>
          <p class="mt-10 text-xs font-bold tracking-[.34em] text-secondary">
            Procedures
          </p>
          <h1
            id="service-heading"
            class="serif mt-5 max-w-[760px] text-5xl leading-[0.96] text-surface sm:text-6xl xl:text-[72px]"
          >
            Anesthesia.
          </h1>
          <p class="mt-7 max-w-[590px] text-lg leading-8 text-surface/75 sm:text-xl">
            Our oral surgeons are trained in multiple anesthesia methods for wisdom
            teeth removal, tooth extractions, dental implants, and other oral surgery
            procedures. The right option depends on your treatment and comfort level.
          </p>
          <div class="mt-9 flex flex-col gap-3 sm:flex-row">
            <a
              href="/#appointment"
              class="inline-flex h-14 items-center justify-center rounded-md bg-secondary px-7 font-bold text-surface transition-opacity hover:opacity-90 sm:min-w-[223px]"
            >
              Request Appointment
            </a>
            <a
              href="tel:7852720444"
              class="inline-flex h-14 items-center justify-center rounded-md border border-surface/40 px-7 font-bold text-surface transition-colors hover:bg-surface/10 sm:min-w-[216px]"
            >
              Call (785) 272-0444
            </a>
          </div>
        </div>

        <div
          class="relative mx-auto w-full max-w-[500px] lg:mx-0"
          data-reveal
          style="--reveal-delay: 120ms"
        >
          <div
            class="absolute -bottom-3 left-3 right-[-12px] top-3 rounded-lg border border-secondary"
            aria-hidden="true"
          >
          </div>
          <div class="relative aspect-[4/5] overflow-hidden rounded-lg bg-surface/5">
            <img
              src="/images/specialized-care.jpg"
              alt="Oral surgery equipment used during anesthesia planning"
              class="h-full w-full object-cover object-center"
              width="5184"
              height="3456"
              loading="eager"
              decoding="async"
              fetchpriority="high"
            />
          </div>
        </div>
      </div>
    </section>

    <section class="bg-background py-20 text-foreground lg:py-24">
      <div
        class="mx-auto grid max-w-[920px] gap-10 px-5 min-[1400px]:max-w-[1400px] min-[1400px]:grid-cols-[220px_minmax(0,840px)_220px] min-[1400px]:items-start min-[1400px]:gap-8 min-[1700px]:max-w-[1640px] min-[1700px]:grid-cols-[280px_minmax(0,920px)_280px] min-[1700px]:gap-12"
      >
        <ServiceSidebar groupLabel="Procedures" currentHref={currentHref} />

        <div class="grid gap-20 lg:gap-24 min-[1400px]:col-start-2">
          <section class="pb-2 lg:pb-0" aria-labelledby="overview-heading">
            <div class="max-w-5xl" data-reveal>
              <p class="text-xs font-bold tracking-[.34em] text-secondary">
                Safety and comfort
              </p>
              <h2
                id="overview-heading"
                class="serif mt-4 text-4xl leading-tight sm:text-5xl"
              >
                Anesthesia is chosen around the procedure, your health, and your anxiety level.
              </h2>
              <div class="mt-7 space-y-6 text-base leading-8 text-muted">
                <p>
                  Anesthesia helps oral surgery feel safer and more comfortable. Some
                  patients need only local anesthetic, while others benefit from nitrous
                  oxide, IV sedation, office-based general anesthesia, or a hospital
                  setting.
                </p>
                <p>
                  The method chosen depends on the nature of the procedure, the level of
                  apprehension, and any medical factors that may affect the safest way to
                  provide care.
                </p>
                <p>
                  If you have concerns about the anesthesia planned for your procedure,
                  your consultation is the right time to talk through those questions
                  with the doctor.
                </p>
              </div>

              <div class="mt-8 rounded-lg border border-line bg-surface p-7 shadow-sm sm:p-8">
                <p class="text-xs font-bold tracking-[.28em] text-secondary">
                  First priority
                </p>
                <p class="mt-3 text-base leading-7 text-muted">
                  Patient comfort and safety guide every anesthesia recommendation, from
                  simple local numbing to deeper sedation for more involved surgery.
                </p>
              </div>
            </div>
          </section>

          <section class="pt-4 lg:pt-2" aria-labelledby="options-heading">
            <div class="max-w-3xl" data-reveal>
              <p class="text-xs font-bold tracking-[.34em] text-secondary">
                Anesthesia options
              </p>
              <h2
                id="options-heading"
                class="serif mt-4 text-4xl leading-tight sm:text-5xl"
              >
                Different levels of anesthesia support different oral surgery needs.
              </h2>
              <p class="mt-6 text-base leading-7 text-muted">
                Many procedures use local anesthetic as the foundation, with additional
                sedation options added when comfort, anxiety, or procedure complexity
                call for it.
              </p>
            </div>

            <div class="mt-12 grid gap-6 lg:grid-cols-2 lg:gap-7">
              {
                anesthesiaOptions.map(({ number, title, body }, index) => (
                  <article
                    class="rounded-lg border border-line bg-surface p-8 shadow-sm sm:p-9 lg:p-10"
                    data-reveal
                    style={`--reveal-delay: ${(index % 2) * 80}ms`}
                  >
                    <div class="flex h-10 w-10 items-center justify-center rounded-full bg-aqua-pale text-sm font-bold text-secondary">
                      {number}
                    </div>
                    <h3 class="serif mt-6 text-2xl font-bold text-foreground">
                      {title}
                    </h3>
                    <p class="mt-4 text-base leading-7 text-muted">{body}</p>
                  </article>
                ))
              }
            </div>
          </section>

          <section
            class="grid gap-10 rounded-lg bg-aqua-soft p-8 sm:p-10 lg:grid-cols-[minmax(0,1fr)_280px] lg:items-center lg:p-12"
            aria-labelledby="factors-heading"
            data-reveal
          >
            <div>
              <p class="text-xs font-bold tracking-[.34em] text-secondary">
                Choosing the method
              </p>
              <h2
                id="factors-heading"
                class="serif mt-4 text-4xl leading-tight sm:text-5xl"
              >
                The safest option is personalized to the patient and procedure.
              </h2>
              <p class="mt-6 text-base leading-7 text-muted">
                General anesthesia may be chosen for implant placement, wisdom teeth
                removal, or anxiety, and may be necessary when infection makes local
                anesthesia less predictable.
              </p>
            </div>
            <div class="grid gap-3 text-sm font-bold text-foreground">
              {comfortFactors.map((item) => (
                <p class="rounded-md bg-surface px-4 py-3">{item}</p>
              ))}
            </div>
          </section>

          <section class="grid gap-8 md:grid-cols-2">
            <article class="rounded-lg border border-line bg-surface p-8 shadow-sm sm:p-9 lg:p-10" data-reveal>
              <p class="text-xs font-bold tracking-[.28em] text-secondary">
                IV sedation
              </p>
              <h2 class="serif mt-5 text-3xl leading-tight text-foreground">
                Twilight sedation helps you feel calm and relaxed.
              </h2>
              <p class="mt-6 text-base leading-7 text-muted">
                IV sedation is administered through a small needle in the arm or hand.
                Patients are very relaxed and may drift in and out of sleep, with little
                memory of the procedure.
              </p>
            </article>

            <article
              class="rounded-lg border border-line bg-surface p-8 shadow-sm sm:p-9 lg:p-10"
              data-reveal
              style="--reveal-delay: 120ms"
            >
              <p class="text-xs font-bold tracking-[.28em] text-secondary">
                Monitoring and training
              </p>
              <h2 class="serif mt-5 text-3xl leading-tight text-foreground">
                Office anesthesia requires licensing and emergency readiness.
              </h2>
              <p class="mt-6 text-base leading-7 text-muted">
                Oral surgeons complete hospital-based anesthesia training and must meet
                state requirements for monitoring equipment, emergency preparedness, and
                continuing education.
              </p>
            </article>
          </section>

          <section class="rounded-lg bg-midnight px-8 py-12 text-surface sm:px-10 lg:px-12 lg:py-14">
            <div class="grid gap-8 lg:grid-cols-[minmax(0,1fr)_auto] lg:items-center">
              <div data-reveal>
                <p class="text-xs font-bold tracking-[.34em] text-secondary">
                  Comfortable oral surgery
                </p>
                <h2 class="serif mt-4 text-4xl leading-tight sm:text-5xl">
                  Talk through anesthesia before treatment.
                </h2>
                <p class="mt-5 max-w-[660px] text-base leading-7 text-surface/75">
                  We will explain your anesthesia options, answer questions, and help
                  choose the level of care that fits your procedure and comfort.
                </p>
              </div>
              <div
                class="flex flex-col gap-3 sm:flex-row lg:flex-col"
                data-reveal
                style="--reveal-delay: 120ms"
              >
                <a
                  href="/#appointment"
                  class="inline-flex h-14 items-center justify-center rounded-md bg-secondary px-7 font-bold text-surface transition-opacity hover:opacity-90"
                >
                  Request Appointment
                </a>
                <a
                  href="tel:7852720444"
                  class="inline-flex h-14 items-center justify-center rounded-md border border-surface/40 px-7 font-bold text-surface transition-colors hover:bg-surface/10"
                >
                  Call (785) 272-0444
                </a>
              </div>
            </div>
          </section>
        </div>

        <div class="hidden min-[1400px]:block" aria-hidden="true"></div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
