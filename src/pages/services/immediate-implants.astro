---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import ServiceSidebar from "../../components/ServiceSidebar.astro";

const title =
  "Immediate Dental Implants | Topeka, KS | Capital Oral Surgery";
const description =
  "Learn when immediate dental implants may be placed after tooth extraction and how timing, healing, and restoration planning work in Topeka, KS.";

const currentHref = "/services/immediate-implants/";

const restorationTimelines = [
  {
    number: "01",
    title: "Restoration within 48 hours",
    body: "Some patients may be candidates for a very early temporary or final restoration after implant placement, depending on bone strength, bite forces, and the treatment plan.",
  },
  {
    number: "02",
    title: "Restoration within three months",
    body: "Many patients need a short healing window before their restoration is attached. This gives the implant site time to recover and allows your team to confirm stability.",
  },
  {
    number: "03",
    title: "Traditional restoration timing",
    body: "Some cases still benefit from a three-to-six-month healing period before restoration. Your surgeon and dentist choose the timeline that best protects long-term results.",
  },
];

const benefits = [
  "Shorter wait between implant placement and restoration",
  "Fewer surgeries for many patients",
  "Faster overall recovery time",
  "Less tissue and bone loss",
  "Greater satisfaction with final results",
];
---

<Layout title={title} description={description} ogImage="/images/specialized-care.jpg">
  <Header />
  <main>
    <section class="bg-midnight text-surface" aria-labelledby="service-heading">
      <div
        class="mx-auto grid min-h-[calc(100dvh-76px)] max-w-7xl items-center gap-10 px-5 py-14 lg:gap-14 xl:grid-cols-[minmax(0,610px)_minmax(360px,500px)] xl:justify-between xl:px-0"
      >
        <div data-reveal>
          <a
            href="/#procedures"
            class="inline-flex text-sm font-bold text-accent transition-colors hover:text-surface"
          >
            ← Services
          </a>
          <p class="mt-10 text-xs font-bold tracking-[.34em] text-secondary">
            Dental implants
          </p>
          <h1
            id="service-heading"
            class="serif mt-5 max-w-[760px] text-5xl leading-[0.96] text-surface sm:text-6xl xl:text-[72px]"
          >
            Immediate implants.
          </h1>
          <p class="mt-7 max-w-[590px] text-lg leading-8 text-surface/75 sm:text-xl">
            If a damaged tooth needs to be removed before implant treatment, immediate
            implant placement may shorten the overall process. Our surgeons evaluate
            the extraction site, bone support, and healing needs before recommending
            the safest timing.
          </p>
          <div class="mt-9 flex flex-col gap-3 sm:flex-row">
            <a
              href="/#appointment"
              class="inline-flex h-14 items-center justify-center rounded-md bg-secondary px-7 font-bold text-surface transition-opacity hover:opacity-90 sm:min-w-[223px]"
            >
              Request Appointment
            </a>
            <a
              href="tel:7852720444"
              class="inline-flex h-14 items-center justify-center rounded-md border border-surface/40 px-7 font-bold text-surface transition-colors hover:bg-surface/10 sm:min-w-[216px]"
            >
              Call (785) 272-0444
            </a>
          </div>
        </div>

        <div
          class="relative mx-auto w-full max-w-[500px] lg:mx-0"
          data-reveal
          style="--reveal-delay: 120ms"
        >
          <div
            class="absolute -bottom-3 left-3 right-[-12px] top-3 rounded-lg border border-secondary"
            aria-hidden="true"
          >
          </div>
          <div class="relative aspect-[4/5] overflow-hidden rounded-lg bg-surface/5">
            <img
              src="/images/specialized-care.jpg"
              alt="3D dental imaging equipment used for dental implant planning"
              class="h-full w-full object-cover object-center"
              width="5184"
              height="3456"
              loading="eager"
              decoding="async"
              fetchpriority="high"
            />
          </div>
        </div>
      </div>
    </section>

    <section class="bg-background py-20 text-foreground lg:py-24">
      <div
        class="mx-auto grid max-w-[920px] gap-10 px-5 min-[1400px]:max-w-[1400px] min-[1400px]:grid-cols-[220px_minmax(0,840px)_220px] min-[1400px]:items-start min-[1400px]:gap-8 min-[1700px]:max-w-[1640px] min-[1700px]:grid-cols-[280px_minmax(0,920px)_280px] min-[1700px]:gap-12"
      >
        <ServiceSidebar groupLabel="Dental implants" currentHref={currentHref} />

        <div class="grid gap-20 lg:gap-24 min-[1400px]:col-start-2">
          <section class="pb-2 lg:pb-0" aria-labelledby="immediate-heading">
            <div class="max-w-5xl" data-reveal>
              <p class="text-xs font-bold tracking-[.34em] text-secondary">
                What immediate means
              </p>
              <h2
                id="immediate-heading"
                class="serif mt-4 text-4xl leading-tight sm:text-5xl"
              >
                The implant can be placed right after extraction, but the crown timing varies.
              </h2>
              <div class="mt-7 space-y-6 text-base leading-8 text-muted">
                <p>
                  Dental implants can be a longer process, especially when teeth have
                  been missing for some time. For many patients, restorations are added
                  months after implant placement.
                </p>
                <p>
                  Immediate implant placement means the titanium implant is placed in
                  the jawbone immediately after the damaged tooth is extracted. This can
                  simplify treatment, support healing, and reduce the wait before the
                  final restoration.
                </p>
                <p>
                  “Immediate” does not always mean a crown or overdenture is attached
                  the same day. Some patients restore quickly, while many need several
                  weeks of healing before the restoration is attached.
                </p>
              </div>

              <div class="mt-8 rounded-lg border border-line bg-surface p-7 shadow-sm sm:p-8">
                <p class="text-xs font-bold tracking-[.28em] text-secondary">
                  Candidate fit
                </p>
                <p class="mt-3 text-base leading-7 text-muted">
                  Immediate placement depends on the condition of the extraction site,
                  jawbone strength, infection risk, and how well the implant can be
                  stabilized at the time of surgery.
                </p>
              </div>
            </div>
          </section>

          <section class="pt-4 lg:pt-2" aria-labelledby="timeline-heading">
            <div class="max-w-3xl" data-reveal>
              <p class="text-xs font-bold tracking-[.34em] text-secondary">
                Restoration timing
              </p>
              <h2
                id="timeline-heading"
                class="serif mt-4 text-4xl leading-tight sm:text-5xl"
              >
                Your restoration timeline is chosen after healing is evaluated.
              </h2>
              <p class="mt-6 text-base leading-7 text-muted">
                Your surgeon works with your dentist or prosthodontist to determine
                when your restoration can be attached. The right timing depends on bone
                strength, recovery, implant stability, and your restorative plan.
              </p>
            </div>

            <div class="mt-12 grid gap-6 lg:grid-cols-3 lg:gap-7">
              {
                restorationTimelines.map(({ number, title, body }, index) => (
                  <article
                    class="rounded-lg border border-line bg-surface p-8 shadow-sm sm:p-9 lg:p-10"
                    data-reveal
                    style={`--reveal-delay: ${index * 80}ms`}
                  >
                    <div class="flex h-10 w-10 items-center justify-center rounded-full bg-aqua-pale text-sm font-bold text-secondary">
                      {number}
                    </div>
                    <h3 class="serif mt-6 text-2xl font-bold text-foreground">
                      {title}
                    </h3>
                    <p class="mt-4 text-base leading-7 text-muted">{body}</p>
                  </article>
                ))
              }
            </div>
          </section>

          <section
            class="grid gap-10 rounded-lg bg-aqua-soft p-8 sm:p-10 lg:grid-cols-[minmax(0,1fr)_280px] lg:items-center lg:p-12"
            aria-labelledby="benefits-heading"
            data-reveal
          >
            <div>
              <p class="text-xs font-bold tracking-[.34em] text-secondary">
                Benefits
              </p>
              <h2
                id="benefits-heading"
                class="serif mt-4 text-4xl leading-tight sm:text-5xl"
              >
                Immediate implants can reduce the number of steps.
              </h2>
              <p class="mt-6 text-base leading-7 text-muted">
                When the anatomy and extraction site are favorable, immediate implants
                may simplify surgery, shorten recovery, reduce the amount of tissue and
                bone change, and improve patient satisfaction with the process.
              </p>
            </div>
            <div class="grid gap-3 text-sm font-bold text-foreground">
              {benefits.map((item) => (
                <p class="rounded-md bg-surface px-4 py-3">{item}</p>
              ))}
            </div>
          </section>

          <section class="grid gap-8 md:grid-cols-2">
            <article class="rounded-lg border border-line bg-surface p-8 shadow-sm sm:p-9 lg:p-10" data-reveal>
              <p class="text-xs font-bold tracking-[.28em] text-secondary">
                Healing checks
              </p>
              <h2 class="serif mt-5 text-3xl leading-tight text-foreground">
                Progress is monitored before restoration.
              </h2>
              <p class="mt-6 text-base leading-7 text-muted">
                Your surgeon checks healing periodically to confirm when the implant is
                ready for a restoration. This protects the final result and helps avoid
                placing too much force on the implant too early.
              </p>
            </article>

            <article
              class="rounded-lg border border-line bg-surface p-8 shadow-sm sm:p-9 lg:p-10"
              data-reveal
              style="--reveal-delay: 120ms"
            >
              <p class="text-xs font-bold tracking-[.28em] text-secondary">
                Recovery time
              </p>
              <h2 class="serif mt-5 text-3xl leading-tight text-foreground">
                Faster does not mean rushed.
              </h2>
              <p class="mt-6 text-base leading-7 text-muted">
                Immediate implants can shorten the treatment timeline, but the final
                schedule should still respect the biology of healing and the strength
                of the implant site.
              </p>
            </article>
          </section>

          <section class="rounded-lg bg-midnight px-8 py-12 text-surface sm:px-10 lg:px-12 lg:py-14">
            <div class="grid gap-8 lg:grid-cols-[minmax(0,1fr)_auto] lg:items-center">
              <div data-reveal>
                <p class="text-xs font-bold tracking-[.34em] text-secondary">
                  Reclaim confidence
                </p>
                <h2 class="serif mt-4 text-4xl leading-tight sm:text-5xl">
                  Ask whether immediate placement fits your case.
                </h2>
                <p class="mt-5 max-w-[660px] text-base leading-7 text-surface/75">
                  We will evaluate your extraction site, bone support, and restorative
                  goals to determine whether immediate implants are a smart option.
                </p>
              </div>
              <div
                class="flex flex-col gap-3 sm:flex-row lg:flex-col"
                data-reveal
                style="--reveal-delay: 120ms"
              >
                <a
                  href="/#appointment"
                  class="inline-flex h-14 items-center justify-center rounded-md bg-secondary px-7 font-bold text-surface transition-opacity hover:opacity-90"
                >
                  Request Appointment
                </a>
                <a
                  href="tel:7852720444"
                  class="inline-flex h-14 items-center justify-center rounded-md border border-surface/40 px-7 font-bold text-surface transition-colors hover:bg-surface/10"
                >
                  Call (785) 272-0444
                </a>
              </div>
            </div>
          </section>
        </div>

        <div class="hidden min-[1400px]:block" aria-hidden="true"></div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
