---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import ServiceSidebar from "../../components/ServiceSidebar.astro";

const title = "Pre-Prosthetic Surgery | Topeka, KS | Capital Oral Surgery";
const description =
  "Learn how pre-prosthetic surgery prepares the mouth for a comfortable partial or complete denture by reshaping bone or gum tissue when needed.";

const currentHref = "/services/pre-prosthetic-surgery/";

const preparationSteps = [
  {
    number: "01",
    title: "Bone smoothing and reshaping",
    body: "Sharp or uneven bone can be smoothed so a denture rests more comfortably on the ridge.",
  },
  {
    number: "02",
    title: "Removal of excess bone",
    body: "Areas of extra bone may need to be reduced before a partial or complete denture can fit properly.",
  },
  {
    number: "03",
    title: "Bone ridge reduction",
    body: "The ridge that supports a denture can sometimes be reshaped to improve stability and comfort.",
  },
  {
    number: "04",
    title: "Excess gum tissue care",
    body: "Extra soft tissue may be adjusted when it interferes with denture fit or long-term comfort.",
  },
];

const treatmentGoals = [
  "Create a smoother denture foundation",
  "Improve comfort while chewing or speaking",
  "Reduce sore spots from sharp bone",
  "Prepare the mouth for a better prosthetic fit",
];
---

<Layout title={title} description={description} ogImage="/images/specialized-care.jpg">
  <Header />
  <main>
    <section class="bg-midnight text-surface" aria-labelledby="service-heading">
      <div
        class="mx-auto grid min-h-[calc(100dvh-76px)] max-w-7xl items-center gap-10 px-5 py-14 lg:gap-14 xl:grid-cols-[minmax(0,610px)_minmax(360px,500px)] xl:justify-between xl:px-0"
      >
        <div data-reveal>
          <a
            href="/#procedures"
            class="inline-flex text-sm font-bold text-accent transition-colors hover:text-surface"
          >
            ← Services
          </a>
          <p class="mt-10 text-xs font-bold tracking-[.34em] text-secondary">
            Procedures
          </p>
          <h1
            id="service-heading"
            class="serif mt-5 max-w-[760px] text-5xl leading-[0.96] text-surface sm:text-6xl xl:text-[72px]"
          >
            Pre-prosthetic surgery.
          </h1>
          <p class="mt-7 max-w-[590px] text-lg leading-8 text-surface/75 sm:text-xl">
            Pre-prosthetic surgery prepares the mouth before a partial or complete
            denture is placed. Small adjustments to bone or gum tissue can help the
            prosthesis fit more comfortably and securely.
          </p>
          <div class="mt-9 flex flex-col gap-3 sm:flex-row">
            <a
              href="/#appointment"
              class="inline-flex h-14 items-center justify-center rounded-md bg-secondary px-7 font-bold text-surface transition-opacity hover:opacity-90 sm:min-w-[223px]"
            >
              Request Appointment
            </a>
            <a
              href="tel:7852720444"
              class="inline-flex h-14 items-center justify-center rounded-md border border-surface/40 px-7 font-bold text-surface transition-colors hover:bg-surface/10 sm:min-w-[216px]"
            >
              Call (785) 272-0444
            </a>
          </div>
        </div>

        <div
          class="relative mx-auto w-full max-w-[500px] lg:mx-0"
          data-reveal
          style="--reveal-delay: 120ms"
        >
          <div
            class="absolute -bottom-3 left-3 right-[-12px] top-3 rounded-lg border border-secondary"
            aria-hidden="true"
          >
          </div>
          <div class="relative aspect-[4/5] overflow-hidden rounded-lg bg-surface/5">
            <img
              src="/images/specialized-care.jpg"
              alt="Dental imaging equipment used to plan pre-prosthetic surgery"
              class="h-full w-full object-cover object-center"
              width="5184"
              height="3456"
              loading="eager"
              decoding="async"
              fetchpriority="high"
            />
          </div>
        </div>
      </div>
    </section>

    <section class="bg-background py-20 text-foreground lg:py-24">
      <div
        class="mx-auto grid max-w-[920px] gap-10 px-5 min-[1400px]:max-w-[1400px] min-[1400px]:grid-cols-[220px_minmax(0,840px)_220px] min-[1400px]:items-start min-[1400px]:gap-8 min-[1700px]:max-w-[1640px] min-[1700px]:grid-cols-[280px_minmax(0,920px)_280px] min-[1700px]:gap-12"
      >
        <ServiceSidebar groupLabel="Procedures" currentHref={currentHref} />

        <div class="grid gap-20 lg:gap-24 min-[1400px]:col-start-2">
          <section class="pb-2 lg:pb-0" aria-labelledby="overview-heading">
            <div class="max-w-5xl" data-reveal>
              <p class="text-xs font-bold tracking-[.34em] text-secondary">
                Preparing for a prosthesis
              </p>
              <h2
                id="overview-heading"
                class="serif mt-4 text-4xl leading-tight sm:text-5xl"
              >
                A comfortable denture starts with a smooth, stable foundation.
              </h2>
              <div class="mt-7 space-y-6 text-base leading-8 text-muted">
                <p>
                  A denture rests directly on the bone ridge and gum tissue. If the
                  underlying bone is sharp, uneven, too bulky, or irregular after tooth
                  removal, the denture may not fit as comfortably as it should.
                </p>
                <p>
                  Pre-prosthetic surgery refers to the minor oral surgical procedures
                  that prepare the mouth before a prosthesis is placed. The goal is to
                  create the best possible shape and support for the final appliance.
                </p>
                <p>
                  The exact procedure depends on your anatomy, whether teeth need to be
                  extracted, and the type of partial or complete denture being planned.
                </p>
              </div>

              <div class="mt-8 rounded-lg border border-line bg-surface p-7 shadow-sm sm:p-8">
                <p class="text-xs font-bold tracking-[.28em] text-secondary">
                  Personalized planning
                </p>
                <p class="mt-3 text-base leading-7 text-muted">
                  Your surgeon will review your specific needs during your appointment
                  and coordinate the surgical plan around your prosthetic goals.
                </p>
              </div>
            </div>
          </section>

          <section class="pt-4 lg:pt-2" aria-labelledby="procedures-heading">
            <div class="max-w-3xl" data-reveal>
              <p class="text-xs font-bold tracking-[.34em] text-secondary">
                Common procedures
              </p>
              <h2
                id="procedures-heading"
                class="serif mt-4 text-4xl leading-tight sm:text-5xl"
              >
                Small changes to bone or gum tissue can improve the final fit.
              </h2>
              <p class="mt-6 text-base leading-7 text-muted">
                Some patients need one minor procedure, while others may need a
                combination of adjustments to prepare the mouth for a stable prosthesis.
              </p>
            </div>

            <div class="mt-12 grid gap-6 lg:grid-cols-2 lg:gap-7">
              {
                preparationSteps.map(({ number, title, body }, index) => (
                  <article
                    class="rounded-lg border border-line bg-surface p-8 shadow-sm sm:p-9 lg:p-10"
                    data-reveal
                    style={`--reveal-delay: ${(index % 2) * 80}ms`}
                  >
                    <div class="flex h-10 w-10 items-center justify-center rounded-full bg-aqua-pale text-sm font-bold text-secondary">
                      {number}
                    </div>
                    <h3 class="serif mt-6 text-2xl font-bold text-foreground">
                      {title}
                    </h3>
                    <p class="mt-4 text-base leading-7 text-muted">{body}</p>
                  </article>
                ))
              }
            </div>
          </section>

          <section
            class="grid gap-10 rounded-lg bg-aqua-soft p-8 sm:p-10 lg:grid-cols-[minmax(0,1fr)_280px] lg:items-center lg:p-12"
            aria-labelledby="goals-heading"
            data-reveal
          >
            <div>
              <p class="text-xs font-bold tracking-[.34em] text-secondary">
                Treatment goals
              </p>
              <h2
                id="goals-heading"
                class="serif mt-4 text-4xl leading-tight sm:text-5xl"
              >
                The goal is a prosthesis that feels stable and natural.
              </h2>
              <p class="mt-6 text-base leading-7 text-muted">
                Preparing the ridge and soft tissue can reduce pressure points and give
                your denture a more even surface to rest on.
              </p>
            </div>
            <div class="grid gap-3 text-sm font-bold text-foreground">
              {treatmentGoals.map((item) => (
                <p class="rounded-md bg-surface px-4 py-3">{item}</p>
              ))}
            </div>
          </section>

          <section class="grid gap-8 md:grid-cols-2">
            <article class="rounded-lg border border-line bg-surface p-8 shadow-sm sm:p-9 lg:p-10" data-reveal>
              <p class="text-xs font-bold tracking-[.28em] text-secondary">
                After tooth removal
              </p>
              <h2 class="serif mt-5 text-3xl leading-tight text-foreground">
                Extraction sites may need smoothing before a denture is made.
              </h2>
              <p class="mt-6 text-base leading-7 text-muted">
                If a tooth needs to be extracted, the underlying bone may be uneven.
                Smoothing or reshaping that area can help the prosthesis sit more
                comfortably once healing is complete.
              </p>
            </article>

            <article
              class="rounded-lg border border-line bg-surface p-8 shadow-sm sm:p-9 lg:p-10"
              data-reveal
              style="--reveal-delay: 120ms"
            >
              <p class="text-xs font-bold tracking-[.28em] text-secondary">
                Impacted teeth
              </p>
              <h2 class="serif mt-5 text-3xl leading-tight text-foreground">
                Some treatment plans include exposing impacted teeth.
              </h2>
              <p class="mt-6 text-base leading-7 text-muted">
                In selected cases, exposing impacted teeth may be part of preparing the
                mouth for the broader restorative or orthodontic plan.
              </p>
            </article>
          </section>

          <section class="rounded-lg bg-midnight px-8 py-12 text-surface sm:px-10 lg:px-12 lg:py-14">
            <div class="grid gap-8 lg:grid-cols-[minmax(0,1fr)_auto] lg:items-center">
              <div data-reveal>
                <p class="text-xs font-bold tracking-[.34em] text-secondary">
                  Plan the fit
                </p>
                <h2 class="serif mt-4 text-4xl leading-tight sm:text-5xl">
                  Prepare your mouth for a better prosthesis.
                </h2>
                <p class="mt-5 max-w-[660px] text-base leading-7 text-surface/75">
                  We will review your anatomy, discuss the planned appliance, and explain
                  whether pre-prosthetic surgery can improve comfort and stability.
                </p>
              </div>
              <div
                class="flex flex-col gap-3 sm:flex-row lg:flex-col"
                data-reveal
                style="--reveal-delay: 120ms"
              >
                <a
                  href="/#appointment"
                  class="inline-flex h-14 items-center justify-center rounded-md bg-secondary px-7 font-bold text-surface transition-opacity hover:opacity-90"
                >
                  Request Appointment
                </a>
                <a
                  href="tel:7852720444"
                  class="inline-flex h-14 items-center justify-center rounded-md border border-surface/40 px-7 font-bold text-surface transition-colors hover:bg-surface/10"
                >
                  Call (785) 272-0444
                </a>
              </div>
            </div>
          </section>
        </div>

        <div class="hidden min-[1400px]:block" aria-hidden="true"></div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
