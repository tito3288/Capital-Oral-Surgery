---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import ServiceSidebar from "../../components/ServiceSidebar.astro";

const title =
  "After Wisdom Teeth Extraction | Topeka, KS | Capital Oral Surgery";
const description =
  "Post-operative guidance after wisdom teeth extraction, including bleeding, pain, swelling, activity, dry socket, sinus precautions, infection, and when to call.";

const currentHref = "/services/after-extraction-of-wisdom-teeth/";

const recoveryCards = [
  {
    number: "01",
    title: "Bleeding and Gauze",
    body: "After teeth are removed, the gums are sutured and gauze is placed to help control bleeding. Bite down gently as directed, and expect minor bleeding during the first day.",
  },
  {
    number: "02",
    title: "Pain and Swelling",
    body: "Pain can range from mild discomfort to stronger soreness. Swelling usually peaks on the second day and should begin improving on the third day.",
  },
  {
    number: "03",
    title: "Ice and Heat",
    body: "Use ice through the first day to limit swelling. Moist heat on days two and three can help relax stiff jaw muscles and improve opening.",
  },
  {
    number: "04",
    title: "Rest and Activity",
    body: "Plan to rest for a few days before returning to a busy social, academic, or athletic schedule. Most patients feel over the hump in three to five days.",
  },
];

const concerns = [
  "Dry socket",
  "Infection",
  "Sinus communication",
  "Temporary numbness or tingling",
  "Jaw stiffness",
  "Facial bruising or oozing",
];
---

<Layout title={title} description={description} ogImage="/images/specialized-care.jpg">
  <Header />
  <main>
    <section class="bg-midnight text-surface" aria-labelledby="service-heading">
      <div
        class="mx-auto grid min-h-[calc(100dvh-76px)] max-w-7xl items-center gap-14 px-5 py-14 lg:grid-cols-[minmax(0,610px)_minmax(380px,500px)] lg:px-0"
      >
        <div data-reveal>
          <a
            href="/#procedures"
            class="inline-flex text-sm font-bold text-accent transition-colors hover:text-surface"
          >
            ← Services
          </a>
          <p class="mt-10 text-xs font-bold uppercase tracking-[.34em] text-secondary">
            Wisdom Teeth
          </p>
          <h1
            id="service-heading"
            class="serif mt-5 max-w-[760px] text-5xl leading-[0.96] text-surface sm:text-6xl lg:text-[72px]"
          >
            After wisdom tooth extraction.
          </h1>
          <p class="mt-7 max-w-[590px] text-lg leading-8 text-surface/75 sm:text-xl">
            Recovery is smoother when you know what to expect. These instructions cover
            bleeding, swelling, activity, dry socket, infection, sinus precautions, and
            when to call our office.
          </p>
          <div class="mt-9 flex flex-col gap-3 sm:flex-row">
            <a
              href="/#appointment"
              class="inline-flex h-14 items-center justify-center rounded-md bg-secondary px-7 font-bold text-surface transition-opacity hover:opacity-90 sm:min-w-[223px]"
            >
              Request Appointment
            </a>
            <a
              href="tel:7852720444"
              class="inline-flex h-14 items-center justify-center rounded-md border border-surface/40 px-7 font-bold text-surface transition-colors hover:bg-surface/10 sm:min-w-[216px]"
            >
              Call (785) 272-0444
            </a>
          </div>
        </div>

        <div
          class="relative mx-auto w-full max-w-[500px] lg:mx-0"
          data-reveal
          style="--reveal-delay: 120ms"
        >
          <div
            class="absolute -bottom-3 left-3 right-[-12px] top-3 rounded-lg border border-secondary"
            aria-hidden="true"
          >
          </div>
          <div class="relative aspect-[4/5] overflow-hidden rounded-lg bg-surface/5">
            <img
              src="/images/specialized-care.jpg"
              alt="3D dental imaging equipment used for oral surgery planning"
              class="h-full w-full object-cover object-center"
              width="5184"
              height="3456"
              loading="eager"
              decoding="async"
              fetchpriority="high"
            />
          </div>
        </div>
      </div>
    </section>

    <section class="bg-background py-20 text-foreground lg:py-24">
      <div
        class="mx-auto grid max-w-[1600px] gap-10 px-5 lg:grid-cols-[minmax(0,1fr)_minmax(0,920px)_minmax(0,1fr)] lg:items-start lg:gap-12"
      >
        <ServiceSidebar groupLabel="Wisdom Teeth" currentHref={currentHref} />

        <div class="grid gap-20 lg:col-start-2 lg:gap-24">
          <section class="pb-2 lg:pb-0" aria-labelledby="aftercare-heading">
            <div class="max-w-5xl" data-reveal>
              <p class="text-xs font-bold uppercase tracking-[.34em] text-secondary">
                Post-Operative Care
              </p>
              <h2
                id="aftercare-heading"
                class="serif mt-4 text-4xl leading-tight sm:text-5xl"
              >
                The first few days are about comfort, clot protection, and rest.
              </h2>
              <div class="mt-7 space-y-6 text-base leading-8 text-muted">
                <p>
                  Wisdom tooth removal may be performed with local anesthesia, nitrous
                  oxide, or general anesthesia. These options and surgical risks are
                  reviewed before treatment.
                </p>
                <p>
                  After surgery, you will rest under supervision until you are ready to
                  go home. Your post-operative kit may include instructions, medication,
                  antibiotics, and a follow-up appointment.
                </p>
                <p>
                  Follow the written instructions closely, especially during the first
                  few days. This helps protect the healing blood clot and keeps recovery
                  as comfortable as possible.
                </p>
              </div>

              <div class="mt-8 rounded-lg border border-line bg-surface p-7 shadow-sm sm:p-8">
                <p class="text-xs font-bold uppercase tracking-[.28em] text-secondary">
                  Most patients improve in 3 to 5 days
                </p>
                <p class="mt-3 text-base leading-7 text-muted">
                  Recovery varies, but many patients feel they are over the hump and on
                  the way to recovery within several days.
                </p>
              </div>
            </div>
          </section>

          <section class="pt-4 lg:pt-2" aria-labelledby="recovery-heading">
            <div class="max-w-3xl" data-reveal>
              <p class="text-xs font-bold uppercase tracking-[.34em] text-secondary">
                What You May Feel
              </p>
              <h2
                id="recovery-heading"
                class="serif mt-4 text-4xl leading-tight sm:text-5xl"
              >
                Bleeding, soreness, swelling, and stiffness can be normal early on.
              </h2>
              <p class="mt-6 text-base leading-7 text-muted">
                Every patient reacts differently. The goal is to control swelling,
                protect the clot, rest, and let your body begin healing before returning
                to a demanding schedule.
              </p>
            </div>

            <div class="mt-12 grid gap-6 lg:grid-cols-2 lg:gap-7">
              {
                recoveryCards.map(({ number, title, body }, index) => (
                  <article
                    class="rounded-lg border border-line bg-surface p-8 shadow-sm sm:p-9 lg:p-10"
                    data-reveal
                    style={`--reveal-delay: ${(index % 2) * 80}ms`}
                  >
                    <div class="flex h-10 w-10 items-center justify-center rounded-full bg-aqua-pale text-sm font-bold text-secondary">
                      {number}
                    </div>
                    <h3 class="serif mt-6 text-2xl font-bold text-foreground">
                      {title}
                    </h3>
                    <p class="mt-4 text-base leading-7 text-muted">{body}</p>
                  </article>
                ))
              }
            </div>
          </section>

          <section
            class="grid gap-10 rounded-lg bg-aqua-soft p-8 sm:p-10 lg:grid-cols-[minmax(0,1fr)_280px] lg:items-center lg:p-12"
            aria-labelledby="concerns-heading"
            data-reveal
          >
            <div>
              <p class="text-xs font-bold uppercase tracking-[.34em] text-secondary">
                Possible Concerns
              </p>
              <h2
                id="concerns-heading"
                class="serif mt-4 text-4xl leading-tight sm:text-5xl"
              >
                Know which changes deserve a call.
              </h2>
              <p class="mt-6 text-base leading-7 text-muted">
                As with any surgery, unexpected healing events can happen. Contact the
                office if pain worsens, swelling does not improve, numbness or tingling
                persists, or you suspect infection or dry socket.
              </p>
            </div>
            <div class="grid gap-3 text-sm font-bold text-foreground">
              {concerns.map((item) => (
                <p class="rounded-md bg-surface px-4 py-3">{item}</p>
              ))}
            </div>
          </section>

          <section class="grid gap-8 md:grid-cols-2">
            <article class="rounded-lg border border-line bg-surface p-8 shadow-sm sm:p-9 lg:p-10" data-reveal>
              <p class="text-xs font-bold uppercase tracking-[.28em] text-secondary">
                Dry Socket
              </p>
              <h2 class="serif mt-5 text-3xl leading-tight text-foreground">
                Deep aching pain can start several days later.
              </h2>
              <p class="mt-6 text-base leading-7 text-muted">
                Dry socket occurs when the blood clot is lost too early. It is more
                common in the lower jaw and may cause deep, dull pain that radiates
                toward the ear or chin. Treatment may include medicated dressing.
              </p>
            </article>

            <article
              class="rounded-lg border border-line bg-surface p-8 shadow-sm sm:p-9 lg:p-10"
              data-reveal
              style="--reveal-delay: 120ms"
            >
              <p class="text-xs font-bold uppercase tracking-[.28em] text-secondary">
                Sinus and Nerve Awareness
              </p>
              <h2 class="serif mt-5 text-3xl leading-tight text-foreground">
                Some rare risks need special instructions.
              </h2>
              <p class="mt-6 text-base leading-7 text-muted">
                Upper wisdom teeth sit near the sinuses, and lower wisdom teeth can be
                near sensory nerves. If you notice sinus pressure changes, numbness, or
                tingling after surgery, call the office for guidance.
              </p>
            </article>
          </section>

          <section class="rounded-lg bg-midnight px-8 py-12 text-surface sm:px-10 lg:px-12 lg:py-14">
            <div class="grid gap-8 lg:grid-cols-[minmax(0,1fr)_auto] lg:items-center">
              <div data-reveal>
                <p class="text-xs font-bold uppercase tracking-[.34em] text-secondary">
                  We Are Here to Help
                </p>
                <h2 class="serif mt-4 text-4xl leading-tight sm:text-5xl">
                  Call with recovery questions.
                </h2>
                <p class="mt-5 max-w-[660px] text-base leading-7 text-surface/75">
                  If you are unsure whether what you are feeling is normal, our team is
                  here to help you through recovery.
                </p>
              </div>
              <div
                class="flex flex-col gap-3 sm:flex-row lg:flex-col"
                data-reveal
                style="--reveal-delay: 120ms"
              >
                <a
                  href="/#appointment"
                  class="inline-flex h-14 items-center justify-center rounded-md bg-secondary px-7 font-bold text-surface transition-opacity hover:opacity-90"
                >
                  Request Appointment
                </a>
                <a
                  href="tel:7852720444"
                  class="inline-flex h-14 items-center justify-center rounded-md border border-surface/40 px-7 font-bold text-surface transition-colors hover:bg-surface/10"
                >
                  Call (785) 272-0444
                </a>
              </div>
            </div>
          </section>
        </div>

        <div class="hidden lg:block" aria-hidden="true"></div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
