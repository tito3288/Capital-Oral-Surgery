---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import ServiceSidebar from "../../components/ServiceSidebar.astro";

const title =
  "Zygomatic Implants | Dental Implants for Severe Bone Loss in Topeka, KS";
const description =
  "Learn how zygomatic implants can provide fixed teeth for patients with severe upper jaw bone loss, often without bone grafting or sinus lift procedures.";

const currentHref = "/services/zygomatic-implants/";

const processSteps = [
  {
    number: "01",
    title: "Consultation and imaging",
    body: "Your team gathers detailed information with advanced technology, including CBCT imaging and 3D planning, so each implant can be positioned with precision.",
  },
  {
    number: "02",
    title: "Pre-surgical planning",
    body: "The scans help your surgeon understand bone quality, sinus anatomy, restoration needs, and whether traditional implants will be combined with zygomatic implants.",
  },
  {
    number: "03",
    title: "Implant placement",
    body: "Long implant screws are anchored in the zygoma, the strong cheekbone near the sinus. Often, two zygomatic implants are used with two to four traditional implants in the front jaw.",
  },
  {
    number: "04",
    title: "Single-surgery treatment",
    body: "If teeth need to be removed first, extractions may be completed during the same surgery before zygomatic implant placement.",
  },
];

const benefits = [
  "Fixed teeth can often be loaded immediately",
  "No bone grafting for many patients",
  "No sinus lift in many cases",
  "Comfort through IV sedation",
  "Quick treatment and recovery time",
  "Single-surgery potential",
];
---

<Layout title={title} description={description} ogImage="/images/specialized-care.jpg">
  <Header />
  <main>
    <section class="bg-midnight text-surface" aria-labelledby="service-heading">
      <div
        class="mx-auto grid min-h-[calc(100dvh-76px)] max-w-7xl items-center gap-14 px-5 py-14 lg:grid-cols-[minmax(0,610px)_minmax(380px,500px)] lg:px-0"
      >
        <div data-reveal>
          <a
            href="/#procedures"
            class="inline-flex text-sm font-bold text-accent transition-colors hover:text-surface"
          >
            ← Services
          </a>
          <p class="mt-10 text-xs font-bold uppercase tracking-[.34em] text-secondary">
            Dental Implants
          </p>
          <h1
            id="service-heading"
            class="serif mt-5 max-w-[760px] text-5xl leading-[0.96] text-surface sm:text-6xl lg:text-[72px]"
          >
            Zygomatic implants.
          </h1>
          <p class="mt-7 max-w-[590px] text-lg leading-8 text-surface/75 sm:text-xl">
            Zygomatic implants are designed for patients with severe upper-jaw bone
            loss who have been told they are not candidates for conventional implants
            or that dentures are their only option.
          </p>
          <div class="mt-9 flex flex-col gap-3 sm:flex-row">
            <a
              href="/#appointment"
              class="inline-flex h-14 items-center justify-center rounded-md bg-secondary px-7 font-bold text-surface transition-opacity hover:opacity-90 sm:min-w-[223px]"
            >
              Request Appointment
            </a>
            <a
              href="tel:7852720444"
              class="inline-flex h-14 items-center justify-center rounded-md border border-surface/40 px-7 font-bold text-surface transition-colors hover:bg-surface/10 sm:min-w-[216px]"
            >
              Call (785) 272-0444
            </a>
          </div>
        </div>

        <div
          class="relative mx-auto w-full max-w-[500px] lg:mx-0"
          data-reveal
          style="--reveal-delay: 120ms"
        >
          <div
            class="absolute -bottom-3 left-3 right-[-12px] top-3 rounded-lg border border-secondary"
            aria-hidden="true"
          >
          </div>
          <div class="relative aspect-[4/5] overflow-hidden rounded-lg bg-surface/5">
            <img
              src="/images/specialized-care.jpg"
              alt="3D dental imaging equipment used for dental implant planning"
              class="h-full w-full object-cover object-center"
              width="5184"
              height="3456"
              loading="eager"
              decoding="async"
              fetchpriority="high"
            />
          </div>
        </div>
      </div>
    </section>

    <section class="bg-background py-20 text-foreground lg:py-24">
      <div
        class="mx-auto grid max-w-[1600px] gap-10 px-5 lg:grid-cols-[minmax(0,1fr)_minmax(0,920px)_minmax(0,1fr)] lg:items-start lg:gap-12"
      >
        <ServiceSidebar groupLabel="Dental Implants" currentHref={currentHref} />

        <div class="grid gap-20 lg:col-start-2 lg:gap-24">
          <section class="pb-2 lg:pb-0" aria-labelledby="bone-loss-heading">
            <div class="max-w-5xl" data-reveal>
              <p class="text-xs font-bold uppercase tracking-[.34em] text-secondary">
                Severe Bone Loss
              </p>
              <h2
                id="bone-loss-heading"
                class="serif mt-4 text-4xl leading-tight sm:text-5xl"
              >
                A teeth replacement option when upper-jaw bone is limited.
              </h2>
              <div class="mt-7 space-y-6 text-base leading-8 text-muted">
                <p>
                  Patients with moderate, advanced, or extreme resorption in the upper
                  jaw may not have enough bone to support conventional dental implants.
                  Zygomatic implants are an alternative to traditional implants and bone
                  grafting in these cases.
                </p>
                <p>
                  Instead of relying only on upper-jaw bone, zygomatic implants attach
                  to the zygoma, or cheekbone. This thick, solid bone can provide stable
                  support for a non-removable replacement appliance.
                </p>
                <p>
                  Because this approach can avoid bone grafting and the lengthy healing
                  period that often follows grafting, implants may be placed immediately
                  for patients who qualify.
                </p>
              </div>

              <div class="mt-8 rounded-lg border border-line bg-surface p-7 shadow-sm sm:p-8">
                <p class="text-xs font-bold uppercase tracking-[.28em] text-secondary">
                  Bone graft alternative
                </p>
                <p class="mt-3 text-base leading-7 text-muted">
                  Zygomatic implants are often considered when bone grafting, sinus lift,
                  or conventional implant treatment would be too limited, lengthy, or
                  unpredictable for the upper jaw.
                </p>
              </div>
            </div>
          </section>

          <section class="pt-4 lg:pt-2" aria-labelledby="process-heading">
            <div class="max-w-3xl" data-reveal>
              <p class="text-xs font-bold uppercase tracking-[.34em] text-secondary">
                Planning and Placement
              </p>
              <h2
                id="process-heading"
                class="serif mt-4 text-4xl leading-tight sm:text-5xl"
              >
                3D planning guides precise placement in the cheekbone.
              </h2>
              <p class="mt-6 text-base leading-7 text-muted">
                Zygomatic implant placement requires careful planning, advanced imaging,
                and specialized surgical training. The goal is to create strong support
                for fixed teeth while avoiding unnecessary grafting whenever possible.
              </p>
            </div>

            <div class="mt-12 grid gap-6 lg:grid-cols-2 lg:gap-7">
              {
                processSteps.map(({ number, title, body }, index) => (
                  <article
                    class="rounded-lg border border-line bg-surface p-8 shadow-sm sm:p-9 lg:p-10"
                    data-reveal
                    style={`--reveal-delay: ${(index % 2) * 80}ms`}
                  >
                    <div class="flex h-10 w-10 items-center justify-center rounded-full bg-aqua-pale text-sm font-bold text-secondary">
                      {number}
                    </div>
                    <h3 class="serif mt-6 text-2xl font-bold text-foreground">
                      {title}
                    </h3>
                    <p class="mt-4 text-base leading-7 text-muted">{body}</p>
                  </article>
                ))
              }
            </div>
          </section>

          <section
            class="grid gap-10 rounded-lg bg-aqua-soft p-8 sm:p-10 lg:grid-cols-[minmax(0,1fr)_280px] lg:items-center lg:p-12"
            aria-labelledby="benefits-heading"
            data-reveal
          >
            <div>
              <p class="text-xs font-bold uppercase tracking-[.34em] text-secondary">
                Benefits
              </p>
              <h2
                id="benefits-heading"
                class="serif mt-4 text-4xl leading-tight sm:text-5xl"
              >
                A fixed solution without the usual grafting timeline.
              </h2>
              <p class="mt-6 text-base leading-7 text-muted">
                For the right patient, zygomatic implants can provide fully functional
                teeth, reduce the need for grafting, and streamline treatment into a
                shorter, more comfortable path.
              </p>
            </div>
            <div class="grid gap-3 text-sm font-bold text-foreground">
              {benefits.map((item) => (
                <p class="rounded-md bg-surface px-4 py-3">{item}</p>
              ))}
            </div>
          </section>

          <section class="grid gap-8 md:grid-cols-2">
            <article class="rounded-lg border border-line bg-surface p-8 shadow-sm sm:p-9 lg:p-10" data-reveal>
              <p class="text-xs font-bold uppercase tracking-[.28em] text-secondary">
                Training and Experience
              </p>
              <h2 class="serif mt-5 text-3xl leading-tight text-foreground">
                This treatment requires specialized expertise.
              </h2>
              <p class="mt-6 text-base leading-7 text-muted">
                The surgical skill involved in placing zygomatic implants requires
                extensive training and experience. Our doctors have formal training in
                zygomatic placement and plan each case carefully.
              </p>
            </article>

            <article
              class="rounded-lg border border-line bg-surface p-8 shadow-sm sm:p-9 lg:p-10"
              data-reveal
              style="--reveal-delay: 120ms"
            >
              <p class="text-xs font-bold uppercase tracking-[.28em] text-secondary">
                Comfort and Recovery
              </p>
              <h2 class="serif mt-5 text-3xl leading-tight text-foreground">
                Most patients are surprised by recovery.
              </h2>
              <p class="mt-6 text-base leading-7 text-muted">
                IV sedation and anti-inflammatory medications help support comfort.
                Any discomfort is often similar to bone grafting recovery, with mild
                bruising and pain usually managed with over-the-counter medications.
              </p>
            </article>
          </section>

          <section class="rounded-lg bg-midnight px-8 py-12 text-surface sm:px-10 lg:px-12 lg:py-14">
            <div class="grid gap-8 lg:grid-cols-[minmax(0,1fr)_auto] lg:items-center">
              <div data-reveal>
                <p class="text-xs font-bold uppercase tracking-[.34em] text-secondary">
                  Reclaim Confidence
                </p>
                <h2 class="serif mt-4 text-4xl leading-tight sm:text-5xl">
                  Find out if zygomatic implants are possible.
                </h2>
                <p class="mt-5 max-w-[660px] text-base leading-7 text-surface/75">
                  We will review your imaging, bone condition, and goals to determine
                  whether zygomatic implants can restore function and confidence.
                </p>
              </div>
              <div
                class="flex flex-col gap-3 sm:flex-row lg:flex-col"
                data-reveal
                style="--reveal-delay: 120ms"
              >
                <a
                  href="/#appointment"
                  class="inline-flex h-14 items-center justify-center rounded-md bg-secondary px-7 font-bold text-surface transition-opacity hover:opacity-90"
                >
                  Request Appointment
                </a>
                <a
                  href="tel:7852720444"
                  class="inline-flex h-14 items-center justify-center rounded-md border border-surface/40 px-7 font-bold text-surface transition-colors hover:bg-surface/10"
                >
                  Call (785) 272-0444
                </a>
              </div>
            </div>
          </section>
        </div>

        <div class="hidden lg:block" aria-hidden="true"></div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
