---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import ServiceSidebar from "../../components/ServiceSidebar.astro";

const title = "3D Imaging | Cone Beam CT | Topeka, KS | Capital Oral Surgery";
const description =
  "Learn how cone beam CT 3D imaging helps diagnose oral surgery concerns, plan treatment, minimize radiation exposure, and collaborate with referring doctors.";

const currentHref = "/services/3d-imaging/";

const imagingAdvantages = [
  {
    number: "01",
    title: "More accurate diagnosis",
    body: "Cone beam CT imaging provides detailed 3D views that help the team evaluate anatomy, identify concerns, and plan treatment with greater confidence.",
  },
  {
    number: "02",
    title: "Focused field of view",
    body: "The scanner can focus on the specific area of concern, which helps limit radiation exposure while still capturing the needed detail.",
  },
  {
    number: "03",
    title: "Clear treatment planning",
    body: "Three-dimensional images make it easier to understand bone, teeth, nerves, sinuses, and other anatomy involved in treatment.",
  },
  {
    number: "04",
    title: "Referring doctor collaboration",
    body: "Images can be shared with your referring doctor so the full care team can collaborate on diagnosis and treatment planning.",
  },
];

const imagingUses = [
  "Dental implant planning",
  "Wisdom tooth evaluation",
  "Bone grafting assessment",
  "Sinus and nerve location review",
  "Oral pathology or surgical planning",
];
---

<Layout title={title} description={description} ogImage="/images/specialized-care.jpg">
  <Header />
  <main>
    <section class="bg-midnight text-surface" aria-labelledby="service-heading">
      <div
        class="mx-auto grid min-h-[calc(100dvh-76px)] max-w-7xl items-center gap-14 px-5 py-14 lg:grid-cols-[minmax(0,610px)_minmax(380px,500px)] lg:px-0"
      >
        <div data-reveal>
          <a
            href="/#procedures"
            class="inline-flex text-sm font-bold text-accent transition-colors hover:text-surface"
          >
            ← Services
          </a>
          <p class="mt-10 text-xs font-bold uppercase tracking-[.34em] text-secondary">
            Procedures
          </p>
          <h1
            id="service-heading"
            class="serif mt-5 max-w-[760px] text-5xl leading-[0.96] text-surface sm:text-6xl lg:text-[72px]"
          >
            3D imaging.
          </h1>
          <p class="mt-7 max-w-[590px] text-lg leading-8 text-surface/75 sm:text-xl">
            Cone beam CT technology gives our team precise, crystal-clear 3D images for
            diagnosis and treatment planning while focusing the scan on your specific
            area of concern.
          </p>
          <div class="mt-9 flex flex-col gap-3 sm:flex-row">
            <a
              href="/#appointment"
              class="inline-flex h-14 items-center justify-center rounded-md bg-secondary px-7 font-bold text-surface transition-opacity hover:opacity-90 sm:min-w-[223px]"
            >
              Request Appointment
            </a>
            <a
              href="tel:7852720444"
              class="inline-flex h-14 items-center justify-center rounded-md border border-surface/40 px-7 font-bold text-surface transition-colors hover:bg-surface/10 sm:min-w-[216px]"
            >
              Call (785) 272-0444
            </a>
          </div>
        </div>

        <div
          class="relative mx-auto w-full max-w-[500px] lg:mx-0"
          data-reveal
          style="--reveal-delay: 120ms"
        >
          <div
            class="absolute -bottom-3 left-3 right-[-12px] top-3 rounded-lg border border-secondary"
            aria-hidden="true"
          >
          </div>
          <div class="relative aspect-[4/5] overflow-hidden rounded-lg bg-surface/5">
            <img
              src="/images/specialized-care.jpg"
              alt="Cone beam CT imaging equipment used for oral surgery planning"
              class="h-full w-full object-cover object-center"
              width="5184"
              height="3456"
              loading="eager"
              decoding="async"
              fetchpriority="high"
            />
          </div>
        </div>
      </div>
    </section>

    <section class="bg-background py-20 text-foreground lg:py-24">
      <div
        class="mx-auto grid max-w-[1600px] gap-10 px-5 lg:grid-cols-[minmax(0,1fr)_minmax(0,920px)_minmax(0,1fr)] lg:items-start lg:gap-12"
      >
        <ServiceSidebar groupLabel="Procedures" currentHref={currentHref} />

        <div class="grid gap-20 lg:col-start-2 lg:gap-24">
          <section class="pb-2 lg:pb-0" aria-labelledby="overview-heading">
            <div class="max-w-5xl" data-reveal>
              <p class="text-xs font-bold uppercase tracking-[.34em] text-secondary">
                Cone Beam CT Scan
              </p>
              <h2
                id="overview-heading"
                class="serif mt-4 text-4xl leading-tight sm:text-5xl"
              >
                Three-dimensional imaging helps us see the details that matter.
              </h2>
              <div class="mt-7 space-y-6 text-base leading-8 text-muted">
                <p>
                  The CS 9300 cone beam CT system helps our oral and maxillofacial
                  surgery team diagnose potential concerns more accurately and plan care
                  with greater confidence.
                </p>
                <p>
                  Unlike a traditional spiral CT scanner, cone beam technology captures
                  precise digital images while minimizing radiation exposure. The scanner
                  can focus on the field of view that best fits your treatment needs.
                </p>
                <p>
                  The resulting 3D images help us explain your case more clearly,
                  answer questions, and plan treatment around the actual anatomy we see.
                </p>
              </div>

              <div class="mt-8 rounded-lg border border-line bg-surface p-7 shadow-sm sm:p-8">
                <p class="text-xs font-bold uppercase tracking-[.28em] text-secondary">
                  Focused scanning
                </p>
                <p class="mt-3 text-base leading-7 text-muted">
                  Choosing the right scanning area helps capture the information needed
                  while limiting exposure to the area of concern.
                </p>
              </div>
            </div>
          </section>

          <section class="pt-4 lg:pt-2" aria-labelledby="advantages-heading">
            <div class="max-w-3xl" data-reveal>
              <p class="text-xs font-bold uppercase tracking-[.34em] text-secondary">
                Why 3D Matters
              </p>
              <h2
                id="advantages-heading"
                class="serif mt-4 text-4xl leading-tight sm:text-5xl"
              >
                Better visualization supports safer, more confident planning.
              </h2>
              <p class="mt-6 text-base leading-7 text-muted">
                Detailed views of teeth, bone, nerves, sinuses, and surrounding anatomy
                can help reduce guesswork and support clearer communication.
              </p>
            </div>

            <div class="mt-12 grid gap-6 lg:grid-cols-2 lg:gap-7">
              {
                imagingAdvantages.map(({ number, title, body }, index) => (
                  <article
                    class="rounded-lg border border-line bg-surface p-8 shadow-sm sm:p-9 lg:p-10"
                    data-reveal
                    style={`--reveal-delay: ${(index % 2) * 80}ms`}
                  >
                    <div class="flex h-10 w-10 items-center justify-center rounded-full bg-aqua-pale text-sm font-bold text-secondary">
                      {number}
                    </div>
                    <h3 class="serif mt-6 text-2xl font-bold text-foreground">
                      {title}
                    </h3>
                    <p class="mt-4 text-base leading-7 text-muted">{body}</p>
                  </article>
                ))
              }
            </div>
          </section>

          <section
            class="grid gap-10 rounded-lg bg-aqua-soft p-8 sm:p-10 lg:grid-cols-[minmax(0,1fr)_280px] lg:items-center lg:p-12"
            aria-labelledby="uses-heading"
            data-reveal
          >
            <div>
              <p class="text-xs font-bold uppercase tracking-[.34em] text-secondary">
                Treatment Planning
              </p>
              <h2
                id="uses-heading"
                class="serif mt-4 text-4xl leading-tight sm:text-5xl"
              >
                3D imaging supports many oral surgery decisions.
              </h2>
              <p class="mt-6 text-base leading-7 text-muted">
                The scan can help evaluate anatomy before treatment and may reduce the
                need for multiple visits by giving the team more complete information in
                the office.
              </p>
            </div>
            <div class="grid gap-3 text-sm font-bold text-foreground">
              {imagingUses.map((item) => (
                <p class="rounded-md bg-surface px-4 py-3">{item}</p>
              ))}
            </div>
          </section>

          <section class="grid gap-8 md:grid-cols-2">
            <article class="rounded-lg border border-line bg-surface p-8 shadow-sm sm:p-9 lg:p-10" data-reveal>
              <p class="text-xs font-bold uppercase tracking-[.28em] text-secondary">
                Patient Understanding
              </p>
              <h2 class="serif mt-5 text-3xl leading-tight text-foreground">
                Seeing the anatomy can make the plan easier to understand.
              </h2>
              <p class="mt-6 text-base leading-7 text-muted">
                Three-dimensional visualization helps the team explain the particulars
                of your case and answer questions with more clarity.
              </p>
            </article>

            <article
              class="rounded-lg border border-line bg-surface p-8 shadow-sm sm:p-9 lg:p-10"
              data-reveal
              style="--reveal-delay: 120ms"
            >
              <p class="text-xs font-bold uppercase tracking-[.28em] text-secondary">
                Care Collaboration
              </p>
              <h2 class="serif mt-5 text-3xl leading-tight text-foreground">
                Images can be shared with your referring doctor.
              </h2>
              <p class="mt-6 text-base leading-7 text-muted">
                When appropriate, 3D images can be shared quickly with your referring
                dentist or doctor so the care team can coordinate treatment together.
              </p>
            </article>
          </section>

          <section class="rounded-lg bg-midnight px-8 py-12 text-surface sm:px-10 lg:px-12 lg:py-14">
            <div class="grid gap-8 lg:grid-cols-[minmax(0,1fr)_auto] lg:items-center">
              <div data-reveal>
                <p class="text-xs font-bold uppercase tracking-[.34em] text-secondary">
                  Precise Planning
                </p>
                <h2 class="serif mt-4 text-4xl leading-tight sm:text-5xl">
                  Start with a clearer picture.
                </h2>
                <p class="mt-5 max-w-[660px] text-base leading-7 text-surface/75">
                  We use 3D imaging to better understand your anatomy, explain your
                  options, and plan oral surgery with confidence.
                </p>
              </div>
              <div
                class="flex flex-col gap-3 sm:flex-row lg:flex-col"
                data-reveal
                style="--reveal-delay: 120ms"
              >
                <a
                  href="/#appointment"
                  class="inline-flex h-14 items-center justify-center rounded-md bg-secondary px-7 font-bold text-surface transition-opacity hover:opacity-90"
                >
                  Request Appointment
                </a>
                <a
                  href="tel:7852720444"
                  class="inline-flex h-14 items-center justify-center rounded-md border border-surface/40 px-7 font-bold text-surface transition-colors hover:bg-surface/10"
                >
                  Call (785) 272-0444
                </a>
              </div>
            </div>
          </section>
        </div>

        <div class="hidden lg:block" aria-hidden="true"></div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
